<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - The Academic Atelier</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OnlineExam.styles.css" asp-append-version="true" />

    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script src="https://cdn.tailwindcss.com"></script>
    <script id="tailwind-config">
        tailwind.config = {
          theme: {
            extend: {
              colors: {
                  "brand-blue": "#005bbf",
                  "brand-blue-container": "#1a73e8",
                  "brand-orange": "#FF8A65",
                  "brand-yellow": "#fbbc05",
                  "brand-teal": "#006e2c",
                  "surface-bg": "#f9f9ff",
                  "on-surface-variant": "#414754"
              },
              fontFamily: {
                  "headline": ["Manrope"],
                  "body": ["Inter"]
              }
            }
          }
        }
    </script>

    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }

        body {
            font-family: 'Inter', sans-serif;
        }

        h1, h2, h3, h4, h5 {
            font-family: 'Manrope', sans-serif;
        }

        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: #94a3b8;
            }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-surface-bg font-body text-slate-800 antialiased">
    @{
        var currentPath = Context.Request.Path.Value ?? string.Empty;
        string headerTitle;
        var serverToastMessage = TempData["ToastMessage"] as string;
        var serverToastType = (TempData["ToastType"] as string) ?? "success";

        if (currentPath.StartsWith("/Teacher/Classes", StringComparison.OrdinalIgnoreCase)
            || currentPath.StartsWith("/Teacher/ManageClass", StringComparison.OrdinalIgnoreCase))
        {
            headerTitle = "Quản lý lớp học";
        }
        else if (currentPath.StartsWith("/Teacher/Exams", StringComparison.OrdinalIgnoreCase))
        {
            headerTitle = "Quản lý đề thi";
        }
        else if (currentPath.StartsWith("/Teacher/Sessions", StringComparison.OrdinalIgnoreCase)
            || currentPath.StartsWith("/Teacher/MonitorSession", StringComparison.OrdinalIgnoreCase))
        {
            headerTitle = "Tổ chức ca thi";
        }
        else if (currentPath.StartsWith("/Teacher/Reports", StringComparison.OrdinalIgnoreCase))
        {
            headerTitle = "Báo cáo thống kê";
        }
        else if (currentPath.StartsWith("/Student/JoinClass", StringComparison.OrdinalIgnoreCase))
        {
            headerTitle = "Tham gia lớp";
        }
        else if (currentPath.StartsWith("/Student/Exams", StringComparison.OrdinalIgnoreCase))
        {
            headerTitle = "Ca thi của tôi";
        }
        else if (currentPath.StartsWith("/Student/Results", StringComparison.OrdinalIgnoreCase))
        {
            headerTitle = "Kết quả";
        }
        else if (currentPath.StartsWith("/Student", StringComparison.OrdinalIgnoreCase))
        {
            headerTitle = "Trang chủ";
        }
        else if (currentPath.StartsWith("/Teacher", StringComparison.OrdinalIgnoreCase))
        {
            headerTitle = "Tổng quan";
        }
        else
        {
            headerTitle = "Hệ thống thi trắc nghiệm online";
        }
    }

    <div class="flex h-screen overflow-hidden">
        <partial name="_Sidebar" />

        <main class="flex-1 flex flex-col h-screen overflow-hidden relative bg-surface-bg ml-24 peer-hover:ml-[260px] transition-all duration-300 ease-in-out">
            <header class="h-20 bg-white/80 backdrop-blur-md border-b border-slate-100 flex items-center justify-between px-8 z-10 sticky top-0">
                <div class="flex-1 max-w-2xl font-headline font-semibold text-lg text-slate-800">
                    @headerTitle
                </div>
                <div class="ml-4 flex items-center gap-6">
                    <button class="text-slate-500 hover:text-brand-blue transition-colors">
                        <span class="material-symbols-outlined text-2xl">settings</span>
                    </button>
                    <button class="relative text-slate-500 hover:text-brand-blue transition-colors">
                        <span class="material-symbols-outlined text-2xl">notifications</span>
                        <span class="absolute top-0 right-0 flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500 border border-white"></span>
                        </span>
                    </button>
                </div>
            </header>

            <div class="flex-1 overflow-y-auto p-8 lg:p-12">
                <div>
                    @RenderBody()
                </div>
            </div>
        </main>
    </div>

    <div id="app-toast-container" class="fixed top-4 right-4 z-[140] pointer-events-none">
        <div id="app-toast" class="hidden min-w-[280px] max-w-[420px] rounded-2xl border bg-white shadow-[0_20px_40px_rgba(15,23,42,0.12)] px-4 py-3 flex items-start gap-3 pointer-events-auto">
            <div id="app-toast-icon" class="w-9 h-9 rounded-xl flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined">check_circle</span>
            </div>
            <div class="flex-1">
                <p id="app-toast-title" class="font-bold text-sm">Thông báo</p>
                <p id="app-toast-message" class="text-sm mt-0.5 text-slate-600">Nội dung thông báo</p>
            </div>
            <button id="app-toast-close" class="text-slate-400 hover:text-slate-600 transition-colors" type="button" aria-label="Đóng thông báo">
                <span class="material-symbols-outlined text-[18px]">close</span>
            </button>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (() => {
            const toastEl = document.getElementById('app-toast');
            const iconEl = document.getElementById('app-toast-icon');
            const titleEl = document.getElementById('app-toast-title');
            const messageEl = document.getElementById('app-toast-message');
            const closeEl = document.getElementById('app-toast-close');
            let hideToastTimer;

            function getToastTheme(type) {
                if (type === 'error') {
                    return {
                        root: 'border-rose-200',
                        iconWrap: 'bg-rose-100 text-rose-600',
                        title: 'Thất bại',
                        icon: 'error'
                    };
                }

                return {
                    root: 'border-emerald-200',
                    iconWrap: 'bg-emerald-100 text-emerald-600',
                    title: 'Thành công',
                    icon: 'check_circle'
                };
            }

            function hideToast() {
                if (!toastEl) {
                    return;
                }

                toastEl.classList.add('hidden');
            }

            function showToast(message, type = 'success') {
                if (!toastEl || !iconEl || !titleEl || !messageEl) {
                    return;
                }

                const theme = getToastTheme(type);

                toastEl.classList.remove('border-emerald-200', 'border-rose-200');
                toastEl.classList.add(theme.root);

                iconEl.classList.remove('bg-emerald-100', 'text-emerald-600', 'bg-rose-100', 'text-rose-600');
                iconEl.classList.add(...theme.iconWrap.split(' '));

                const iconSpan = iconEl.querySelector('.material-symbols-outlined');
                if (iconSpan) {
                    iconSpan.textContent = theme.icon;
                }

                titleEl.textContent = theme.title;
                messageEl.textContent = message;

                toastEl.classList.remove('hidden');

                clearTimeout(hideToastTimer);
                hideToastTimer = setTimeout(hideToast, 3200);
            }

            if (closeEl) {
                closeEl.addEventListener('click', hideToast);
            }

            window.appToast = {
                show: showToast,
                storeAndReload: (message, type = 'success') => {
                    sessionStorage.setItem('app.toast', JSON.stringify({ message, type }));
                    location.reload();
                }
            };

            const serverToastMessage = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(serverToastMessage));
            const serverToastType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(serverToastType));

            if (serverToastMessage) {
                showToast(serverToastMessage, serverToastType || 'success');
            }

            const pendingToastRaw = sessionStorage.getItem('app.toast');
            if (pendingToastRaw) {
                sessionStorage.removeItem('app.toast');
                try {
                    const pendingToast = JSON.parse(pendingToastRaw);
                    if (pendingToast?.message) {
                        showToast(pendingToast.message, pendingToast.type || 'success');
                    }
                } catch {
                    // Ignore malformed session data.
                }
            }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>