@{
    var currentUrl = Context.Request.Path.Value ?? "/";
    if (currentUrl.Equals("/Teacher", StringComparison.OrdinalIgnoreCase) || currentUrl.Equals("/Teacher/",
StringComparison.OrdinalIgnoreCase))
    {
        currentUrl = "/Teacher/Index";
    }
    else if (currentUrl.Equals("/Student", StringComparison.OrdinalIgnoreCase) || currentUrl.Equals("/Student/",
StringComparison.OrdinalIgnoreCase))
    {
        currentUrl = "/Student/Index";
    }

    var teacherMenu = new[] {
        new { Title = "Tổng quan", Url = "/Teacher/Index", Icon = "dashboard" },
        new { Title = "Quản lý lớp học", Url = "/Teacher/Classes", Icon = "groups" },
        new { Title = "Quản lý đề thi", Url = "/Teacher/Exams", Icon = "description" },
        new { Title = "Tổ chức ca thi", Url = "/Teacher/Sessions", Icon = "event_available" },
        new { Title = "Báo cáo thống kê", Url = "/Teacher/Reports", Icon = "analytics" }
    };

    var studentMenu = new[] {
        new { Title = "Trang chủ", Url = "/Student/Index", Icon = "dashboard" },
        new { Title = "Tham gia lớp", Url = "/Student/JoinClass", Icon = "group_add" },
        new { Title = "Ca thi của tôi", Url = "/Student/Exams", Icon = "event_note" },
        new { Title = "Kết quả", Url = "/Student/Results", Icon = "military_tech" }
    };
}



<aside
    class="peer fixed left-0 top-0 h-screen bg-brand-blue flex flex-col py-8 z-50 transition-[width] duration-300 ease-in-out w-24 hover:w-[260px] group overflow-hidden shadow-[4px_0_24px_rgba(0,0,0,0.15)]">

    <div class="mb-12 flex items-center h-12 w-full whitespace-nowrap">
        <div
            class="w-14 h-14 ml-5 shrink-0 rounded-2xl bg-white/20 flex items-center justify-center text-white shadow-inner">
            <span class="material-symbols-outlined text-3xl">school</span>
        </div>
        <span class="ml-6 text-white font-headline font-bold text-xl whitespace-nowrap">
            Thi Online
        </span>
    </div>

    <nav class="flex flex-col gap-4 w-full">
        @if (User.IsInRole("Teacher"))
        {
            @foreach (var item in teacherMenu)
            {
                bool isActive = currentUrl.StartsWith(item.Url, StringComparison.OrdinalIgnoreCase)
                    || (item.Url.Equals("/Teacher/Classes", StringComparison.OrdinalIgnoreCase)
                        && currentUrl.StartsWith("/Teacher/ManageClass", StringComparison.OrdinalIgnoreCase))
                    || (item.Url.Equals("/Teacher/Sessions", StringComparison.OrdinalIgnoreCase)
                        && currentUrl.StartsWith("/Teacher/MonitorSession", StringComparison.OrdinalIgnoreCase));
                string activeClass = isActive
                ? "bg-surface-bg text-brand-blue shadow-md"
                : "text-white/70 hover:text-white transition-colors hover:bg-white/5";

                <a href="@item.Url"
                       class="relative ml-3.5 mr-4 w-[calc(100%-2rem)] h-16 flex items-center rounded-2xl transition-all duration-300 overflow-hidden @activeClass"
                       title="@item.Title">
                    <div class="w-16 h-full flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined text-2xl"
                              style="@(isActive ? "font-variation-settings: 'FILL' 1;" : "")">@item.Icon</span>
                    </div>
                    <span class="ml-1 font-bold text-sm whitespace-nowrap pr-4">
                        @item.Title
                    </span>
                </a>
            }
        }
        else if (User.IsInRole("Student"))
        {
            @foreach (var item in studentMenu)
            {
                bool isActive = currentUrl.StartsWith(item.Url, StringComparison.OrdinalIgnoreCase);
                string activeClass = isActive
                ? "bg-surface-bg text-brand-blue shadow-lg"
                : "text-white/70 hover:text-white transition-colors hover:bg-white/5";

                <a href="@item.Url"
                       class="relative mx-4 w-[calc(100%-2rem)] h-16 flex items-center rounded-2xl transition-all duration-300 @activeClass"
                       title="@item.Title">
                    <div class="w-16 h-full flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined text-2xl"
                              style="@(isActive ? "font-variation-settings: 'FILL' 1;" : "")">@item.Icon</span>
                    </div>
                    <span
                        class="font-bold text-sm whitespace-nowrap opacity-0 group-hover:!opacity-100 transition-opacity duration-300 delay-75">
                        @item.Title
                    </span>
                </a>
            }
        }
    </nav>

    <div class="mt-auto pb-4 w-full">
        <a href="/Auth/Logout"
               class="relative ml-3.5 mr-4 w-[calc(100%-2rem)] h-16 flex items-center rounded-2xl text-white/70 hover:text-white hover:bg-white/10 transition-all duration-300 overflow-hidden">
            <div class="w-16 h-full flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-2xl">logout</span>
            </div>
            <span class="ml-1 font-bold text-sm whitespace-nowrap pr-4">
                Đăng xuất
            </span>
        </a>
    </div>
</aside>