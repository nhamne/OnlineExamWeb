@model ErrorViewModel
@{
    ViewData["Title"] = "Lỗi";
}

<h1 class="text-danger">Lỗi.</h1>
<h2 class="text-danger">Đã xảy ra lỗi trong quá trình xử lý yêu cầu của bạn.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>Mã yêu cầu:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>Chế độ Development</h3>
<p>
    Khi chuyển sang môi trường <strong>Development</strong>, hệ thống sẽ hiển thị thông tin chi tiết hơn về lỗi đã xảy ra.
</p>
<p>
    <strong>Không nên bật môi trường Development trên ứng dụng đang triển khai thực tế.</strong>
    Việc này có thể làm lộ thông tin nhạy cảm từ exception cho người dùng cuối.
    Để debug cục bộ, hãy bật môi trường <strong>Development</strong> bằng cách đặt biến môi trường <strong>ASPNETCORE_ENVIRONMENT</strong> thành <strong>Development</strong>
    và khởi động lại ứng dụng.
</p>
