@{
    ViewData["Title"] = "Đăng ký";
    // Ép trang này sử dụng Layout riêng dành cho Auth
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<!DOCTYPE html>
<html class="light" lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Đăng ký | Academic Atelier</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "secondary-fixed": "#89fa9b",
                        "tertiary-fixed-dim": "#fbbc05",
                        "on-tertiary-container": "#ffffff",
                        "tertiary-container": "#987000",
                        "surface-bright": "#f9f9ff",
                        "primary": "#005bbf",
                        "on-tertiary-fixed-variant": "#5c4300",
                        "on-primary-fixed-variant": "#004493",
                        "surface-container-highest": "#e0e2ec",
                        "on-primary-container": "#ffffff",
                        "primary-fixed": "#d8e2ff",
                        "on-surface-variant": "#414754",
                        "surface-container-lowest": "#ffffff",
                        "inverse-primary": "#adc7ff",
                        "primary-fixed-dim": "#adc7ff",
                        "outline-variant": "#c1c6d6",
                        "secondary-container": "#86f898",
                        "on-primary": "#ffffff",
                        "on-primary-fixed": "#001a41",
                        "outline": "#727785",
                        "error-container": "#ffdad6",
                        "inverse-on-surface": "#eff0fa",
                        "surface-tint": "#005bc0",
                        "primary-container": "#1a73e8",
                        "inverse-surface": "#2d3038",
                        "surface-container-high": "#e6e8f2",
                        "on-tertiary": "#ffffff",
                        "on-secondary": "#ffffff",
                        "on-error-container": "#93000a",
                        "on-tertiary-fixed": "#261a00",
                        "tertiary": "#795900",
                        "error": "#ba1a1a",
                        "surface-container-low": "#f2f3fd",
                        "surface": "#f9f9ff",
                        "on-secondary-fixed": "#002108",
                        "on-error": "#ffffff",
                        "surface-container": "#ecedf7",
                        "secondary": "#006e2c",
                        "tertiary-fixed": "#ffdfa0",
                        "background": "#f9f9ff",
                        "secondary-fixed-dim": "#6ddd81",
                        "on-background": "#191c23",
                        "surface-dim": "#d8d9e3",
                        "on-surface": "#191c23",
                        "on-secondary-fixed-variant": "#005320",
                        "on-secondary-container": "#d3f8d3", /* Adjusted slightly for the badge */
                        "surface-variant": "#e0e2ec"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "fontFamily": {
                        "headline": ["Manrope", "sans-serif"],
                        "body": ["Inter", "sans-serif"],
                        "label": ["Inter", "sans-serif"]
                    }
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="bg-surface font-body text-on-surface overflow-x-hidden min-h-screen">
    <div class="flex flex-col md:flex-row min-h-screen">

        <div class="hidden md:flex md:w-1/2 bg-surface-container-highest relative flex-col justify-center px-16 lg:px-24 overflow-hidden">
            <div class="absolute inset-0 z-0">
                <img alt="Modern minimalist study space" class="w-full h-full object-cover opacity-30 mix-blend-multiply" src="https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=1000&auto=format&fit=crop" />
                <div class="absolute inset-0 bg-gradient-to-t from-surface-container-highest via-transparent to-surface/20"></div>
            </div>

            <div class="relative z-10 space-y-8 max-w-lg">
                <div class="inline-flex items-center gap-2 px-5 py-2 bg-primary rounded-full text-white text-xs font-bold tracking-widest shadow-sm">
                    <span class="material-symbols-outlined text-sm">auto_awesome</span>
                    INTELLECTUAL SANCTUARY
                </div>

                <h1 class="font-headline font-extrabold text-5xl lg:text-[64px] tracking-tight leading-[1.1]">
                    <span class="text-primary">Khơi nguồn tri thức tại</span> <span class="text-on-surface">Academic Atelier.</span>
                </h1>

                <p class="text-on-surface-variant text-lg font-medium leading-relaxed max-w-md">
                    Trải nghiệm nền tảng học thuật tinh hoa, nơi giáo dục được nâng tầm thành nghệ thuật với giao diện trực quan và công cụ quản lý thông minh.
                </p>

                <div class="pt-10 flex gap-16">
                    <div class="space-y-1">
                        <div class="text-4xl font-headline font-bold text-primary">150+</div>
                        <div class="text-xs font-label text-on-surface-variant uppercase tracking-widest font-semibold">Học viện liên kết</div>
                    </div>
                    <div class="space-y-1">
                        <div class="text-4xl font-headline font-bold text-secondary">98%</div>
                        <div class="text-xs font-label text-on-surface-variant uppercase tracking-widest font-semibold">Sự hài lòng</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="w-full md:w-1/2 bg-surface-container-lowest flex flex-col justify-center relative p-8 md:p-16 lg:px-32">

            <div class="absolute top-8 right-8 hidden md:flex items-center gap-2 px-4 py-2 bg-[#dcfce7] rounded-full text-secondary font-bold text-xs uppercase tracking-widest shadow-sm">
                <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">verified</span>
                Bảo mật tiêu chuẩn giáo dục
            </div>

            <div class="md:hidden flex flex-col items-center gap-4 mb-10">
                <div class="inline-flex items-center gap-2 px-4 py-2 bg-[#dcfce7] rounded-full text-secondary font-bold text-[10px] uppercase tracking-widest">
                    <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">verified</span>
                    Bảo mật tiêu chuẩn
                </div>
            </div>

            <div class="w-full max-w-md mx-auto space-y-10">
                <div class="space-y-2">
                    <h2 class="font-headline font-bold text-[32px] text-on-surface">Bắt đầu hành trình</h2>
                    <p class="text-on-surface-variant text-[15px] font-medium">Tạo tài khoản học thuật của bạn ngay hôm nay.</p>
                </div>

                <form class="space-y-6">
                    <div class="space-y-3">
                        <label class="text-[11px] font-label text-on-surface-variant uppercase tracking-widest font-bold">Chọn vai trò của bạn</label>
                        <div class="grid grid-cols-2 gap-4">
                            <label class="cursor-pointer group">
                                <input checked class="peer hidden" name="role" type="radio" value="student" />
                                <div class="flex items-center justify-center gap-2 p-3.5 rounded-xl bg-surface border border-outline-variant/30 peer-checked:border-primary peer-checked:bg-surface-container-lowest peer-checked:shadow-[0_0_0_1px_rgba(0,91,191,1)] transition-all duration-200">
                                    <span class="material-symbols-outlined text-on-surface-variant peer-checked:text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">person</span>
                                    <span class="font-semibold text-on-surface text-[15px]">Học sinh</span>
                                </div>
                            </label>
                            <label class="cursor-pointer group">
                                <input class="peer hidden" name="role" type="radio" value="teacher" />
                                <div class="flex items-center justify-center gap-2 p-3.5 rounded-xl bg-surface-container-low border border-transparent hover:bg-surface-container-high transition-all duration-200">
                                    <span class="material-symbols-outlined text-on-surface-variant text-[20px]" style="font-variation-settings: 'FILL' 1;">school</span>
                                    <span class="font-semibold text-on-surface text-[15px]">Giáo viên</span>
                                </div>
                            </label>
                        </div>
                    </div>

                    <div class="space-y-2 group">
                        <label class="text-[11px] font-label text-on-surface-variant uppercase tracking-widest font-bold" for="fullname">Họ và tên</label>
                        <div class="relative">
                            <input class="w-full px-5 py-4 bg-surface-container-low border-none rounded-xl focus:ring-0 focus:bg-surface-container-lowest transition-all duration-200 placeholder:text-outline-variant text-[15px]" id="fullname" placeholder="Nguyễn Văn A" type="text" />
                            <div class="absolute bottom-0 left-0 w-full h-[2px] bg-primary scale-x-0 group-focus-within:scale-x-100 transition-transform origin-center duration-300 rounded-b-xl"></div>
                        </div>
                    </div>

                    <div class="space-y-2 group">
                        <label class="text-[11px] font-label text-on-surface-variant uppercase tracking-widest font-bold" for="email">Email học viện</label>
                        <div class="relative">
                            <input class="w-full px-5 py-4 bg-surface-container-low border-none rounded-xl focus:ring-0 focus:bg-surface-container-lowest transition-all duration-200 placeholder:text-outline-variant text-[15px]" id="email" placeholder="name@atelier.edu.vn" type="email" />
                            <div class="absolute bottom-0 left-0 w-full h-[2px] bg-primary scale-x-0 group-focus-within:scale-x-100 transition-transform origin-center duration-300 rounded-b-xl"></div>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div class="space-y-2 group">
                            <label class="text-[11px] font-label text-on-surface-variant uppercase tracking-widest font-bold" for="password">Mật khẩu</label>
                            <div class="relative">
                                <input class="w-full px-5 py-4 bg-surface-container-low border-none rounded-xl focus:ring-0 focus:bg-surface-container-lowest transition-all duration-200 text-[15px] tracking-widest placeholder:tracking-normal placeholder:text-outline-variant" id="password" placeholder="••••••••" type="password" />
                                <div class="absolute bottom-0 left-0 w-full h-[2px] bg-primary scale-x-0 group-focus-within:scale-x-100 transition-transform origin-center duration-300 rounded-b-xl"></div>
                            </div>
                        </div>
                        <div class="space-y-2 group">
                            <label class="text-[11px] font-label text-on-surface-variant uppercase tracking-widest font-bold" for="confirm-password">Xác nhận</label>
                            <div class="relative">
                                <input class="w-full px-5 py-4 bg-surface-container-low border-none rounded-xl focus:ring-0 focus:bg-surface-container-lowest transition-all duration-200 text-[15px] tracking-widest placeholder:tracking-normal placeholder:text-outline-variant" id="confirm-password" placeholder="••••••••" type="password" />
                                <div class="absolute bottom-0 left-0 w-full h-[2px] bg-primary scale-x-0 group-focus-within:scale-x-100 transition-transform origin-center duration-300 rounded-b-xl"></div>
                            </div>
                        </div>
                    </div>

                    <div class="flex items-start gap-3 pt-2">
                        <div class="flex items-center h-5 mt-0.5">
                            <input class="w-[18px] h-[18px] rounded-[4px] border border-outline-variant text-primary focus:ring-primary/20 bg-surface-container-lowest transition-all cursor-pointer" id="terms" type="checkbox" />
                        </div>
                        <label class="text-[13px] text-on-surface font-medium leading-[1.6]" for="terms">
                            Tôi đồng ý với các <a class="text-primary hover:underline" href="#">Điều khoản dịch vụ</a> và <a class="text-primary hover:underline" href="#">Chính sách bảo mật</a> của Academic Atelier.
                        </label>
                    </div>

                    <button class="w-full mt-4 py-4 bg-primary text-white font-headline text-[15px] font-bold rounded-xl shadow-[0_8px_20px_-6px_rgba(0,91,191,0.4)] hover:bg-primary-container active:scale-[0.98] transition-all duration-300 flex items-center justify-center gap-2" type="submit">
                        Tạo tài khoản
                        <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                    </button>
                </form>

                <div class="text-center pt-2">
                    <p class="text-on-surface-variant text-[15px] font-medium">
                        Đã có tài khoản?
                        <a class="text-primary font-bold hover:underline ml-1" href="#">Đăng nhập</a>
                    </p>
                </div>

                <div class="pt-8 flex justify-center gap-4">
                    <div class="w-10 h-1 bg-[#86efac] rounded-full"></div> <div class="w-10 h-1 bg-[#fbbf24] rounded-full"></div> <div class="w-10 h-1 bg-[#bfdbfe] rounded-full"></div>
                </div>

            </div>
        </div>
    </div>
</body>
</html>

   