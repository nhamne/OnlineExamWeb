@model AuthPageViewModel
@{
    ViewData["Title"] = Model.PageTitle;
    Layout = "~/Views/Shared/_AuthLayout.cshtml";

    var roleLabel = Model.IsTeacherRole ? "Giáo viên" : "Học sinh";
    var switchAction = Model.IsRegister ? "Register" : "Login";
}

<style>
    @@keyframes authEnter {
        from {
            opacity: 0;
            transform: translateY(18px) scale(0.985);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .auth-enter {
        animation: authEnter 420ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    .auth-transitioning {
        opacity: 0;
        transform: translateY(8px) scale(0.99);
        transition: opacity 180ms ease, transform 180ms ease;
    }

    @@media (prefers-reduced-motion: reduce) {
        .auth-enter,
        .auth-transitioning {
            animation: none;
            transition: none;
        }
    }
</style>

<div class="h-[100dvh] overflow-hidden bg-[radial-gradient(1200px_500px_at_20%_-20%,#dbeafe_0%,transparent_55%),radial-gradient(900px_500px_at_100%_120%,#dcfce7_0%,transparent_60%),#f8fafc]">
    <main id="authShell" class="auth-enter h-full grid grid-cols-1 lg:grid-cols-2">
        <section class="hidden lg:flex relative h-full overflow-hidden bg-slate-900 text-white">
            <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-slate-800 to-sky-900"></div>
            <div class="absolute inset-0 opacity-30" style="background-image: linear-gradient(to right, rgba(255,255,255,0.08) 1px, transparent 1px), linear-gradient(to bottom, rgba(255,255,255,0.08) 1px, transparent 1px); background-size: 42px 42px;"></div>

            <div class="relative z-10 h-full flex flex-col justify-between p-12 xl:p-16">
                <div>
                    @* <a asp-controller="Home" asp-action="Index" data-auth-transition="true" class="inline-flex items-center gap-3 rounded-full border border-white/20 bg-white/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-white/95 hover:bg-white/20 transition-colors">
                        <span class="material-symbols-outlined text-base">home</span>
                        Về trang chủ
                    </a> *@

                    <p class="mt-12 text-xs uppercase tracking-[0.22em] text-cyan-200 font-semibold">@Model.HeroTagline</p>
                    <h1 class="mt-4 text-5xl xl:text-6xl font-headline font-extrabold leading-tight">@Model.HeroTitle</h1>
                    <p class="mt-6 max-w-md text-slate-200 text-lg leading-relaxed">@Model.HeroDescription</p>
                </div>

                <div class="rounded-2xl border border-white/20 bg-white/10 p-5 backdrop-blur-sm max-w-md">
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-lime-300" style="font-variation-settings: 'FILL' 1;">verified_user</span>
                        <p class="text-sm font-medium text-slate-100">Đăng nhập an toàn cho @roleLabel với xác thực phiên bằng cookie.</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="h-full overflow-y-auto">
            <div class="min-h-full flex items-center justify-center px-6 py-8 sm:px-10 lg:px-14 xl:px-20">
                <div class="w-full max-w-md">
                    <div class="lg:hidden mb-8 flex items-center justify-between">
                        @* <a asp-controller="Home" asp-action="Index" data-auth-transition="true" class="inline-flex items-center gap-2 text-sm font-semibold text-slate-600 hover:text-slate-900">
                            <span class="material-symbols-outlined text-base">arrow_back</span>
                            Trang chủ
                        </a> *@
                        <span class="inline-flex items-center rounded-full bg-emerald-50 px-3 py-1 text-xs font-bold uppercase tracking-wider text-emerald-700">@roleLabel</span>
                    </div>

                    <div class="inline-flex w-full rounded-2xl bg-slate-100 p-1 mb-7">
                        <a asp-controller="Auth" asp-action="@switchAction" asp-route-role="student" data-auth-transition="true"
                           class="flex-1 rounded-xl px-4 py-2.5 text-center text-sm font-semibold transition @(Model.IsTeacherRole ? "text-slate-500 hover:text-slate-700" : "bg-white text-sky-700 shadow-sm")">
                            Học sinh
                        </a>
                        <a asp-controller="Auth" asp-action="@switchAction" asp-route-role="teacher" data-auth-transition="true"
                           class="flex-1 rounded-xl px-4 py-2.5 text-center text-sm font-semibold transition @(Model.IsTeacherRole ? "bg-white text-sky-700 shadow-sm" : "text-slate-500 hover:text-slate-700")">
                            Giáo viên
                        </a>
                    </div>

                    <h2 class="text-3xl font-headline font-bold text-slate-900">@Model.FormTitle</h2>
                    <p class="mt-2 text-sm text-slate-600">@Model.FormDescription</p>

                    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                    {
                        <div class="mt-5 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700">
                            @Model.ErrorMessage
                        </div>
                    }

                    <form id="authForm" asp-controller="Auth" asp-action="@(Model.IsRegister ? "Register" : "Login")" method="post" autocomplete="off" class="mt-7 space-y-4">
                        <input type="hidden" name="role" value="@Model.Role" />

                        @if (Model.IsRegister)
                        {
                            <div>
                                <label for="fullname" class="mb-2 block text-xs font-bold uppercase tracking-wider text-slate-500">Họ và tên</label>
                                <input id="fullname" name="fullname" type="text" required
                                       class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3.5 text-sm outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100"
                                       placeholder="Nguyễn Văn A" />
                            </div>
                        }

                        <div>
                            <label for="email" class="mb-2 block text-xs font-bold uppercase tracking-wider text-slate-500">Email</label>
                            <input id="email" name="email" type="email" required autocomplete="off"
                                   class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3.5 text-sm outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100"
                                   placeholder="name@edu.vn" />
                        </div>

                        <div>
                            <label for="password" class="mb-2 block text-xs font-bold uppercase tracking-wider text-slate-500">Mật khẩu</label>
                            <input id="password" name="password" type="password" required autocomplete="new-password"
                                   class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3.5 text-sm outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100"
                                   placeholder="••••••••" />
                        </div>

                        @if (Model.IsRegister)
                        {
                            <div>
                                <label for="confirmPassword" class="mb-2 block text-xs font-bold uppercase tracking-wider text-slate-500">Xác nhận mật khẩu</label>
                                    <input id="confirmPassword" name="confirmPassword" type="password" required autocomplete="new-password"
                                       class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3.5 text-sm outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100"
                                       placeholder="••••••••" />
                            </div>
                        }
                        else
                        {
                            <div class="flex items-center justify-between text-sm">
                                <label class="inline-flex items-center gap-2 text-slate-600 font-medium">
                                    <input type="checkbox" name="rememberMe" class="h-4 w-4 rounded border-slate-300 text-sky-600 focus:ring-sky-500" />
                                    Ghi nhớ đăng nhập
                                </label>
                                <a href="#" class="font-semibold text-sky-700 hover:underline">Quên mật khẩu?</a>
                            </div>
                        }

                        <button type="submit"
                                class="mt-3 inline-flex w-full items-center justify-center gap-2 rounded-xl bg-sky-700 px-5 py-3.5 text-sm font-bold text-white shadow-lg shadow-sky-700/20 transition hover:bg-sky-600 active:scale-[0.99]">
                            @Model.SubmitLabel
                            <span class="material-symbols-outlined text-base">arrow_forward</span>
                        </button>
                    </form>

                    <p class="mt-6 text-center text-sm font-medium text-slate-600">
                        @Model.AlternatePrompt
                        <a asp-controller="Auth" asp-action="@Model.AlternateAction" asp-route-role="@Model.Role" data-auth-transition="true" class="ml-1 font-bold text-sky-700 hover:underline">
                            @Model.AlternateActionLabel
                        </a>
                    </p>

                    <div class="mt-8 text-center text-xs uppercase tracking-widest text-slate-400">Nền tảng thi trực tuyến</div>
                </div>
            </div>
        </section>
    </main>
</div>

<script>
    (() => {
        const shell = document.getElementById('authShell');
        const links = document.querySelectorAll('[data-auth-transition="true"]');
        const authForm = document.getElementById('authForm');
        const emailInput = document.getElementById('email');
        const passwordInput = document.getElementById('password');
        const confirmPasswordInput = document.getElementById('confirmPassword');

        const params = new URLSearchParams(window.location.search);
        const shouldClear = params.get('cleared') === '1';

        if (shouldClear && authForm) {
            authForm.reset();

            if (emailInput) {
                emailInput.value = '';
            }

            if (passwordInput) {
                passwordInput.value = '';
            }

            if (confirmPasswordInput) {
                confirmPasswordInput.value = '';
            }

            const nextUrl = `${window.location.pathname}${window.location.hash}`;
            window.history.replaceState({}, document.title, nextUrl);
        }

        links.forEach((link) => {
            link.addEventListener('click', (event) => {
                const url = link.getAttribute('href');
                if (!url || url.startsWith('#')) {
                    return;
                }

                event.preventDefault();
                shell.classList.add('auth-transitioning');

                window.setTimeout(() => {
                    window.location.href = url;
                }, 180);
            });
        });
    })();
</script>
