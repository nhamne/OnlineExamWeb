        <form id="sessionFilterForm" method="get" asp-action="Sessions" asp-controller="Teacher"
              class="flex flex-col lg:flex-row gap-5 items-end mb-12 p-4 bg-white rounded-[16px] shadow-[0_4px_12px_rgba(25,28,35,0.02)]">
                        <input type="hidden" id="sessionPageInput" name="page" value="@Model.CurrentPage" />
            <div class="flex-1 w-full space-y-2 group">
                <label class="block text-[11px] font-bold text-[#414754] uppercase tracking-widest ml-1">Từ khóa</label>
                <div class="relative">
                    <span
                    class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#727785] pointer-events-none group-focus-within:text-[#005bbf] transition-colors">search</span>
                    <input id="sessionKeywordInput" type="text" name="searchKeyword" value="@Model.SearchKeyword"
                           class="w-full border-none rounded-[12px] pl-12 pr-14 py-3.5 text-[#191c23] text-[14px] focus:ring-0 focus:bg-[#ffffff] placeholder:text-[#c1c6d6] transition-all shadow-sm"
                           placeholder="VD: Giữa kỳ, 12A1...">
                    <button type="submit" title="Tìm kiếm"
                            class="absolute right-1.5 top-1/2 -translate-y-1/2 w-[40px] h-[40px] rounded-[13px] bg-[#005bbf] text-white inline-flex items-center justify-center hover:bg-[#1a73e8] transition-colors shadow-[0_4px_10px_rgba(0,91,191,0.22)]">
                        <span class="material-symbols-outlined text-[16px]">search</span>
                    </button>
                    <div
                        class="absolute bottom-0 left-0 w-full h-[2px] bg-[#005bbf] scale-x-0 group-focus-within:scale-x-100 transition-transform origin-center duration-300 rounded-b-[12px]">
                    </div>
                </div>
            </div>

            <div class="w-full lg:w-48 space-y-2 group">
                <label class="block text-[11px] font-bold text-[#414754] uppercase tracking-widest ml-1">Trạng thái</label>
                <div class="relative">
                        <select id="statusFilter" name="statusFilter"
                            class="w-full appearance-none border-none rounded-[12px] pl-4 pr-12 py-3.5 text-[#191c23] text-[14px] font-medium focus:ring-0 focus:bg-[#ffffff] transition-all cursor-pointer shadow-sm">
                        <option value="all" selected="@(Model.StatusFilter == "all")">Tất cả</option>
                        <option value="ongoing" selected="@(Model.StatusFilter == "ongoing")">Đang diễn ra</option>
                        <option value="upcoming" selected="@(Model.StatusFilter == "upcoming")">Sắp diễn ra</option>
                        <option value="finished" selected="@(Model.StatusFilter == "finished")">Đã kết thúc</option>
                    </select>
                    <span
                    class="material-symbols-outlined absolute right-[14px] top-1/2 -translate-y-1/2 text-[#727785] text-[21px] pointer-events-none">keyboard_arrow_down</span>
                    <div
                        class="absolute bottom-0 left-0 w-full h-[2px] bg-[#005bbf] scale-x-0 group-focus-within:scale-x-100 transition-transform origin-center duration-300 rounded-b-[12px]">
                    </div>
                </div>
            </div>

            <div class="w-full lg:w-48 space-y-2 group">
                <label class="block text-[11px] font-bold text-[#414754] uppercase tracking-widest ml-1">Sắp xếp</label>
                <div class="relative">
                        <select id="sortBy" name="sortBy"
                            class="w-full appearance-none border-none rounded-[12px] pl-4 pr-12 py-3.5 text-[#191c23] text-[14px] font-medium focus:ring-0 focus:bg-[#ffffff] transition-all cursor-pointer shadow-sm">
                        <option value="start_desc" selected="@(Model.SortBy == "start_desc")">Gần nhất</option>
                        <option value="start_asc" selected="@(Model.SortBy == "start_asc")">Xa nhất</option>
                        <option value="name_asc" selected="@(Model.SortBy == "name_asc")">Tên A-Z</option>
                        <option value="submissions_desc" selected="@(Model.SortBy == "submissions_desc")">Nhiều bài nộp nhất
                        </option>
                    </select>
                    <span
                    class="material-symbols-outlined absolute right-[14px] top-1/2 -translate-y-1/2 text-[#727785] text-[21px] pointer-events-none">keyboard_arrow_down</span>
                    <div
                        class="absolute bottom-0 left-0 w-full h-[2px] bg-[#005bbf] scale-x-0 group-focus-within:scale-x-100 transition-transform origin-center duration-300 rounded-b-[12px]">
                    </div>
                </div>
            </div>

            <button id="clearSessionFilters" type="button" title="Bỏ lọc"
                    class="h-[50px] w-[50px] rounded-[12px] bg-[#eef2fb] text-[#51607a] inline-flex items-center justify-center hover:bg-[#e2e9f7] transition-colors">
                <span class="material-symbols-outlined text-[22px]">filter_alt_off</span>
            </button>
            </form>

        

            <div class="space-y-3">
                <div class="hidden lg:grid grid-cols-12 gap-4 px-6 py-2">
                    <div class="col-span-4 text-[11px] font-bold text-[#414754] uppercase tracking-widest">Tên ca thi / Đề thi
                    </div>
                    <div class="col-span-3 text-[11px] font-bold text-[#414754] uppercase tracking-widest">Lớp học</div>
                    <div class="col-span-2 text-[11px] font-bold text-[#414754] uppercase tracking-widest">Trạng thái</div>
                    <div class="col-span-3 text-[11px] font-bold text-[#414754] uppercase tracking-widest text-right">Thao tác
                    </div>
                </div>

                @if (!Model.Sessions.Any())
                {
                    <div class="bg-white border border-slate-200 rounded-[16px] p-8 text-center text-slate-500 font-semibold">Không
                        có ca thi phù hợp.</div>
                    }
            else
                    {
                        @foreach (var session in Model.Sessions)
                        {
                            var statusClass = session.Status == "Đang diễn ra"
                                ? "session-status-ongoing"
                                : session.Status == "Sắp diễn ra"
                                    ? "session-status-upcoming"
                                    : "session-status-finished";

                            var rowClass = session.Status == "Đã kết thúc" ? "session-card-finished" : string.Empty;

                            <article
                                class="session-card @rowClass bg-[#ffffff] rounded-[16px] p-5 shadow-[0px_4px_12px_rgba(25,28,35,0.02)] hover:-translate-y-0.5 hover:shadow-[0px_12px_32px_rgba(25,28,35,0.06)] transition-all duration-300 flex flex-col lg:grid lg:grid-cols-12 gap-4 lg:items-center group"
                                data-session-id="@session.Id"
                                data-monitor-url="@Url.Action("MonitorSession", "Teacher", new { sessionId = session.Id })">
                                <div class="col-span-4 flex flex-col gap-1 min-w-0">
                                    <div class="flex items-center gap-2">
                                        <span class="material-symbols-outlined text-[20px] text-[#1d4ed8]"
                                              style="font-variation-settings: 'FILL' 1;">calendar_month</span>
                                        <span class="font-bold text-[#191c23] text-[15px] truncate">@session.SessionName</span>
                                
                                    </div>
                            
                                </div>

                                <div class="col-span-3 text-[14px] font-medium text-[#191c23]">@session.ClassName</div>

                                <div class="col-span-2 text-[13px] font-medium text-[#414754]">
                                    <span class="text-xs font-semibold px-2.5 py-1 rounded-full @statusClass">@session.Status</span>
                                </div>

                                <div class="col-span-3 session-actions flex justify-start lg:justify-end gap-2">
                                    <a href="@Url.Action("MonitorSession", "Teacher", new { sessionId = session.Id })" class="session-report-btn whitespace-nowrap" title="Theo dõi ca thi">
                                        <span class="material-symbols-outlined text-[18px]">monitoring</span>
                                        Theo dõi
                                    </a>

                                    @if (session.Status == "Sắp diễn ra")
                                    {
                                        <button type="button" class="session-action-btn session-action-btn-view btn-view-session-detail" title="Xem chi tiết">
                                            <span class="material-symbols-outlined text-[18px]">visibility</span>
                                        </button>
                                        <button type="button" class="session-action-btn session-action-btn-edit btn-edit-session" title="Chỉnh sửa">
                                            <span class="material-symbols-outlined text-[18px]">edit</span>
                                        </button>
                                        <button type="button" class="session-action-btn session-action-btn-delete btn-delete-session" title="Xóa">
                                            <span class="material-symbols-outlined text-[18px]">delete</span>
                                        </button>
                                    }
                                    else if (session.Status == "Đang diễn ra")
                                    {
                                        <button type="button" class="session-action-btn session-action-btn-view btn-view-session-detail" title="Xem chi tiết">
                                            <span class="material-symbols-outlined text-[18px]">visibility</span>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" class="session-action-btn session-action-btn-view btn-view-session-detail" title="Xem chi tiết">
                                            <span class="material-symbols-outlined text-[18px]">visibility</span>
                                        </button>
                                        <button type="button" class="session-report-btn whitespace-nowrap" title="Xem báo cáo">
                                            <span class="material-symbols-outlined text-[18px]">analytics</span>
                                            Xem báo cáo
                                        </button>
                                    }
                                </div>
                            </article>
                        }
                    }

                </div>

                @if (Model.TotalPages > 1)
                {
                    var visiblePages = new SortedSet<int> { 1, Model.TotalPages };
                    for (var p = Model.CurrentPage - 1; p <= Model.CurrentPage + 1; p++)
                    {
                        if (p >= 1 && p <= Model.TotalPages)
                        {
                            visiblePages.Add(p);
                        }
                    }

                    if (Model.CurrentPage <= 3)
                    {
                        visiblePages.Add(2);
                        visiblePages.Add(3);
                    }

                    if (Model.CurrentPage >= Model.TotalPages - 2)
                    {
                        visiblePages.Add(Model.TotalPages - 1);
                        visiblePages.Add(Model.TotalPages - 2);
                    }

                    visiblePages.RemoveWhere(pageNumber => pageNumber < 1 || pageNumber > Model.TotalPages);
                    var orderedPages = visiblePages.ToList();

                    <div class="mt-5 flex flex-wrap items-center justify-end gap-2">
                        <a class="h-10 w-10 rounded-xl bg-slate-100 text-[#5ca0f0] flex items-center justify-center transition-colors @(Model.CurrentPage == 1 ? "pointer-events-none opacity-45" : "hover:bg-[#e8f1ff]")"
                           href="@Url.Action("Sessions", "Teacher", new { searchKeyword = Model.SearchKeyword, statusFilter = Model.StatusFilter, sortBy = Model.SortBy, page = Model.CurrentPage - 1 })"
                           aria-label="Trang trước">
                            <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                        </a>

                        @for (var i = 0; i < orderedPages.Count; i++)
                        {
                            var pageNumber = orderedPages[i];
                            if (i > 0 && pageNumber - orderedPages[i - 1] > 1)
                            {
                                <span class="h-10 min-w-10 px-2 rounded-xl bg-slate-100 text-[#5ca0f0] text-sm font-bold inline-flex items-center justify-center">...</span>
                            }

                            <a class="h-10 min-w-10 px-3 rounded-xl text-sm font-bold inline-flex items-center justify-center transition-colors @(pageNumber == Model.CurrentPage ? "bg-[#5ca0f0] text-white" : "bg-slate-100 text-[#5ca0f0] hover:bg-[#e8f1ff]")"
                               href="@Url.Action("Sessions", "Teacher", new { searchKeyword = Model.SearchKeyword, statusFilter = Model.StatusFilter, sortBy = Model.SortBy, page = pageNumber })">@pageNumber</a>
                        }

                        <a class="h-10 w-10 rounded-xl bg-slate-100 text-[#5ca0f0] flex items-center justify-center transition-colors @(Model.CurrentPage == Model.TotalPages ? "pointer-events-none opacity-45" : "hover:bg-[#e8f1ff]")"
                           href="@Url.Action("Sessions", "Teacher", new { searchKeyword = Model.SearchKeyword, statusFilter = Model.StatusFilter, sortBy = Model.SortBy, page = Model.CurrentPage + 1 })"
                           aria-label="Trang sau">
                            <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                        </a>
                    </div>
                }
            </div>
        </main>

        <!-- Session Detail Panel -->
        <aside id="sessionDetailPanel" class="session-detail-panel">
            <div class="session-detail-header">
                <h3 id="detailSessionName">Chi tiết ca thi</h3>
                <button type="button" id="btnCloseDetailPanel" class="btn-close-detail-panel">
                    <span class="material-symbols-outlined text-[20px]">close</span>
                </button>
            </div>

            <div class="session-detail-body">
                <!-- Session Info -->
                <div class="session-detail-section">
                    <div class="session-detail-label">Đề thi</div>
                    <div class="session-detail-value" id="detailExamTitle">-</div>
                </div>

                <div class="session-detail-section">
                    <div class="session-detail-label">Lớp học</div>
                    <div class="session-detail-value" id="detailClassName">-</div>
                </div>

                <div class="session-detail-section">
                    <div class="session-detail-label">Mã khóa</div>
                    <div class="session-detail-value" id="detailPassword">-</div>
                </div>

                <div class="session-detail-section">
                    <div class="session-detail-label">Ngày thi</div>
                    <div class="session-detail-value date-time" id="detailDate">-</div>
                </div>

                <div class="session-detail-section">
                    <div class="session-detail-label">Thời gian thi</div>
                    <div class="session-detail-value date-time" id="detailTime">-</div>
                </div>

                <div class="session-detail-section">
                    <div class="session-detail-label">Trạng thái</div>
                    <div id="detailStatus">-</div>
                </div>

                <div class="session-detail-section">
                    <div class="session-detail-label">Công bố lời giải</div>
                    <div class="session-detail-value" id="detailAllowViewExplanation">-</div>
                </div>

                <div class="session-detail-section">
                    <div class="session-detail-label">Xáo trộn câu hỏi</div>
                    <div class="session-detail-value" id="detailShuffleQuestions">-</div>
                </div>

                <div class="session-detail-section">
                    <div class="session-detail-label">Xáo trộn đáp án</div>
                    <div class="session-detail-value" id="detailShuffleAnswers">-</div>
                </div>

                <div class="session-detail-section">
                    <div class="session-detail-label">Ghi chú</div>
                    <div class="session-detail-value" id="detailNotes" style="word-break: break-word; white-space: pre-wrap;">-</div>
