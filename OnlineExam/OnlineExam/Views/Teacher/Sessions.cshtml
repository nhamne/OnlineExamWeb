                                <div class="absolute bottom-0 left-0 w-full h-[2px] bg-[#005bbf] scale-x-0 group-focus-within:scale-x-100 transition-transform origin-center duration-300 rounded-b-[16px]"></div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <div class="px-8 py-3 bg-[#f9f9ff] border-t border-[#e6e8f2] flex flex-col sm:flex-row justify-between items-center gap-4 rounded-b-[24px]">
                <button type="button" id="btn-cancel-exam" class="w-full sm:w-auto px-6 py-2.5 text-[#005bbf] font-bold text-[14px] hover:bg-[#f2f3fd] rounded-[12px] transition-colors">
                    Hủy bỏ
