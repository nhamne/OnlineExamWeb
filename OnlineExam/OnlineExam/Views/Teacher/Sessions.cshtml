        function clearEditErrors() {
            document.querySelectorAll('#modal-edit-exam-overlay [data-error-for]').forEach((element) => {
                element.textContent = '';
                element.classList.add('hidden');
            });
        }

        function setEditError(fieldName, message) {
            const errorElement = document.querySelector(`#modal-edit-exam-overlay [data-error-for="${fieldName}"]`);
            if (!errorElement) {
                return;
            }

            errorElement.textContent = message;
            errorElement.classList.remove('hidden');
        }

        function clearEditError(fieldName) {
            const errorElement = document.querySelector(`#modal-edit-exam-overlay [data-error-for="${fieldName}"]`);
            if (!errorElement) {
                return;
            }

            errorElement.textContent = '';
            errorElement.classList.add('hidden');
        }

        function getSelectedEditExamDuration() {
            const selectedOption = editExamPaperIdSelect ? editExamPaperIdSelect.selectedOptions[0] : null;
            if (!selectedOption) {
                return 0;
            }

            const rawValue = selectedOption.getAttribute('data-duration');
            const duration = Number(rawValue);
            return Number.isFinite(duration) ? duration : 0;
        }

        function calculateEditSessionDuration() {
            const startTime = parseLocalDateTime(editStartTimeInput.value);
            const endTime = parseLocalDateTime(editEndTimeInput.value);

            if (!startTime || !endTime) {
                return 0;
            }

            return Math.ceil((endTime.getTime() - startTime.getTime()) / 60000);
        }

        function validateEditRequiredField(fieldName) {
            if (fieldName === 'sessionName') {
                if (!editSessionNameInput.value.trim()) {
                    setEditError('sessionName', 'Trường Tên ca thi là trường bắt buộc.');
                    return false;
                }

                clearEditError('sessionName');
                return true;
            }

            if (fieldName === 'examPaperId') {
                if (!editExamPaperIdSelect.value.trim()) {
                    setEditError('examPaperId', 'Trường Đề thi là trường bắt buộc.');
                    return false;
                }

                clearEditError('examPaperId');
                return true;
            }

            if (fieldName === 'classroomId') {
                if (!editClassroomIdSelect.value.trim()) {
                    setEditError('classroomId', 'Trường Lớp học tham gia là trường bắt buộc.');
                    return false;
                }

                clearEditError('classroomId');
                return true;
            }

            if (fieldName === 'startTime') {
                if (!editStartTimeInput.value.trim()) {
                    setEditError('startTime', 'Trường Giờ bắt đầu là trường bắt buộc.');
                    return false;
                }

                clearEditError('startTime');
                return true;
            }

            if (fieldName === 'endTime') {
                if (!editEndTimeInput.value.trim()) {
                    setEditError('endTime', 'Trường Giờ kết thúc là trường bắt buộc.');
                    return false;
                }

                clearEditError('endTime');
                return true;
            }

            return true;
        }

        function validateEditTimeFieldsImmediate() {
            const now = new Date();
            const startTime = parseLocalDateTime(editStartTimeInput.value);
            const endTime = parseLocalDateTime(editEndTimeInput.value);
            const examDuration = getSelectedEditExamDuration();

            if (editStartTimeInput.value.trim()) {
                if (!startTime) {
                    setEditError('startTime', 'Trường Giờ bắt đầu không đúng định dạng.');
                } else if (startTime < now) {
                    setEditError('startTime', 'Giờ bắt đầu không được là thời gian trong quá khứ.');
                } else {
                    clearEditError('startTime');
                }
            }

            if (editEndTimeInput.value.trim()) {
                if (!endTime) {
                    setEditError('endTime', 'Trường Giờ kết thúc không đúng định dạng.');
                } else {
                    clearEditError('endTime');
                }
            }

            if (startTime && endTime) {
                if (endTime <= startTime) {
                    setEditError('endTime', 'Giờ kết thúc phải lớn hơn giờ bắt đầu.');
                } else if (examDuration > 0 && calculateEditSessionDuration() < examDuration) {
                    setEditError('endTime', `Tổng thời gian ca thi phải lớn hơn hoặc bằng thời gian của đề thi (${examDuration} phút).`);
                } else if (editEndTimeInput.value.trim()) {
                    clearEditError('endTime');
                }
            }
        }

        function validateEditSequentialBefore(fieldName) {
            const order = ['sessionName', 'examPaperId', 'classroomId', 'startTime', 'endTime'];
            const index = order.indexOf(fieldName);
            if (index <= 0) {
                return;
            }

            for (let i = 0; i < index; i += 1) {
                validateEditRequiredField(order[i]);
            }

            validateEditTimeFieldsImmediate();
        }

        function validateEditSessionForm() {
            clearEditErrors();

            let firstInvalidField = null;
            let isValid = true;

            if (!validateEditRequiredField('sessionName')) {
                firstInvalidField = firstInvalidField || editSessionNameInput;
                isValid = false;
            }

            if (!validateEditRequiredField('examPaperId')) {
                firstInvalidField = firstInvalidField || editExamPaperIdSelect;
                isValid = false;
            }

            if (!validateEditRequiredField('classroomId')) {
                firstInvalidField = firstInvalidField || editClassroomIdSelect;
                isValid = false;
            }

            if (!validateEditRequiredField('startTime')) {
                firstInvalidField = firstInvalidField || editStartTimeInput;
                isValid = false;
            }

            if (!validateEditRequiredField('endTime')) {
                firstInvalidField = firstInvalidField || editEndTimeInput;
                isValid = false;
            }

            validateEditTimeFieldsImmediate();

            const startHasError = !document.querySelector('#modal-edit-exam-overlay [data-error-for="startTime"]')?.classList.contains('hidden');
            const endHasError = !document.querySelector('#modal-edit-exam-overlay [data-error-for="endTime"]')?.classList.contains('hidden');

            if (startHasError) {
                firstInvalidField = firstInvalidField || editStartTimeInput;
                isValid = false;
            }

            if (endHasError) {
                firstInvalidField = firstInvalidField || editEndTimeInput;
                isValid = false;
            }

            if (!isValid && firstInvalidField) {
                firstInvalidField.focus();
            }

            return isValid;
        }

        async function submitUpdateSession() {
            if (!validateEditSessionForm()) {
                return;
            }

            const tokenInput = editForm.querySelector('input[name="__RequestVerificationToken"]');
            const payload = new URLSearchParams();

            if (tokenInput) {
                payload.set('__RequestVerificationToken', tokenInput.value);
            }

            payload.set('sessionId', editSessionId.value);
            payload.set('sessionName', editSessionNameInput.value.trim());
            payload.set('classroomId', editClassroomIdSelect.value);
            payload.set('examPaperId', editExamPaperIdSelect.value);
            payload.set('startTime', editStartTimeInput.value);
            payload.set('endTime', editEndTimeInput.value);
            payload.set('sessionPassword', editSessionPasswordInput.value.trim());
            payload.set('allowViewExplanation', editAllowViewExplanation.checked ? 'true' : 'false');
            payload.set('shuffleQuestions', editShuffleQuestions.checked ? 'true' : 'false');
            payload.set('shuffleAnswers', editShuffleAnswers.checked ? 'true' : 'false');
            payload.set('notes', editNotesInput.value.trim());

            try {
                const response = await fetch('/Teacher/UpdateSession', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
                    },
                    body: payload.toString()
                });

                const result = await response.json().catch(() => null);

                if (!response.ok || !result || !result.success) {
                    throw new Error(result?.message || 'Cập nhật ca thi thất bại.');
                }

                closeEditModal();
                location.reload();
            } catch (error) {
                if (window.appToast) {
                    window.appToast.show(error.message || 'Cập nhật ca thi thất bại.', 'error');
                }
            }
        }

        // ========== Delete Session Logic ==========
        const deleteConfirmOverlay = document.getElementById('modal-delete-confirm-overlay');
        const deleteConfirmSessionName = document.getElementById('deleteConfirmSessionName');
        const btnDeleteCancel = document.getElementById('btn-delete-cancel');
        const btnDeleteConfirm = document.getElementById('btn-delete-confirm');

        let pendingDeleteSessionId = null;

        function openDeleteConfirm(sessionId, sessionName) {
            pendingDeleteSessionId = sessionId;
            if (deleteConfirmSessionName) {
                deleteConfirmSessionName.textContent = sessionName;
            }
            if (deleteConfirmOverlay) {
                deleteConfirmOverlay.classList.add('show');
            }
        }

        function closeDeleteConfirm() {
            if (deleteConfirmOverlay) {
                deleteConfirmOverlay.classList.remove('show');
            }
            pendingDeleteSessionId = null;
        }

        async function submitDeleteSession() {
            if (!pendingDeleteSessionId) {
                return;
            }

            const token = document.querySelector('form input[name="__RequestVerificationToken"]')?.value || '';
            const payload = new URLSearchParams();

            if (token) {
                payload.set('__RequestVerificationToken', token);
            }

            payload.set('sessionId', pendingDeleteSessionId);

            const actionButton = btnDeleteConfirm;
            const originalButtonHtml = actionButton ? actionButton.innerHTML : '';

            try {
                if (actionButton) {
                    actionButton.disabled = true;
                    actionButton.innerHTML = '<span class="material-symbols-outlined text-[16px] animate-spin">refresh</span> Đang xóa...';
                }

                const response = await fetch('/Teacher/DeleteSession', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
                    },
                    body: payload.toString()
                });

                const result = await response.json().catch(() => null);

                if (!response.ok || !result || !result.success) {
                    throw new Error(result?.message || 'Xóa ca thi thất bại.');
                }

                closeDeleteConfirm();
                location.reload();
            } catch (error) {
                if (window.appToast) {
                    window.appToast.show(error.message || 'Xóa ca thi thất bại.', 'error');
                }
            } finally {
                if (actionButton) {
                    actionButton.disabled = false;
                    actionButton.innerHTML = originalButtonHtml;
                }
            }
        }

        // Event listeners for edit/delete buttons
        document.querySelectorAll('.btn-edit-session').forEach((button) => {
            button.addEventListener('click', async (event) => {
                event.preventDefault();
                const sessionCard = button.closest('[data-session-id]');
                if (sessionCard) {
                    const sessionId = parseInt(sessionCard.getAttribute('data-session-id'), 10);
                    try {
                        const response = await fetch(`/Teacher/GetSessionDetail?sessionId=${sessionId}`);
                        if (response.ok) {
                            const result = await response.json();
                            if (result.success && result.data) {
                                openEditModal(result.data);
                            }
                        }
                    } catch (error) {
                        if (window.appToast) {
                            window.appToast.show('Không thể tải thông tin ca thi.', 'error');
                        }
                    }
                }
            });
        });

        document.querySelectorAll('.btn-delete-session').forEach((button) => {
            button.addEventListener('click', (event) => {
                event.preventDefault();
                const sessionCard = button.closest('[data-session-id]');
                if (sessionCard) {
                    const sessionId = parseInt(sessionCard.getAttribute('data-session-id'), 10);
                    const sessionName = sessionCard.querySelector('[class*="font-bold"][class*="text-\\[15px\\]"]')?.textContent.trim() || `#${sessionId}`;
                    openDeleteConfirm(sessionId, sessionName);
                }
            });
        });

        // Edit modal event listeners
        if (btnCloseEditModal) {
            btnCloseEditModal.addEventListener('click', closeEditModal);
        }

        if (btnCancelEditExam) {
            btnCancelEditExam.addEventListener('click', closeEditModal);
        }

        if (editSessionNameInput) {
            editSessionNameInput.addEventListener('blur', () => {
                validateEditRequiredField('sessionName');
            });
        }

        if (editExamPaperIdSelect) {
            editExamPaperIdSelect.addEventListener('focus', () => validateEditSequentialBefore('examPaperId'));
            editExamPaperIdSelect.addEventListener('change', () => {
                validateEditSequentialBefore('examPaperId');
                validateEditRequiredField('examPaperId');
                validateEditTimeFieldsImmediate();
            });
            editExamPaperIdSelect.addEventListener('blur', () => validateEditRequiredField('examPaperId'));
        }

        if (editClassroomIdSelect) {
            editClassroomIdSelect.addEventListener('focus', () => validateEditSequentialBefore('classroomId'));
            editClassroomIdSelect.addEventListener('change', () => {
                validateEditSequentialBefore('classroomId');
                validateEditRequiredField('classroomId');
            });
            editClassroomIdSelect.addEventListener('blur', () => validateEditRequiredField('classroomId'));
        }

        if (editStartTimeInput) {
            editStartTimeInput.addEventListener('focus', () => validateEditSequentialBefore('startTime'));
            editStartTimeInput.addEventListener('change', () => {
                validateEditSequentialBefore('startTime');
                validateEditRequiredField('startTime');
                validateEditTimeFieldsImmediate();
            });
            editStartTimeInput.addEventListener('blur', () => {
                validateEditRequiredField('startTime');
                validateEditTimeFieldsImmediate();
            });
        }

        if (editEndTimeInput) {
            editEndTimeInput.addEventListener('focus', () => validateEditSequentialBefore('endTime'));
            editEndTimeInput.addEventListener('change', () => {
                validateEditSequentialBefore('endTime');
                validateEditRequiredField('endTime');
                validateEditTimeFieldsImmediate();
            });
            editEndTimeInput.addEventListener('blur', () => {
                validateEditRequiredField('endTime');
                validateEditTimeFieldsImmediate();
            });
        }

        if (btnUpdateEditSession) {
            btnUpdateEditSession.addEventListener('click', async () => {
                if (validateEditSessionForm()) {
                    await submitUpdateSession();
                }
            });
        }

        if (editOverlay) {
            editOverlay.addEventListener('click', (event) => {
                if (event.target === editOverlay) {
                    closeEditModal();
                }
            });
        }

        // Delete confirmation event listeners
        if (btnDeleteCancel) {
            btnDeleteCancel.addEventListener('click', closeDeleteConfirm);
        }

        if (btnDeleteConfirm) {
            btnDeleteConfirm.addEventListener('click', submitDeleteSession);
        }

        if (deleteConfirmOverlay) {
            deleteConfirmOverlay.addEventListener('click', (event) => {
                if (event.target === deleteConfirmOverlay) {
                    closeDeleteConfirm();
                }
            });
        }
    </script>
}
