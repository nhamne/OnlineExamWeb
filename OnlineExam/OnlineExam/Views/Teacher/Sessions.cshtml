@section Scripts {
    <script>
        (function () {
            const form = document.getElementById("sessionFilterForm");
            const statusFilter = document.getElementById("statusFilter");
            const sortBy = document.getElementById("sortBy");
            const keywordInput = document.getElementById("sessionKeywordInput");
            const clearButton = document.getElementById("clearSessionFilters");
            const pageInput = document.getElementById("sessionPageInput");

            if (!form || !statusFilter || !sortBy || !keywordInput || !clearButton) {
                return;
            }

            statusFilter.addEventListener("change", function () {
                if (pageInput) {
                    pageInput.value = "1";
                }
                form.submit();
            });

            sortBy.addEventListener("change", function () {
                if (pageInput) {
                    pageInput.value = "1";
                }
                form.submit();
            });

            // Keep keyword search tied to search icon click only.
            keywordInput.addEventListener("keydown", function (event) {
                if (event.key === "Enter") {
                    event.preventDefault();
                }
            });

            clearButton.addEventListener("click", function () {
                keywordInput.value = "";
                statusFilter.value = "all";
                sortBy.value = "start_desc";
                if (pageInput) {
                    pageInput.value = "1";
                }
                form.submit();
            });

            form.addEventListener("submit", function () {
                if (pageInput) {
                    pageInput.value = "1";
                }
            });
        })();
        const btnOpen = document.getElementById('btn-open-exam-modal');
        const overlay = document.getElementById('modal-exam-overlay');
        const btnClose = document.getElementById('btn-close-exam-modal');
        const btnCancel = document.getElementById('btn-cancel-exam');
        const createForm = document.getElementById('create-session-form');
        const previewOverlay = document.getElementById('modal-session-preview-overlay');
        const btnPreview = document.getElementById('btn-preview-session');
        const btnConfirmCreate = document.getElementById('btn-confirm-create-session');
        const btnClosePreviewHeader = document.getElementById('btn-close-preview-modal');
        const btnClosePreviewFooter = document.getElementById('btn-close-preview-modal-footer');

        const successOverlay = document.getElementById('modal-create-success-overlay');
        const successSessionName = document.getElementById('successSessionName');
        const successJoinLink = document.getElementById('successJoinLink');
        const successQrImage = document.getElementById('successQrImage');
        const btnCopyJoinLink = document.getElementById('btn-copy-join-link');
        const btnDownloadQr = document.getElementById('btn-download-qr');
        const btnCloseSuccessModalIcon = document.getElementById('btn-close-success-modal-icon');

        const sessionNameInput = document.getElementById('sessionNameInput');
        const examPaperIdSelect = document.getElementById('examPaperIdSelect');
        const classroomIdSelect = document.getElementById('classroomIdSelect');
        const startTimeInput = document.getElementById('startTimeInput');
        const endTimeInput = document.getElementById('endTimeInput');
        const sessionPasswordInput = document.getElementById('sessionPasswordInput');
        const notesInput = document.getElementById('notesInput');
        const allowViewExplanationInput = createForm ? createForm.querySelector('input[name="allowViewExplanation"]') : null;
        const shuffleQuestionsInput = createForm ? createForm.querySelector('input[name="shuffleQuestions"]') : null;
        const shuffleAnswersInput = createForm ? createForm.querySelector('input[name="shuffleAnswers"]') : null;

        const previewSessionName = document.getElementById('previewSessionName');
        const previewQuestionList = document.getElementById('previewQuestionList');

        let cachedExamPreview = null;
        let latestSuccessLink = '';
        let latestSuccessQrLink = '';

        function openModal() {
            overlay.classList.remove('hidden');
            overlay.classList.add('flex');
            resetCreateSessionDraft();
            clearCreateErrors();
            if (sessionNameInput) {
                sessionNameInput.focus();
            }
        }

        function resetCreateSessionDraft() {
            clearCreateErrors();

            if (!createForm) {
                return;
            }

            createForm.reset();

            if (sessionNameInput) {
                sessionNameInput.value = '';
            }

            if (sessionPasswordInput) {
                sessionPasswordInput.value = '';
            }

            if (notesInput) {
                notesInput.value = '';
            }

            cachedExamPreview = null;

            if (previewQuestionList) {
                previewQuestionList.innerHTML = '';
            }

            closePreviewModal();
        }

        function closeModal() {
            overlay.classList.add('hidden');
            overlay.classList.remove('flex');
            resetCreateSessionDraft();
        }

        async function openPreviewModal() {
            if (!previewOverlay) {
                return;
            }

            previewSessionName.textContent = sessionNameInput.value.trim();

            const examPaperId = examPaperIdSelect.value;

            let examData = null;

            try {
                examData = await fetchExamPreview(examPaperId);
            } catch (error) {
                if (window.appToast) {
                    window.appToast.show(error.message || 'Không thể tải dữ liệu đề thi.', 'error');
                }
            }

            renderPreviewQuestions(examData);

            previewOverlay.classList.remove('hidden');
            previewOverlay.classList.add('flex');
        }

        function closePreviewModal() {
            if (!previewOverlay) {
                return;
            }

            previewOverlay.classList.add('hidden');
            previewOverlay.classList.remove('flex');
        }

        function buildSessionJoinLink(sessionId) {
            const encodedId = encodeURIComponent(sessionId);
            return `${window.location.origin}/Student/Index?sessionId=${encodedId}`;
        }

        function openSuccessModal(sessionName, sessionId) {
            if (!successOverlay) {
                location.reload();
                return;
            }

            latestSuccessLink = buildSessionJoinLink(sessionId);
            latestSuccessQrLink = `https://api.qrserver.com/v1/create-qr-code/?size=260x260&data=${encodeURIComponent(latestSuccessLink)}`;

            if (successSessionName) {
                successSessionName.textContent = sessionName || `#${sessionId}`;
            }

            if (successJoinLink) {
                successJoinLink.value = latestSuccessLink;
            }

            if (successQrImage) {
                successQrImage.src = latestSuccessQrLink;
            }

            successOverlay.classList.remove('hidden');
            successOverlay.classList.add('flex');
        }

        function closeSuccessModal() {
            if (!successOverlay) {
                return;
            }

            successOverlay.classList.add('hidden');
            successOverlay.classList.remove('flex');
            location.reload();
        }

        function clearCreateErrors() {
            document.querySelectorAll('[data-error-for]').forEach((element) => {
                element.textContent = '';
                element.classList.add('hidden');
            });
        }

        function setCreateError(fieldName, message) {
            const errorElement = document.querySelector(`[data-error-for="${fieldName}"]`);
            if (!errorElement) {
                return;
            }

            errorElement.textContent = message;
            errorElement.classList.remove('hidden');
        }

        function clearCreateError(fieldName) {
            const errorElement = document.querySelector(`[data-error-for="${fieldName}"]`);
            if (!errorElement) {
                return;
            }

            errorElement.textContent = '';
            errorElement.classList.add('hidden');
        }

        function parseLocalDateTime(value) {
            if (!value) {
                return null;
            }

            const parsed = new Date(value);
            return Number.isNaN(parsed.getTime()) ? null : parsed;
        }

        function toDateTimeLocalInputValue(value) {
            const date = value instanceof Date ? value : new Date(value);
            if (Number.isNaN(date.getTime())) {
                return '';
            }

            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            const hours = String(date.getHours()).padStart(2, '0');
            const minutes = String(date.getMinutes()).padStart(2, '0');

            return `${year}-${month}-${day}T${hours}:${minutes}`;
        }

        function getSelectedExamDuration() {
            const selectedOption = examPaperIdSelect ? examPaperIdSelect.selectedOptions[0] : null;
            if (!selectedOption) {
                return 0;
            }

            const rawValue = selectedOption.getAttribute('data-duration');
            const duration = Number(rawValue);
            return Number.isFinite(duration) ? duration : 0;
        }

        function calculateSessionDuration() {
            const startTime = parseLocalDateTime(startTimeInput.value);
            const endTime = parseLocalDateTime(endTimeInput.value);

            if (!startTime || !endTime) {
                return 0;
            }

            return Math.ceil((endTime.getTime() - startTime.getTime()) / 60000);
        }

        function shuffleArray(items) {
            const cloned = [...items];
            for (let i = cloned.length - 1; i > 0; i -= 1) {
                const j = Math.floor(Math.random() * (i + 1));
                [cloned[i], cloned[j]] = [cloned[j], cloned[i]];
            }

            return cloned;
        }

        function renderPreviewQuestions(examData) {
            if (!previewQuestionList) {
                return;
            }

            previewQuestionList.innerHTML = '';

            if (!examData || !Array.isArray(examData.questions) || examData.questions.length === 0) {
                previewQuestionList.innerHTML = '<div class="rounded-[14px] border border-[#e6e8f2] bg-[#f9f9ff] px-4 py-3 text-sm text-[#6b7280]">Đề thi chưa có câu hỏi để xem trước.</div>';
                return;
            }

            const useShuffleQuestions = !!(shuffleQuestionsInput && shuffleQuestionsInput.checked);
            const useShuffleAnswers = !!(shuffleAnswersInput && shuffleAnswersInput.checked);

            const questionSource = useShuffleQuestions ? shuffleArray(examData.questions) : [...examData.questions];
            const optionLetters = ['A', 'B', 'C', 'D'];

            questionSource.forEach((question, index) => {
                const questionCard = document.createElement('article');
                questionCard.className = 'rounded-[14px] border border-[#e6e8f2] bg-white p-4';

                const options = Array.isArray(question.options) ? [...question.options] : [];
                const displayOptions = useShuffleAnswers ? shuffleArray(options) : options;

                const mappedOptions = displayOptions.map((option, optionIndex) => ({
                    ...option,
                    displayLetter: optionLetters[optionIndex] || String.fromCharCode(65 + optionIndex)
                }));

                const correctOption = mappedOptions.find((option) => option.isCorrect);

                const optionsHtml = mappedOptions.map((option) => {
                    return `<li class="flex items-start gap-2 text-[14px] text-[#374151]"><span class="font-bold text-[#111827]">${option.displayLetter}.</span><span>${option.text || ''}</span></li>`;
                }).join('');

                const explanationHtml = question.explanation
                    ? `<p class="text-[13px] text-[#1f2937] mt-2"><span class="font-semibold">Lời giải:</span> ${question.explanation}</p>`
                    : '';

                questionCard.innerHTML = `
                    <div class="flex items-start justify-between gap-3">
                        <h5 class="text-[15px] font-semibold text-[#111827]">Câu ${index + 1}: ${question.content || ''}</h5>
                        <span class="whitespace-nowrap text-[11px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full bg-[#eef3ff] text-[#1e40af]">Mô phỏng</span>
                    </div>
                    <ul class="mt-3 space-y-2">${optionsHtml}</ul>
                    <p class="text-[13px] text-[#065f46] mt-3"><span class="font-semibold">Đáp án đúng:</span> ${correctOption ? `${correctOption.displayLetter}. ${correctOption.text || ''}` : 'Không xác định'}</p>
                    ${explanationHtml}
                `;

                previewQuestionList.appendChild(questionCard);
            });
        }

        async function fetchExamPreview(examPaperId) {
            if (!examPaperId) {
                return null;
            }

            if (cachedExamPreview && String(cachedExamPreview.id) === String(examPaperId)) {
                return cachedExamPreview;
            }

            const response = await fetch(`/Teacher/GetExamPreview?examPaperId=${encodeURIComponent(examPaperId)}`, {
                method: 'GET',
                headers: {
                    'Accept': 'application/json'
                }
            });

            const result = await response.json().catch(() => null);

            if (!response.ok || !result || !result.success || !result.exam) {
                throw new Error(result?.message || 'Không thể tải dữ liệu xem trước đề thi.');
            }

            cachedExamPreview = result.exam;
            return cachedExamPreview;
        }

        function validateRequiredField(fieldName) {
            if (fieldName === 'sessionName') {
                if (!sessionNameInput.value.trim()) {
                    setCreateError('sessionName', 'Trường Tên ca thi là trường bắt buộc.');
                    return false;
                }

                clearCreateError('sessionName');
                return true;
            }

            if (fieldName === 'examPaperId') {
                if (!examPaperIdSelect.value.trim()) {
                    setCreateError('examPaperId', 'Trường Đề thi là trường bắt buộc.');
                    return false;
                }

                clearCreateError('examPaperId');
                return true;
            }

            if (fieldName === 'classroomId') {
                if (!classroomIdSelect.value.trim()) {
                    setCreateError('classroomId', 'Trường Lớp học tham gia là trường bắt buộc.');
                    return false;
                }

                clearCreateError('classroomId');
                return true;
            }

            if (fieldName === 'startTime') {
                if (!startTimeInput.value.trim()) {
                    setCreateError('startTime', 'Trường Giờ bắt đầu là trường bắt buộc.');
                    return false;
                }

                clearCreateError('startTime');
                return true;
            }

            if (fieldName === 'endTime') {
                if (!endTimeInput.value.trim()) {
                    setCreateError('endTime', 'Trường Giờ kết thúc là trường bắt buộc.');
                    return false;
                }

                clearCreateError('endTime');
                return true;
            }

            return true;
        }

        function validateTimeFieldsImmediate() {
            const now = new Date();
            const startTime = parseLocalDateTime(startTimeInput.value);
            const endTime = parseLocalDateTime(endTimeInput.value);
            const examDuration = getSelectedExamDuration();

            if (startTimeInput.value.trim()) {
                if (!startTime) {
                    setCreateError('startTime', 'Trường Giờ bắt đầu không đúng định dạng.');
                } else if (startTime < now) {
                    setCreateError('startTime', 'Giờ bắt đầu không được là thời gian trong quá khứ.');
                } else {
                    clearCreateError('startTime');
                }
            }

            if (endTimeInput.value.trim()) {
                if (!endTime) {
                    setCreateError('endTime', 'Trường Giờ kết thúc không đúng định dạng.');
                } else {
                    clearCreateError('endTime');
                }
            }

            if (startTime && endTime) {
                if (endTime <= startTime) {
                    setCreateError('endTime', 'Giờ kết thúc phải lớn hơn giờ bắt đầu.');
                } else if (examDuration > 0 && calculateSessionDuration() < examDuration) {
                    setCreateError('endTime', `Tổng thời gian ca thi phải lớn hơn hoặc bằng thời gian của đề thi (${examDuration} phút).`);
                } else if (endTimeInput.value.trim()) {
                    clearCreateError('endTime');
                }
            }
        }

        function validateSequentialBefore(fieldName) {
            const order = ['sessionName', 'examPaperId', 'classroomId', 'startTime', 'endTime'];
            const index = order.indexOf(fieldName);
            if (index <= 0) {
                return;
            }

            for (let i = 0; i < index; i += 1) {
                validateRequiredField(order[i]);
            }

            validateTimeFieldsImmediate();
        }

        function validateCreateSessionForm() {
            clearCreateErrors();

            let firstInvalidField = null;
            let isValid = true;

            if (!validateRequiredField('sessionName')) {
                firstInvalidField = firstInvalidField || sessionNameInput;
                isValid = false;
            }

            if (!validateRequiredField('examPaperId')) {
                firstInvalidField = firstInvalidField || examPaperIdSelect;
                isValid = false;
            }

            if (!validateRequiredField('classroomId')) {
                firstInvalidField = firstInvalidField || classroomIdSelect;
                isValid = false;
            }

            if (!validateRequiredField('startTime')) {
                firstInvalidField = firstInvalidField || startTimeInput;
                isValid = false;
            }

            if (!validateRequiredField('endTime')) {
                firstInvalidField = firstInvalidField || endTimeInput;
                isValid = false;
            }

            validateTimeFieldsImmediate();

            const startHasError = !document.querySelector('[data-error-for="startTime"]')?.classList.contains('hidden');
            const endHasError = !document.querySelector('[data-error-for="endTime"]')?.classList.contains('hidden');

            if (startHasError) {
                firstInvalidField = firstInvalidField || startTimeInput;
                isValid = false;
            }

            if (endHasError) {
                firstInvalidField = firstInvalidField || endTimeInput;
                isValid = false;
            }

            if (!isValid && firstInvalidField) {
                firstInvalidField.focus();
            }

            return isValid;
        }

        if (sessionNameInput) {
            sessionNameInput.addEventListener('blur', () => {
                validateRequiredField('sessionName');
            });
        }

        if (examPaperIdSelect) {
            examPaperIdSelect.addEventListener('focus', () => validateSequentialBefore('examPaperId'));
            examPaperIdSelect.addEventListener('change', () => {
                cachedExamPreview = null;
                validateSequentialBefore('examPaperId');
                validateRequiredField('examPaperId');
                validateTimeFieldsImmediate();
            });
            examPaperIdSelect.addEventListener('blur', () => validateRequiredField('examPaperId'));
        }

        if (classroomIdSelect) {
            classroomIdSelect.addEventListener('focus', () => validateSequentialBefore('classroomId'));
            classroomIdSelect.addEventListener('change', () => {
                validateSequentialBefore('classroomId');
                validateRequiredField('classroomId');
            });
            classroomIdSelect.addEventListener('blur', () => validateRequiredField('classroomId'));
        }

        if (startTimeInput) {
            startTimeInput.addEventListener('focus', () => validateSequentialBefore('startTime'));
            startTimeInput.addEventListener('change', () => {
                validateSequentialBefore('startTime');
                validateRequiredField('startTime');
                validateTimeFieldsImmediate();
            });
            startTimeInput.addEventListener('blur', () => {
                validateRequiredField('startTime');
                validateTimeFieldsImmediate();
            });
        }

        if (endTimeInput) {
            endTimeInput.addEventListener('focus', () => validateSequentialBefore('endTime'));
            endTimeInput.addEventListener('change', () => {
                validateSequentialBefore('endTime');
                validateRequiredField('endTime');
                validateTimeFieldsImmediate();
            });
            endTimeInput.addEventListener('blur', () => {
                validateRequiredField('endTime');
                validateTimeFieldsImmediate();
            });
        }

        async function submitCreateSession() {
            if (!validateCreateSessionForm()) {
                return;
            }

            const tokenInput = createForm.querySelector('input[name="__RequestVerificationToken"]');
            const payload = new URLSearchParams();

            if (tokenInput) {
                payload.set('__RequestVerificationToken', tokenInput.value);
            }

            payload.set('sessionName', sessionNameInput.value.trim());
            payload.set('classroomId', classroomIdSelect.value);
            payload.set('examPaperId', examPaperIdSelect.value);
            payload.set('startTime', startTimeInput.value);
            payload.set('endTime', endTimeInput.value);
            payload.set('sessionPassword', sessionPasswordInput.value.trim());
            payload.set('allowViewExplanation', allowViewExplanationInput && allowViewExplanationInput.checked ? 'true' : 'false');
            payload.set('shuffleQuestions', shuffleQuestionsInput && shuffleQuestionsInput.checked ? 'true' : 'false');
            payload.set('shuffleAnswers', shuffleAnswersInput && shuffleAnswersInput.checked ? 'true' : 'false');
            payload.set('notes', notesInput.value.trim());

            const actionButton = btnConfirmCreate;
            const originalButtonHtml = actionButton ? actionButton.innerHTML : '';

            try {
                if (actionButton) {
                    actionButton.disabled = true;
                    actionButton.innerHTML = '<span class="material-symbols-outlined text-[18px] animate-spin">refresh</span> Đang tạo...';
                }

                const response = await fetch(createForm.getAttribute('action') || '/Teacher/CreateSession', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
                    },
                    body: payload.toString()
                });

                const result = await response.json().catch(() => null);

                if (!response.ok || !result || !result.success) {
                    throw new Error(result?.message || 'Tạo ca thi thất bại.');
                }

                const createdSessionName = sessionNameInput ? sessionNameInput.value.trim() : '';

                closeModal();
                closePreviewModal();

                openSuccessModal(createdSessionName, result.sessionId);
            } catch (error) {
                if (window.appToast) {
                    window.appToast.show(error.message || 'Tạo ca thi thất bại.', 'error');
                }
            } finally {
                if (actionButton) {
                    actionButton.disabled = false;
                    actionButton.innerHTML = originalButtonHtml;
                }
            }
        }

