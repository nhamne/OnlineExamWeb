                <div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto">
                    <button type="button" id="btn-preview-session" class="flex items-center justify-center gap-2 px-6 py-2.5 bg-transparent border border-[#005bbf]/20 text-[#005bbf] rounded-[12px] text-[14px] font-bold hover:bg-[#f2f3fd] transition-all active:scale-[0.98]">
                        <span class="material-symbols-outlined text-[18px]">visibility</span>
