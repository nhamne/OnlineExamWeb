        async function loadSessionDetail(sessionId) {
            try {
                const response = await fetch(`/Teacher/GetSessionDetail?sessionId=${sessionId}`, {
                    method: 'GET',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });

                if (!response.ok) {
                    throw new Error('Không thể tải chi tiết ca thi.');
                }

                const result = await response.json();
                if (!result.success || !result.data) {
                    throw new Error(result.message || 'Dữ liệu không hợp lệ.');
                }

                openDetailPanel(result.data);
            } catch (error) {
                if (window.appToast) {
                    window.appToast.show(error.message || 'Không thể tải chi tiết ca thi.', 'error');
