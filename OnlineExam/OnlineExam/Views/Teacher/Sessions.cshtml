@model OnlineExam.ViewModels.TeacherSessionListVM

@{
    ViewData["Title"] = "Tổ chức ca thi";
}

@section Styles {
    <style>
        .session-action-btn {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            border: 1px solid transparent;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease;
        }

        .session-action-btn-view {
            background: #f1f5ff;
            border-color: #dbe6ff;
            color: #6d28d9;
        }

        .session-action-btn-view:hover {
            background: #e6eeff;
        }

        .session-action-btn-edit {
            background: #eef6ff;
            border-color: #d6e7ff;
            color: #005bbf;
        }

        .session-action-btn-edit:hover {
            background: #deecff;
        }

        .session-action-btn-delete {
            background: #fff1f1;
            border-color: #ffd7d7;
            color: #ba1a1a;
        }

        .session-action-btn-delete:hover {
            background: #ffe4e4;
        }

        .session-report-btn {
            height: 36px;
            padding: 0 12px;
            border-radius: 10px;
            border: 1px solid #d8dfef;
            background: #f3f6fd;
            color: #374151;
            font-size: 13px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s ease;
        }

        .session-report-btn:hover {
            background: #e7edf8;
        }

        .session-status-ongoing {
            background: #86efac;
            color: #166534;
        }

        .session-status-upcoming {
            background: #bfdbfe;
            color: #1d4ed8;
        }

        .session-status-finished {
            background: #e5e7eb;
            color: #6b7280;
        }

        .session-card-finished {
            opacity: 0.72;
        }

        .session-card-finished:hover {
            opacity: 1;
        }
         .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        /* Tùy chỉnh thanh cuộn cho Modal Body */
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #c1c6d6; border-radius: 10px; }
        .custom-scrollbar:hover::-webkit-scrollbar-thumb { background: #727785; }
        
        /* Hiệu ứng hiển thị Modal */
        .modal-enter { animation: modalIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        @@keyframes modalIn {
            0% { opacity: 0; transform: scale(0.95) translateY(10px); }
            100% { opacity: 1; transform: scale(1) translateY(0); }
        }

        /* Giữ popup xem trước luôn nằm gọn trong khung nhìn, nội dung cuộn bên trong */
        .preview-modal-panel {
            max-height: calc(100dvh - 2rem);
        }

        .preview-modal-body {
            flex: 1 1 auto;
            min-height: 0;
            overflow-y: auto;
        }

        .success-modal-panel {
            height: calc(100dvh - 2rem);
            max-height: calc(100dvh - 2rem);
        }

        .success-modal-body {
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            height: 100%;
            overflow: hidden;
            min-height: 0;
        }

        @@supports not (height: 100dvh) {
            .success-modal-panel {
                height: calc(100vh - 2rem);
                max-height: calc(100vh - 2rem);
            }
        }

        @@supports not (height: 100dvh) {
            .preview-modal-panel {
                max-height: calc(100vh - 2rem);
            }
        }

        /* Session Detail Panel Styles */
        .sessions-container {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1rem;
            transition: grid-template-columns 0.3s ease;
        }

        .sessions-container.detail-open {
            grid-template-columns: minmax(350px, 1fr) 420px;
        }

        .sessions-list {
            min-width: 0;
        }

        .session-detail-panel {
            position: fixed;
            right: -500px;
            top: 0;
            width: 420px;
            height: 100vh;
            background: #ffffff;
            border-left: 1px solid #e6e8f2;
            box-shadow: -8px 0 24px rgba(25, 28, 35, 0.12);
            z-index: 40;
            transition: right 0.3s ease;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }

        .session-detail-panel.show {
            right: 0;
        }

        .session-detail-header {
            padding: 1.5rem;
            border-bottom: 1px solid #e6e8f2;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
            flex-shrink: 0;
        }

        .session-detail-header h3 {
            font-size: 18px;
            font-weight: bold;
            color: #191c23;
            margin: 0;
            word-break: break-word;
        }

        .btn-close-detail-panel {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            border: 1px solid #e6e8f2;
            background: #f9f9ff;
            color: #727785;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s ease;
            flex-shrink: 0;
        }

        .btn-close-detail-panel:hover {
            background: #f1f3f9;
            color: #414754;
        }

        .session-detail-body {
            flex: 1 1 50%;
            min-height: 0;
            overflow-y: auto;
            padding: 1.5rem;
            space-y: 1.25rem;
            custom-scrollbar;
        }

        .session-detail-section {
            margin-bottom: 1.5rem;
        }

        .session-detail-section:last-child {
            margin-bottom: 0;
        }

        .session-detail-label {
            font-size: 11px;
            font-weight: bold;
            color: #414754;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-bottom: 0.5rem;
        }

        .session-detail-value {
            font-size: 14px;
            color: #191c23;
            font-weight: 500;
        }

        .session-detail-value.date-time {
            font-size: 13px;
        }

        .session-detail-status {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 13px;
            font-weight: 600;
            padding: 0.4rem 0.75rem;
            border-radius: 6px;
            background: #f1f5ff;
            color: #414754;
        }

        .session-detail-status.ongoing {
            background: #dcfce7;
            color: #166534;
        }

        .session-detail-status.upcoming {
            background: #bfdbfe;
            color: #1d4ed8;
        }

        .session-detail-status.finished {
            background: #e5e7eb;
            color: #6b7280;
        }

        .session-share-section {
            flex: 0 1 50%;
            padding: 1.5rem;
            background: #f9f9ff;
            border-top: 1px solid #e6e8f2;
            min-height: 0;
            overflow-y: auto;
            flex-shrink: 0;
            custom-scrollbar;
        }

        .session-share-header {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 1rem;
            font-weight: 600;
            color: #005bbf;
            font-size: 14px;
        }

        .session-share-link-box {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 1rem;
        }

        .session-share-link-input {
            flex: 1;
            padding: 0.5rem 0.75rem;
            border: 1px solid #dbe6ff;
            border-radius: 8px;
            background: #ffffff;
            font-size: 12px;
            color: #191c23;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            font-family: 'Courier New', monospace;
        }

        .btn-copy-share-link {
            padding: 0.5rem 1rem;
            background: #10b981;
            color: #ffffff;
            border: none;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            white-space: nowrap;
        }

        .btn-copy-share-link:hover {
            background: #059669;
        }

        .session-share-qr {
            text-align: center;
        }

        .session-share-qr-label {
            font-size: 12px;
            font-weight: 600;
            color: #414754;
            margin-bottom: 0.75rem;
        }

        .session-share-qr-image {
            width: 100%;
            max-width: 200px;
            margin: 0 auto 1rem;
            padding: 0.75rem;
            background: #ffffff;
            border: 1px solid #e6e8f2;
            border-radius: 12px;
            display: block;
        }

        .btn-download-qr {
            width: 100%;
            padding: 0.75rem;
            background: #e879f9;
            color: #ffffff;
            border: none;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .btn-download-qr:hover {
            background: #d946ef;
        }

        .session-tips {
            padding: 0.75rem;
            background: #fef3c7;
            border-left: 3px solid #f59e0b;
            border-radius: 6px;
            font-size: 12px;
            color: #92400e;
            line-height: 1.5;
        }

        .session-tips strong {
            display: block;
            margin-bottom: 0.25rem;
            font-weight: 600;
        }

        .session-tips ul {
            margin: 0.5rem 0 0 1.5rem;
            padding: 0;
        }

        .session-tips li {
            margin-bottom: 0.25rem;
        }

        /* Delete Confirmation Modal */
        .delete-confirm-modal {
            position: fixed;
            inset: 0;
            background: rgba(25, 28, 35, 0.4);
            backdrop-filter: blur(4px);
            z-index: 150;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

        .delete-confirm-modal.show {
            display: flex;
        }

        .delete-confirm-panel {
            background: #ffffff;
            border-radius: 24px;
            box-shadow: 0 12px 32px rgba(25, 28, 35, 0.12);
            max-width: 420px;
            width: 100%;
            padding: 2rem;
            text-align: center;
            animation: modalIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        .delete-confirm-icon {
            width: 64px;
            height: 64px;
            margin: 0 auto 1.5rem;
            border-radius: 16px;
            background: #fee2e2;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #dc2626;
            font-size: 32px;
        }

        .delete-confirm-title {
            font-size: 20px;
            font-weight: bold;
            color: #191c23;
            margin: 0 0 0.5rem;
            font-family: 'Manrope', sans-serif;
        }

        .delete-confirm-message {
            font-size: 14px;
            color: #414754;
            margin-bottom: 2rem;
            line-height: 1.6;
        }

        .delete-confirm-actions {
            display: flex;
            gap: 1rem;
        }

        .delete-confirm-actions button {
            flex: 1;
            padding: 0.75rem 1rem;
            border: none;
            border-radius: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            font-size: 14px;
        }

        .btn-delete-cancel {
            background: #f2f3fd;
            color: #005bbf;
        }

        .btn-delete-cancel:hover {
            background: #e8ecf8;
        }

        .btn-delete-confirm {
            background: #dc2626;
            color: #ffffff;
        }

        .btn-delete-confirm:hover {
            background: #b91c1c;
        }

        .btn-delete-confirm:disabled {
            background: #9ca3af;
            cursor: not-allowed;
        }

        @@media (max-width: 1024px) {
            .sessions-container.detail-open {
                grid-template-columns: 1fr;
            }

            .session-detail-panel {
                width: 100%;
                max-width: 100%;
            }
        }
    </style>
}

<main class="flex-1 p-6 pt-0 pl-0 md:p-10 lg:p-12 bg-[#f9f9ff] font-['Inter',_sans-serif] text-[#191c23] min-h-screen">
    <div class="max-w-7xl mx-auto">
        <div class="w-full flex items-center justify-between mb-4">
            <div class="flex items-center mb-4 gap-4 px-2">
                <h1
                    class="text-[32px] font-['Manrope',_sans-serif] font-bold text-[#005bbf] leading-none tracking-tight">
                    Danh sách ca thi</h1>
                    <span
                    class="px-2.5 py-0.5 bg-[#e0e2ec] text-[#414754] rounded-full text-[13px] font-bold">@Model.TotalItems</span>
                </div>

        
                <button type="button"
                id="btn-open-exam-modal"
                        class="bg-gradient-to-r from-[#005bbf] to-[#1a73e8] text-[#ffffff] px-6 py-3.5 rounded-[12px] font-['Manrope',_sans-serif] font-bold text-[15px] flex items-center gap-2 shadow-[0_8px_20px_-6px_rgba(0,91,191,0.4)] hover:shadow-[0_12px_24px_-6px_rgba(0,91,191,0.5)] active:scale-[0.98] transition-all duration-300 whitespace-nowrap"
                        title="Tạo ca thi mới">
                    <span class="material-symbols-outlined text-[20px]"
                          style="font-variation-settings: 'FILL' 1;">add_circle</span>
                    Tạo ca thi mới
                </button>
            </div>
        </div>
  



<div id="modal-exam-overlay" class="fixed inset-0 bg-[#191c23]/40 backdrop-blur-sm z-[100] hidden items-center justify-center p-4">
    <div class="bg-[#ffffff] w-full max-w-[860px] max-h-[90vh] rounded-[24px] shadow-[0px_12px_32px_rgba(25,28,35,0.12)] overflow-hidden flex flex-col modal-enter font-['Inter',_sans-serif]">
        <form id="create-session-form" asp-action="CreateSession" asp-controller="Teacher" method="post" autocomplete="off" class="flex flex-col h-full overflow-hidden">
            @Html.AntiForgeryToken()

            @* Decoy fields to prevent browser credential autofill from targeting real session inputs. *@
            <input type="text" name="fake-username" autocomplete="username" tabindex="-1" class="hidden" aria-hidden="true" />
            <input type="password" name="fake-password" autocomplete="new-password" tabindex="-1" class="hidden" aria-hidden="true" />

            <div class="px-8 py-6 bg-[#ffffff]/80 backdrop-blur-md sticky top-0 z-20 flex justify-between items-center border-b border-[#e6e8f2]/50">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-[16px] bg-[#d8e2ff] flex items-center justify-center text-[#005bbf]">
                        <span class="material-symbols-outlined text-[24px]" style="font-variation-settings: 'FILL' 1;">calendar_add_on</span>
                    </div>
                    <div>
                        <h3 class="text-[20px] font-['Manrope',_sans-serif] font-bold text-[#191c23] leading-tight">Tạo ca thi mới</h3>
                        
                    </div>
                </div>
                <button type="button" id="btn-close-exam-modal" class="w-10 h-10 rounded-full hover:bg-[#f2f3fd] flex items-center justify-center text-[#727785] transition-colors">
                    <span class="material-symbols-outlined text-[24px]">close</span>
                </button>
            </div>

            <div class="flex-1 overflow-y-auto p-8 space-y-10 custom-scrollbar">
                <section class="space-y-5">
                    <div class="flex items-center gap-2 text-[#005bbf]">
                        <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">info</span>
                        <h4 class="font-['Manrope',_sans-serif] font-bold tracking-widest uppercase text-[12px]">Thông tin cơ bản</h4>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="md:col-span-2 space-y-1.5 group">
                            <label for="sessionNameInput" class="block text-[11px] font-bold text-[#414754] uppercase tracking-widest ml-1">Tên ca thi <span class="text-[#d32f2f]">*</span></label>
                            <div class="relative">
                                <input id="sessionNameInput" type="text" name="sessionName" autocomplete="off" class="w-full px-5 py-3.5 bg-[#f2f3fd] rounded-[12px] border-none focus:ring-0 focus:bg-[#ffffff] text-[#191c23] text-[15px] placeholder:text-[#c1c6d6] transition-all" placeholder="Ví dụ: Kiểm tra cuối kỳ - Môn Cấu trúc dữ liệu" />
                                <div class="absolute bottom-0 left-0 w-full h-[2px] bg-[#005bbf] scale-x-0 group-focus-within:scale-x-100 transition-transform origin-center duration-300 rounded-b-[12px]"></div>
                            </div>
                            <div class="text-[#d32f2f] text-[12px] min-h-[18px] hidden" data-error-for="sessionName"></div>
                        </div>

                        <div class="space-y-1.5 group">
                            <label for="examPaperIdSelect" class="block text-[11px] font-bold text-[#414754] uppercase tracking-widest ml-1">Đề thi <span class="text-[#d32f2f]">*</span></label>
                            <div class="relative">
                                <select id="examPaperIdSelect" name="examPaperId" class="w-full px-5 py-3.5 bg-[#f2f3fd] rounded-[12px] border-none appearance-none focus:ring-0 focus:bg-[#ffffff] text-[#191c23] text-[15px] font-medium transition-all cursor-pointer">
                                    <option value="">Chọn đề thi từ thư viện</option>
                                    @foreach (var examPaper in Model.ExamPapers)
                                    {
                                        <option value="@examPaper.Id" data-duration="@examPaper.DurationInMinutes">@examPaper.Name</option>
                                    }
                                </select>
                                <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-[#727785] pointer-events-none">keyboard_arrow_down</span>
                                <div class="absolute bottom-0 left-0 w-full h-[2px] bg-[#005bbf] scale-x-0 group-focus-within:scale-x-100 transition-transform origin-center duration-300 rounded-b-[12px]"></div>
                            </div>
                            <div class="text-[#d32f2f] text-[12px] min-h-[18px] hidden" data-error-for="examPaperId"></div>
                        </div>

                        <div class="space-y-1.5 group">
                            <label for="classroomIdSelect" class="block text-[11px] font-bold text-[#414754] uppercase tracking-widest ml-1">Lớp học tham gia <span class="text-[#d32f2f]">*</span></label>
                            <div class="relative">
                                <select id="classroomIdSelect" name="classroomId" class="w-full px-5 py-3.5 bg-[#f2f3fd] rounded-[12px] border-none appearance-none focus:ring-0 focus:bg-[#ffffff] text-[#191c23] text-[15px] font-medium transition-all cursor-pointer">
                                    <option value="">Chọn lớp học</option>
                                    @foreach (var classroom in Model.Classrooms)
                                    {
                                        <option value="@classroom.Id">@classroom.Name</option>
                                    }
                                </select>
                                <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-[#727785] pointer-events-none">keyboard_arrow_down</span>
                                <div class="absolute bottom-0 left-0 w-full h-[2px] bg-[#005bbf] scale-x-0 group-focus-within:scale-x-100 transition-transform origin-center duration-300 rounded-b-[12px]"></div>
                            </div>
                            <div class="text-[#d32f2f] text-[12px] min-h-[18px] hidden" data-error-for="classroomId"></div>
                        </div>
                    </div>
                </section>

                <section class="space-y-5">
                    <div class="flex items-center gap-2 text-[#005bbf]">
                        <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">schedule</span>
                        <h4 class="font-['Manrope',_sans-serif] font-bold tracking-widest uppercase text-[12px]">Thời gian</h4>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-1.5 group">
                            <label for="startTimeInput" class="block text-[11px] font-bold text-[#414754] uppercase tracking-widest ml-1">Giờ bắt đầu <span class="text-[#d32f2f]">*</span></label>
                            <div class="relative">
                                <input id="startTimeInput" type="datetime-local" name="startTime" class="w-full px-5 py-3.5 bg-[#f2f3fd] rounded-[12px] border-none focus:ring-0 focus:bg-[#ffffff] text-[#191c23] text-[14px] transition-all" />
                                <div class="absolute bottom-0 left-0 w-full h-[2px] bg-[#005bbf] scale-x-0 group-focus-within:scale-x-100 transition-transform origin-center duration-300 rounded-b-[12px]"></div>
                            </div>
                            <div class="text-[#d32f2f] text-[12px] min-h-[18px] hidden" data-error-for="startTime"></div>
                        </div>

                        <div class="space-y-1.5 group">
                            <label for="endTimeInput" class="block text-[11px] font-bold text-[#414754] uppercase tracking-widest ml-1">Giờ kết thúc <span class="text-[#d32f2f]">*</span></label>
                            <div class="relative">
                                <input id="endTimeInput" type="datetime-local" name="endTime" class="w-full px-5 py-3.5 bg-[#f2f3fd] rounded-[12px] border-none focus:ring-0 focus:bg-[#ffffff] text-[#191c23] text-[14px] transition-all" />
                                <div class="absolute bottom-0 left-0 w-full h-[2px] bg-[#005bbf] scale-x-0 group-focus-within:scale-x-100 transition-transform origin-center duration-300 rounded-b-[12px]"></div>
                            </div>
                            <div class="text-[#d32f2f] text-[12px] min-h-[18px] hidden" data-error-for="endTime"></div>
                        </div>
                    </div>
                </section>

                <section class="space-y-5">
                    <div class="flex items-center gap-2 text-[#005bbf]">
                        <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">lock</span>
                        <h4 class="font-['Manrope',_sans-serif] font-bold tracking-widest uppercase text-[12px]">Bảo mật & hiển thị</h4>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-1.5 group">
                            <label for="sessionPasswordInput" class="block text-[11px] font-bold text-[#414754] uppercase tracking-widest ml-1">Mật khẩu phòng (Tùy chọn)</label>
                            <div class="relative">
                                <input id="sessionPasswordInput" type="password" name="sessionPassword" autocomplete="new-password" class="w-full px-5 py-3.5 bg-[#f2f3fd] rounded-[12px] border-none focus:ring-0 focus:bg-[#ffffff] text-[#191c23] text-[15px] placeholder:text-[#c1c6d6] transition-all" placeholder="Nhập mã bảo mật" />
                                <div class="absolute bottom-0 left-0 w-full h-[2px] bg-[#005bbf] scale-x-0 group-focus-within:scale-x-100 transition-transform origin-center duration-300 rounded-b-[12px]"></div>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 gap-4 p-6 bg-[#f2f3fd] rounded-[16px]">
                            <label class="flex items-center gap-3 cursor-pointer group">
