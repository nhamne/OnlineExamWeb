@model OnlineExam.ViewModels.TeacherReportVM

@{
    ViewData["Title"] = "Báo cáo thống kê";
}

<div class="max-w-7xl mx-auto space-y-8">
    <div class="mb-8">
        <h1 class="text-[32px] font-['Manrope',_sans-serif] font-bold text-[#0369A1] leading-none tracking-tight">Báo cáo thống kê</h1>
        <p class="text-sm text-slate-500 mt-2">Tổng quan về tình hình học tập và kết quả bài thi của học sinh.</p>
    </div>

    <!-- Overview Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm flex items-center gap-4 hover:shadow-md transition-shadow">
            <div class="w-14 h-14 rounded-full bg-blue-50 text-[#0369A1] flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-3xl">groups</span>
            </div>
            <div>
                <p class="text-sm font-bold text-slate-500">Tổng học sinh</p>
                <p class="text-3xl font-bold text-slate-800">@Model.TotalStudents</p>
            </div>
        </div>

        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm flex items-center gap-4 hover:shadow-md transition-shadow">
            <div class="w-14 h-14 rounded-full bg-emerald-50 text-emerald-600 flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-3xl">task</span>
            </div>
            <div>
                <p class="text-sm font-bold text-slate-500">Tổng lượt nộp bài</p>
                <p class="text-3xl font-bold text-slate-800">@Model.TotalSubmissions</p>
            </div>
        </div>

        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm flex items-center gap-4 hover:shadow-md transition-shadow">
            <div class="w-14 h-14 rounded-full bg-amber-50 text-amber-500 flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-3xl">grade</span>
            </div>
            <div>
                <p class="text-sm font-bold text-slate-500">Điểm trung bình</p>
                <p class="text-3xl font-bold text-slate-800">@Model.AverageScore <span class="text-lg text-slate-400 font-medium">/ 10</span></p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Score Distribution -->
        <div class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm">
            <div class="flex items-center gap-2 mb-6">
                <span class="material-symbols-outlined text-[#0369A1]">bar_chart</span>
                <h2 class="text-lg font-bold text-slate-800">Phổ điểm</h2>
            </div>
            
            @{
                var totalScoreCount = Model.TotalSubmissions;
                var p0_4 = totalScoreCount > 0 ? (Model.Score0To4 * 100.0 / totalScoreCount) : 0;
                var p4_6 = totalScoreCount > 0 ? (Model.Score4To6 * 100.0 / totalScoreCount) : 0;
                var p6_8 = totalScoreCount > 0 ? (Model.Score6To8 * 100.0 / totalScoreCount) : 0;
                var p8_10 = totalScoreCount > 0 ? (Model.Score8To10 * 100.0 / totalScoreCount) : 0;
            }

            <div class="space-y-5">
                <!-- 8-10 -->
                <div>
                    <div class="flex justify-between text-sm font-bold mb-1">
                        <span class="text-slate-700">Giỏi (8 - 10đ)</span>
                        <span class="text-slate-500">@Model.Score8To10 lượt</span>
                    </div>
                    <div class="w-full bg-slate-100 rounded-full h-3 overflow-hidden">
                        <div class="bg-emerald-500 h-3 rounded-full" style="width: @p8_10%"></div>
                    </div>
                </div>

                <!-- 6-8 -->
                <div>
                    <div class="flex justify-between text-sm font-bold mb-1">
                        <span class="text-slate-700">Khá (6 - 8đ)</span>
                        <span class="text-slate-500">@Model.Score6To8 lượt</span>
                    </div>
                    <div class="w-full bg-slate-100 rounded-full h-3 overflow-hidden">
                        <div class="bg-[#0369A1] h-3 rounded-full" style="width: @p6_8%"></div>
                    </div>
                </div>

                <!-- 4-6 -->
                <div>
                    <div class="flex justify-between text-sm font-bold mb-1">
                        <span class="text-slate-700">Trung bình (4 - 6đ)</span>
                        <span class="text-slate-500">@Model.Score4To6 lượt</span>
                    </div>
                    <div class="w-full bg-slate-100 rounded-full h-3 overflow-hidden">
                        <div class="bg-amber-500 h-3 rounded-full" style="width: @p4_6%"></div>
                    </div>
                </div>

                <!-- 0-4 -->
                <div>
                    <div class="flex justify-between text-sm font-bold mb-1">
                        <span class="text-slate-700">Yếu kém (0 - 4đ)</span>
                        <span class="text-slate-500">@Model.Score0To4 lượt</span>
                    </div>
                    <div class="w-full bg-slate-100 rounded-full h-3 overflow-hidden">
                        <div class="bg-red-500 h-3 rounded-full" style="width: @p0_4%"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Performances -->
        <div class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm flex flex-col h-full">
            <div class="flex items-center gap-2 mb-6">
                <span class="material-symbols-outlined text-[#0369A1]">timeline</span>
                <h2 class="text-lg font-bold text-slate-800">Hiệu suất ca thi gần đây</h2>
            </div>

            <div class="overflow-x-auto flex-1">
                @if (Model.RecentPerformances.Count > 0)
                {
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="border-b border-slate-200">
                                <th class="py-3 px-2 text-sm font-bold text-slate-500">Ca thi</th>
                                <th class="py-3 px-2 text-sm font-bold text-slate-500 text-center">Lượt nộp</th>
                                <th class="py-3 px-2 text-sm font-bold text-slate-500 text-right">Điểm TB</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var perf in Model.RecentPerformances)
                            {
                                <tr class="border-b border-slate-100 last:border-0 hover:bg-slate-50 transition-colors">
                                    <td class="py-3 px-2">
                                        <p class="font-bold text-slate-700">@perf.SessionName</p>
                                        <p class="text-xs text-slate-500">@perf.ClassName</p>
                                    </td>
                                    <td class="py-3 px-2 text-center text-sm font-medium text-slate-600">@perf.TotalSubmissions</td>
                                    <td class="py-3 px-2 text-right">
                                        <span class="inline-flex items-center justify-center px-2 py-1 rounded-lg text-sm font-bold 
                                            @(perf.AverageScore >= 8 ? "bg-emerald-100 text-emerald-700" :
                                              perf.AverageScore >= 6 ? "bg-blue-100 text-blue-700" :
                                              perf.AverageScore >= 4 ? "bg-amber-100 text-amber-700" :
                                              "bg-red-100 text-red-700")">
                                            @perf.AverageScore
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="h-full flex flex-col items-center justify-center text-slate-400 mt-8">
                        <span class="material-symbols-outlined text-4xl mb-2 opacity-50">analytics</span>
                        <p class="text-sm font-medium">Chưa có dữ liệu thống kê</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
