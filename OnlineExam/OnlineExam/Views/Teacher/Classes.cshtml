@model OnlineExam.ViewModels.ClassroomListPageVM
@{
    ViewData["Title"] = "Quản lý lớp học";
}

@section Styles {
    <style>
        .modal-enter {
            animation: modalIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        .class-card .class-card-actions {
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.2s ease;
        }

        .class-card:hover .class-card-actions {
            opacity: 1;
            pointer-events: auto;
        }

        @@keyframes modalIn {
            0% {
                opacity: 0;
                transform: scale(0.95) translateY(10px);
            }

            100% {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }
    </style>
}

<div class="max-w-7xl mx-auto space-y-8">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h1 class="text-[32px] font-['Manrope',_sans-serif] font-bold text-[#0369A1] leading-none tracking-tight">Danh sách lớp học</h1>
            <p class="text-sm text-slate-500 mt-2">Tổng số lớp học: <span class="font-bold text-slate-700">@Model.TotalItems</span></p>
        </div>

        <button id="btn-open-create-modal" class="bg-[#0369A1] text-white flex items-center justify-center px-6 py-3 rounded-xl font-bold text-[15px] flex items-center gap-2 shadow-[0_8px_20px_-6px_rgba(3,105,161,0.4)] hover:shadow-[0_12px_24px_-6px_rgba(3,105,161,0.5)] active:scale-[0.98] transition-all duration-300">
            <span class="material-symbols-outlined text-[20px]">add</span>
            Tạo lớp học mới
        </button>
    </div>

    @if (Model.ShowMeiliSearchWarning)
    {
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                if (window.appToast) window.appToast.warning("Không kết nối được với Meilisearch. Hệ thống đã tự động chuyển sang tìm kiếm thường.");
            });
        </script>
    }

    <form id="class-filter-form" method="get" asp-action="Classes" asp-controller="Teacher" class="bg-white rounded-2xl p-4 md:p-5 border border-slate-100 shadow-sm grid grid-cols-1 md:grid-cols-12 gap-3 items-end">
        <div class="md:col-span-5">
            <label class="text-xs font-semibold text-slate-500 uppercase tracking-widest block mb-2">Tìm kiếm lớp học</label>
            <div class="relative">
                <span class="material-symbols-outlined text-slate-400 absolute left-3 top-1/2 -translate-y-1/2">search</span>
                <input id="search-keyword" name="searchKeyword" value="@Model.SearchKeyword" class="w-full h-11 rounded-xl border border-slate-200 pl-10 pr-14 focus:ring-2 focus:ring-[#0369A1]/20 focus:border-[#0369A1]" placeholder="Nhập tên lớp hoặc mã tham gia..." />
                <button type="submit" class="absolute right-1.5 top-1/2 -translate-y-1/2 h-8.5 w-8.5 rounded-lg bg-[#0369A1] text-white inline-flex items-center justify-center hover:bg-[#0369A1] transition-colors" title="Tìm kiếm" aria-label="Tìm kiếm">
                    <span class="material-symbols-outlined text-[18px] p-2">search</span>
                </button>
            </div>
        </div>

        <div class="md:col-span-3">
            <label class="text-xs font-semibold text-slate-500 uppercase tracking-widest block mb-2">Lọc theo sĩ số</label>
            <div class="relative">
                <select id="student-filter" name="studentFilter" class="w-full h-11 appearance-none rounded-xl border border-slate-200 pl-3 pr-11 focus:ring-2 focus:ring-[#0369A1]/20 focus:border-[#0369A1]">
                    @if (Model.StudentFilter == "all")
                    {
                        <option value="all" selected>Tất cả</option>
                    }
                    else
                    {
                        <option value="all">Tất cả</option>
                    }
                    @if (Model.StudentFilter == "empty")
                    {
                        <option value="empty" selected>Chưa có sinh viên</option>
                    }
                    else
                    {
                        <option value="empty">Chưa có sinh viên</option>
                    }
                    @if (Model.StudentFilter == "small")
                    {
                        <option value="small" selected>1-30 sinh viên</option>
                    }
                    else
                    {
                        <option value="small">1-30 sinh viên</option>
                    }
                    @if (Model.StudentFilter == "large")
                    {
                        <option value="large" selected>Trên 30 sinh viên</option>
                    }
                    else
                    {
                        <option value="large">Trên 30 sinh viên</option>
                    }
                </select>
                <span class="material-symbols-outlined absolute right-[12px] top-1/2 -translate-y-1/2 text-slate-500 text-[20px] pointer-events-none">keyboard_arrow_down</span>
            </div>
        </div>

        <div class="md:col-span-3">
            <label class="text-xs font-semibold text-slate-500 uppercase tracking-widest block mb-2">Sắp xếp</label>
            <div class="relative">
                <select id="sort-by" name="sortBy" class="w-full h-11 appearance-none rounded-xl border border-slate-200 pl-3 pr-11 focus:ring-2 focus:ring-[#0369A1]/20 focus:border-[#0369A1]">
                    @if (Model.SortBy == "created_desc")
                    {
                        <option value="created_desc" selected>Mới nhất</option>
                    }
                    else
                    {
                        <option value="created_desc">Mới nhất</option>
                    }
                    @if (Model.SortBy == "created_asc")
                    {
                        <option value="created_asc" selected>Cũ nhất</option>
                    }
                    else
                    {
                        <option value="created_asc">Cũ nhất</option>
                    }
                    @if (Model.SortBy == "name_asc")
                    {
                        <option value="name_asc" selected>Tên A-Z</option>
                    }
                    else
                    {
                        <option value="name_asc">Tên A-Z</option>
                    }
                    @if (Model.SortBy == "name_desc")
                    {
                        <option value="name_desc" selected>Tên Z-A</option>
                    }
                    else
                    {
                        <option value="name_desc">Tên Z-A</option>
                    }
                    @if (Model.SortBy == "students_desc")
                    {
                        <option value="students_desc" selected>Sĩ số giảm dần</option>
                    }
                    else
                    {
                        <option value="students_desc">Sĩ số giảm dần</option>
                    }
                    @if (Model.SortBy == "students_asc")
                    {
                        <option value="students_asc" selected>Sĩ số tăng dần</option>
                    }
                    else
                    {
                        <option value="students_asc">Sĩ số tăng dần</option>
                    }
                </select>
                <span class="material-symbols-outlined absolute right-[12px] top-1/2 -translate-y-1/2 text-slate-500 text-[20px] pointer-events-none">keyboard_arrow_down</span>
            </div>
        </div>

        <div class="md:col-span-1">
            <label class="text-xs font-semibold text-transparent uppercase tracking-widest block mb-2 select-none">Bỏ lọc</label>
            <a id="btn-clear-filters" href="@Url.Action("Classes", "Teacher")" class="h-11 w-full rounded-xl bg-slate-100 text-slate-600 font-semibold inline-flex items-center justify-center hover:bg-slate-200 transition-colors" title="Xóa toàn bộ tìm kiếm, lọc và sắp xếp" aria-label="Xóa toàn bộ bộ lọc">
                <span class="material-symbols-outlined text-[20px]">filter_alt_off</span>
            </a>
        </div>
    </form>

    @if (Model.Classes.Any())
    {
        var startIndex = ((Model.CurrentPage - 1) * Model.PageSize) + 1;
        var endIndex = Math.Min(Model.TotalItems, Model.CurrentPage * Model.PageSize);

        <div class="flex items-center justify-between gap-3">
            <p class="text-sm text-slate-500">Hiển thị <span class="font-bold text-slate-700">@startIndex-@endIndex</span> trên tổng <span class="font-bold text-slate-700">@Model.TotalItems</span> lớp học</p>
            <p class="text-sm text-slate-500">Trang <span class="font-bold text-slate-700">@Model.CurrentPage</span> / @Model.TotalPages</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var item in Model.Classes)
            {
                <div class="class-card relative bg-white rounded-2xl overflow-hidden shadow-[0px_12px_28px_rgba(25,28,35,0.06)] hover:-translate-y-1 transition-transform duration-300 flex flex-col">
                    <div class="class-card-actions absolute top-3 right-3 z-[2] flex items-center gap-2">
                        <button type="button" class="btn-open-edit-class h-9 w-9 rounded-lg bg-white/90 text-slate-600 border border-slate-200 hover:bg-[#0369A1] hover:text-white transition-colors" title="Chỉnh sửa lớp" data-class-id="@item.Id" data-class-name="@item.ClassName">
                            <span class="material-symbols-outlined text-[18px]">edit</span>
                        </button>
                        <button type="button" class="btn-open-delete-class h-9 w-9 rounded-lg bg-white/90 text-rose-600 border border-rose-200 hover:bg-rose-600 hover:text-white transition-colors" title="Xóa lớp" data-class-id="@item.Id" data-class-name="@item.ClassName">
                            <span class="material-symbols-outlined text-[18px]">delete</span>
                        </button>
                    </div>

                    <div class="h-36 bg-[#0369A1] flex items-center justify-center">
                        <span class="material-symbols-outlined text-white text-[72px]" style="font-variation-settings: 'FILL' 1;">school</span>
                    </div>

                    <div class="p-5 flex flex-col gap-4 h-full">
                        <div>
                            <h3 class="font-bold text-[18px] text-slate-800 leading-tight">@item.ClassName</h3>
                            <p class="text-sm text-slate-500 mt-1">Ngày tạo: @item.CreatedAt?.ToString("dd/MM/yyyy")</p>
                        </div>

                        <div class="bg-[#f2f3fd] p-3 rounded-xl flex items-center justify-between gap-3">
                            <div>
                                <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Mã tham gia</p>
                                <p class="font-mono text-[#0369A1] tracking-wider font-bold text-[14px]">@item.JoinCode</p>
                            </div>
                            <button type="button" class="btn-copy-join-code w-9 h-9 rounded-lg bg-white text-[#0369A1] hover:bg-[#0369A1] hover:text-white transition-colors" data-code="@item.JoinCode" title="Sao chép mã">
                                <span class="material-symbols-outlined text-[18px]">content_copy</span>
                            </button>
                        </div>

                        <div class="mt-auto flex items-center justify-between">
                            <div class="flex items-center gap-2 text-slate-700">
                                <span class="material-symbols-outlined text-[20px]">group</span>
                                <span class="text-sm font-semibold">@item.StudentCount sinh viên</span>
                            </div>
                            <a href="@Url.Action("ManageClass", "Teacher", new { id = item.Id })" class="text-[#0369A1] font-bold text-sm hover:underline inline-flex items-center gap-1">
                                Quản lý <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            var startPage = Math.Max(1, Model.CurrentPage - 2);
            var endPage = Math.Min(Model.TotalPages, startPage + 4);
            startPage = Math.Max(1, endPage - 4);

            <div class="flex flex-wrap items-center justify-end gap-2">
                <a class="h-10 w-10 rounded-xl bg-slate-100 text-[#0369A1] flex items-center justify-center transition-colors @(Model.CurrentPage == 1 ? "pointer-events-none opacity-45" : "hover:bg-[#e8f1ff]")" href="@Url.Action("Classes", "Teacher", new { searchKeyword = Model.SearchKeyword, studentFilter = Model.StudentFilter, sortBy = Model.SortBy, page = Model.CurrentPage - 1 })" aria-label="Trang trước">
                    <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                </a>

                @for (var pageNumber = startPage; pageNumber <= endPage; pageNumber++)
                {
                    <a class="h-10 min-w-10 px-3 rounded-xl text-sm font-bold inline-flex items-center justify-center transition-colors @(pageNumber == Model.CurrentPage ? "bg-[#0369A1] text-white" : "bg-slate-100 text-[#0369A1] hover:bg-[#e8f1ff]")" href="@Url.Action("Classes", "Teacher", new { searchKeyword = Model.SearchKeyword, studentFilter = Model.StudentFilter, sortBy = Model.SortBy, page = pageNumber })">@pageNumber</a>
                }

                <a class="h-10 w-10 rounded-xl bg-slate-100 text-[#0369A1] flex items-center justify-center transition-colors @(Model.CurrentPage == Model.TotalPages ? "pointer-events-none opacity-45" : "hover:bg-[#e8f1ff]")" href="@Url.Action("Classes", "Teacher", new { searchKeyword = Model.SearchKeyword, studentFilter = Model.StudentFilter, sortBy = Model.SortBy, page = Model.CurrentPage + 1 })" aria-label="Trang sau">
                    <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                </a>
            </div>
        }
    }
    else
    {
        <div class="bg-white border border-dashed border-slate-300 rounded-2xl p-12 text-center">
            <p class="text-slate-500 font-semibold">Không tìm thấy lớp học phù hợp với bộ lọc hiện tại.</p>
        </div>
    }
</div>

<div id="modal-overlay" class="fixed inset-0 bg-[#191c23]/40 backdrop-blur-sm z-[100] hidden items-center justify-center p-4">
    <div id="modal-create" class="bg-white w-full max-w-[500px] rounded-2xl shadow-[0px_12px_32px_rgba(25,28,35,0.12)] hidden flex-col modal-enter">
        <div class="px-8 pt-8 pb-4 border-b border-[#e6e8f2]/50">
            <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 rounded-xl bg-[#0369A1] flex items-center justify-center text-white shadow-[0_4px_12px_rgba(3,105,161,0.2)]">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">add_home</span>
                </div>
                <h2 class="text-[24px] font-['Manrope',_sans-serif] font-bold text-[#191c23]">Tạo lớp học mới</h2>
            </div>
            <p class="text-[#414754] text-[14px]">Nhập tên lớp học, hệ thống sẽ tự động sinh mã tham gia cho học sinh.</p>
        </div>

        <div class="px-8 py-6 space-y-2">
            <label for="input-className" class="text-[11px] font-bold text-[#414754] tracking-widest uppercase">Tên lớp học (bắt buộc)</label>
            <input type="text" id="input-className" autocomplete="off" placeholder="Ví dụ: Lập trình Web Nâng cao - D18CNPM1" class="w-full px-4 py-3 border border-[#c1c6d6] rounded-lg focus:border-[#0369A1] focus:ring-2 focus:ring-[#0369A1]/20 text-[#191c23]" />
            <div id="error-className" class="text-[#d32f2f] text-[12px] hidden"></div>
        </div>

        <div class="px-8 py-5 bg-[#f9f9ff] rounded-b-2xl flex justify-end items-center gap-3">
            <button type="button" id="btn-cancel-create" class="px-6 py-2.5 text-[#0369A1] font-bold text-[14px] hover:bg-[#f2f3fd] rounded-xl transition-colors">Hủy</button>
            <button type="button" id="btn-submit-create" class="px-6 py-2.5 bg-[#0369A1] text-white font-bold text-[14px] rounded-xl shadow-[0_4px_12px_rgba(3,105,161,0.2)] hover:bg-[#0369A1] active:scale-[0.98] transition-all flex items-center gap-2">
                <span class="material-symbols-outlined text-[18px]">add</span>
                Tạo lớp học
            </button>
        </div>
    </div>

    <div id="modal-success" class="bg-white w-full max-w-[420px] rounded-3xl p-10 shadow-[0px_12px_32px_rgba(25,28,35,0.12)] hidden flex-col items-center text-center relative modal-enter">
        <div class="w-16 h-16 rounded-2xl bg-[#006e2c] flex items-center justify-center text-white shadow-[0_8px_20px_rgba(0,110,44,0.3)] mb-6">
            <span class="material-symbols-outlined text-[32px]" style="font-variation-settings: 'FILL' 1;">check_circle</span>
        </div>
        <h2 class="text-[24px] font-['Manrope',_sans-serif] font-bold text-[#191c23] mb-2">Tạo lớp thành công</h2>
        <p class="text-[#414754] text-[15px] mb-6 leading-relaxed">Chia sẻ mã bên dưới để học sinh tham gia lớp.</p>
        <div class="w-full bg-[#f9f9ff] border border-dashed border-[#c1c6d6] rounded-2xl py-6 mb-8">
            <span class="text-[11px] font-bold text-[#414754] uppercase mb-2 block">Mã tham gia</span>
            <span id="success-joinCode" class="text-[32px] font-['Manrope',_sans-serif] font-bold tracking-widest text-[#0369A1]">LOADING</span>
        </div>
        <div class="w-full flex flex-col gap-2">
            <button type="button" id="btn-copy-code" class="w-full bg-[#0369A1] text-white font-bold text-[15px] py-3.5 rounded-xl flex items-center justify-center gap-2 shadow-[0_4px_12px_rgba(3,105,161,0.2)] hover:bg-[#0369A1] transition-colors">
                <span class="material-symbols-outlined text-[20px]">content_copy</span>
                Sao chép mã
            </button>
            <button id="btn-close-success" class="w-full text-[#191c23] font-bold text-[15px] py-3.5 rounded-xl hover:bg-[#f2f3fd] transition-colors">Xong</button>
        </div>
    </div>

    <div id="modal-edit" class="bg-white w-full max-w-[520px] rounded-2xl shadow-[0px_12px_32px_rgba(25,28,35,0.12)] hidden flex-col modal-enter">
        <div class="px-8 pt-8 pb-4 border-b border-[#e6e8f2]/50">
            <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 rounded-xl bg-[#f2f3fd] flex items-center justify-center text-[#0369A1]">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">edit</span>
                </div>
                <h2 class="text-[24px] font-['Manrope',_sans-serif] font-bold text-[#191c23]">Chỉnh sửa lớp học</h2>
            </div>
            <p class="text-[#414754] text-[14px]">Cập nhật tên lớp học. Mã tham gia sẽ được giữ nguyên.</p>
        </div>

        <div class="px-8 py-6 space-y-2">
            <label for="input-edit-className" class="text-[11px] font-bold text-[#414754] tracking-widest uppercase">Tên lớp học mới</label>
            <input type="text" id="input-edit-className" autocomplete="off" class="w-full px-4 py-3 border border-[#c1c6d6] rounded-lg focus:border-[#0369A1] focus:ring-2 focus:ring-[#0369A1]/20 text-[#191c23]" />
            <div id="error-edit-className" class="text-[#d32f2f] text-[12px] hidden"></div>
        </div>

        <div class="px-8 py-5 bg-[#f9f9ff] rounded-b-2xl flex justify-end items-center gap-3">
            <button type="button" id="btn-cancel-edit" class="px-6 py-2.5 text-[#0369A1] font-bold text-[14px] hover:bg-[#f2f3fd] rounded-xl transition-colors">Hủy</button>
            <button type="button" id="btn-submit-edit" class="px-6 py-2.5 bg-[#0369A1] text-white font-bold text-[14px] rounded-xl shadow-[0_4px_12px_rgba(3,105,161,0.2)] hover:bg-[#0369A1] active:scale-[0.98] transition-all flex items-center gap-2">
                <span class="material-symbols-outlined text-[18px]">save</span>
                Lưu thay đổi
            </button>
        </div>
    </div>

    <div id="modal-delete" class="bg-white w-full max-w-[460px] rounded-2xl shadow-[0px_12px_32px_rgba(25,28,35,0.12)] hidden flex-col modal-enter">
        <div class="px-8 pt-8 pb-4 border-b border-[#e6e8f2]/50">
            <div class="w-11 h-11 rounded-xl bg-rose-100 text-rose-600 flex items-center justify-center mb-3">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">warning</span>
            </div>
            <h2 class="text-[24px] font-['Manrope',_sans-serif] font-bold text-[#191c23]">Xóa lớp học</h2>
            <p id="delete-class-message" class="text-[#414754] text-[14px] mt-2">Bạn có chắc muốn xóa lớp học này không?</p>
        </div>

        <div class="px-8 py-5 bg-[#f9f9ff] rounded-b-2xl flex justify-end items-center gap-3">
            <button type="button" id="btn-cancel-delete" class="px-6 py-2.5 text-[#0369A1] font-bold text-[14px] hover:bg-[#f2f3fd] rounded-xl transition-colors">Hủy</button>
            <button type="button" id="btn-submit-delete" class="px-6 py-2.5 bg-rose-600 text-white font-bold text-[14px] rounded-xl shadow-[0_4px_12px_rgba(220,38,38,0.2)] hover:bg-rose-700 active:scale-[0.98] transition-all flex items-center gap-2">
                <span class="material-symbols-outlined text-[18px]">delete</span>
                Xóa lớp
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const btnOpenCreate = document.getElementById('btn-open-create-modal');
        const btnCancelCreate = document.getElementById('btn-cancel-create');
        const btnSubmitCreate = document.getElementById('btn-submit-create');
        const btnCloseSuccess = document.getElementById('btn-close-success');
        const btnCopyCode = document.getElementById('btn-copy-code');

        const overlay = document.getElementById('modal-overlay');
        const modalCreate = document.getElementById('modal-create');
        const modalSuccess = document.getElementById('modal-success');
        const modalEdit = document.getElementById('modal-edit');
        const modalDelete = document.getElementById('modal-delete');

        const inputClassName = document.getElementById('input-className');
        const errorClassName = document.getElementById('error-className');
        const successJoinCode = document.getElementById('success-joinCode');
        const inputEditClassName = document.getElementById('input-edit-className');
        const errorEditClassName = document.getElementById('error-edit-className');
        const deleteClassMessage = document.getElementById('delete-class-message');

        const btnCancelEdit = document.getElementById('btn-cancel-edit');
        const btnSubmitEdit = document.getElementById('btn-submit-edit');
        const btnCancelDelete = document.getElementById('btn-cancel-delete');
        const btnSubmitDelete = document.getElementById('btn-submit-delete');

        let selectedEditClassId = null;
        let selectedDeleteClassId = null;

        const classFilterForm = document.getElementById('class-filter-form');
        const searchKeywordInput = document.getElementById('search-keyword');
        const studentFilterSelect = document.getElementById('student-filter');
        const sortBySelect = document.getElementById('sort-by');
        let pendingCreateToastMessage = 'Tạo lớp học thành công!';

        function submitClassFilterForm() {
            if (!classFilterForm) {
                return;
            }

            classFilterForm.requestSubmit();
        }

        if (searchKeywordInput) {
            searchKeywordInput.addEventListener('keydown', (event) => {
                if (event.key === 'Enter') {
                    // Search is intentionally triggered by the search button only.
                    event.preventDefault();
                }
            });
        }

        if (studentFilterSelect) {
            studentFilterSelect.addEventListener('change', submitClassFilterForm);
        }

        if (sortBySelect) {
            sortBySelect.addEventListener('change', submitClassFilterForm);
        }

        function closeModal() {
            overlay.classList.add('hidden');
            overlay.classList.remove('flex');
            modalCreate.classList.add('hidden');
            modalCreate.classList.remove('flex');
            modalSuccess.classList.add('hidden');
            modalSuccess.classList.remove('flex');
            modalEdit.classList.add('hidden');
            modalEdit.classList.remove('flex');
            modalDelete.classList.add('hidden');
            modalDelete.classList.remove('flex');

            selectedEditClassId = null;
            selectedDeleteClassId = null;
        }

        btnOpenCreate.addEventListener('click', () => {
            inputClassName.value = '';
            errorClassName.classList.add('hidden');
            overlay.classList.remove('hidden');
            overlay.classList.add('flex');
            modalCreate.classList.remove('hidden');
            modalCreate.classList.add('flex');
            modalSuccess.classList.add('hidden');
            modalSuccess.classList.remove('flex');
            inputClassName.focus();
        });

        btnCancelCreate.addEventListener('click', closeModal);

        if (btnCancelEdit) {
            btnCancelEdit.addEventListener('click', closeModal);
        }

        if (btnCancelDelete) {
            btnCancelDelete.addEventListener('click', closeModal);
        }

        btnSubmitCreate.addEventListener('click', async () => {
            const className = inputClassName.value.trim();

            if (!className) {
                errorClassName.textContent = 'Vui lòng nhập tên lớp học.';
                errorClassName.classList.remove('hidden');
                inputClassName.focus();
                return;
            }

            errorClassName.classList.add('hidden');

            try {
                btnSubmitCreate.disabled = true;
                btnSubmitCreate.innerHTML = '<span class="material-symbols-outlined text-[18px] animate-spin">refresh</span> Đang tạo...';

                const response = await fetch('/Teacher/CreateClass', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: 'className=' + encodeURIComponent(className)
                });

                const result = await response.json();

                if (result.success) {
                    successJoinCode.textContent = result.joinCode;
                    pendingCreateToastMessage = result.message || 'Tạo lớp học thành công!';
                    modalCreate.classList.add('hidden');
                    modalCreate.classList.remove('flex');
                    modalSuccess.classList.remove('hidden');
                    modalSuccess.classList.add('flex');
                } else {
                    errorClassName.textContent = result.message || 'Tạo lớp học thất bại.';
                    errorClassName.classList.remove('hidden');
                    if (window.appToast) {
                        window.appToast.show(result.message || 'Tạo lớp học thất bại.', 'error');
                    }
                }
            } catch (error) {
                errorClassName.textContent = 'Không thể kết nối đến máy chủ.';
                errorClassName.classList.remove('hidden');
                if (window.appToast) {
                    window.appToast.show('Không thể kết nối đến máy chủ.', 'error');
                }
            } finally {
                btnSubmitCreate.disabled = false;
                btnSubmitCreate.innerHTML = '<span class="material-symbols-outlined text-[18px]">add</span> Tạo lớp học';
            }
        });

        document.querySelectorAll('.btn-open-edit-class').forEach((button) => {
            button.addEventListener('click', () => {
                const classId = Number(button.getAttribute('data-class-id'));
                const className = button.getAttribute('data-class-name') || '';

                if (!classId) {
                    return;
                }

                selectedEditClassId = classId;
                inputEditClassName.value = className;
                errorEditClassName.classList.add('hidden');

                overlay.classList.remove('hidden');
                overlay.classList.add('flex');
                modalEdit.classList.remove('hidden');
                modalEdit.classList.add('flex');
                modalCreate.classList.add('hidden');
                modalSuccess.classList.add('hidden');
                modalDelete.classList.add('hidden');

                inputEditClassName.focus();
                inputEditClassName.select();
            });
        });

        if (btnSubmitEdit) {
            btnSubmitEdit.addEventListener('click', async () => {
                const className = inputEditClassName.value.trim();

                if (!selectedEditClassId) {
                    errorEditClassName.textContent = 'Không xác định được lớp học cần chỉnh sửa.';
                    errorEditClassName.classList.remove('hidden');
                    return;
                }

                if (!className) {
                    errorEditClassName.textContent = 'Vui lòng nhập tên lớp học.';
                    errorEditClassName.classList.remove('hidden');
                    inputEditClassName.focus();
                    return;
                }

                errorEditClassName.classList.add('hidden');

                try {
                    btnSubmitEdit.disabled = true;
                    btnSubmitEdit.innerHTML = '<span class="material-symbols-outlined text-[18px] animate-spin">refresh</span> Đang lưu...';

                    const response = await fetch('/Teacher/UpdateClass', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded'
                        },
                        body: `classId=${encodeURIComponent(selectedEditClassId)}&className=${encodeURIComponent(className)}`
                    });

                    const result = await response.json();

                    if (result.success) {
                        closeModal();
                        if (window.appToast) {
                            window.appToast.storeAndReload(result.message || 'Cập nhật lớp học thành công.', 'success');
                        } else {
                            location.reload();
                        }
                    } else {
                        errorEditClassName.textContent = result.message || 'Cập nhật lớp học thất bại.';
                        errorEditClassName.classList.remove('hidden');
                        if (window.appToast) {
                            window.appToast.show(result.message || 'Cập nhật lớp học thất bại.', 'error');
                        }
                    }
                } catch (error) {
                    errorEditClassName.textContent = 'Không thể kết nối đến máy chủ.';
                    errorEditClassName.classList.remove('hidden');
                    if (window.appToast) {
                        window.appToast.show('Không thể kết nối đến máy chủ.', 'error');
                    }
                } finally {
                    btnSubmitEdit.disabled = false;
                    btnSubmitEdit.innerHTML = '<span class="material-symbols-outlined text-[18px]">save</span> Lưu thay đổi';
                }
            });
        }

        document.querySelectorAll('.btn-open-delete-class').forEach((button) => {
            button.addEventListener('click', () => {
                const classId = Number(button.getAttribute('data-class-id'));
                const className = button.getAttribute('data-class-name') || 'lớp học này';

                if (!classId) {
                    return;
                }

                selectedDeleteClassId = classId;
                deleteClassMessage.textContent = `Bạn có chắc muốn xóa lớp "${className}" không?`;

                overlay.classList.remove('hidden');
                overlay.classList.add('flex');
                modalDelete.classList.remove('hidden');
                modalDelete.classList.add('flex');
                modalCreate.classList.add('hidden');
                modalSuccess.classList.add('hidden');
                modalEdit.classList.add('hidden');
            });
        });

        if (btnSubmitDelete) {
            btnSubmitDelete.addEventListener('click', async () => {
                if (!selectedDeleteClassId) {
                    return;
                }

                try {
                    btnSubmitDelete.disabled = true;
                    btnSubmitDelete.innerHTML = '<span class="material-symbols-outlined text-[18px] animate-spin">refresh</span> Đang xóa...';

                    const response = await fetch('/Teacher/DeleteClass', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded'
                        },
                        body: `classId=${encodeURIComponent(selectedDeleteClassId)}`
                    });

                    const result = await response.json();
                    if (result.success) {
                        closeModal();
                        if (window.appToast) {
                            window.appToast.storeAndReload(result.message || 'Đã xóa lớp học thành công.', 'success');
                        } else {
                            location.reload();
                        }
                    } else {
                        deleteClassMessage.textContent = result.message || 'Xóa lớp học thất bại.';
                        if (window.appToast) {
                            window.appToast.show(result.message || 'Xóa lớp học thất bại.', 'error');
                        }
                    }
                } catch (error) {
                    deleteClassMessage.textContent = 'Không thể kết nối đến máy chủ.';
                    if (window.appToast) {
                        window.appToast.show('Không thể kết nối đến máy chủ.', 'error');
                    }
                } finally {
                    btnSubmitDelete.disabled = false;
                    btnSubmitDelete.innerHTML = '<span class="material-symbols-outlined text-[18px]">delete</span> Xóa lớp';
                }
            });
        }

        inputClassName.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                btnSubmitCreate.click();
            }
        });

        if (inputEditClassName) {
            inputEditClassName.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    if (btnSubmitEdit) {
                        btnSubmitEdit.click();
                    }
                }
            });
        }

        btnCopyCode.addEventListener('click', async () => {
            const code = successJoinCode.textContent;
            await navigator.clipboard.writeText(code);

            const originalText = btnCopyCode.innerHTML;
            btnCopyCode.innerHTML = '<span class="material-symbols-outlined text-[20px]">check</span> Đã sao chép';
            setTimeout(() => {
                btnCopyCode.innerHTML = originalText;
            }, 1200);
        });

        btnCloseSuccess.addEventListener('click', () => {
            closeModal();
            if (window.appToast) {
                window.appToast.storeAndReload(pendingCreateToastMessage, 'success');
            } else {
                location.reload();
            }
        });

        overlay.addEventListener('click', (e) => {
            if (e.target === overlay) {
                closeModal();
            }
        });

        document.querySelectorAll('.btn-copy-join-code').forEach((button) => {
            button.addEventListener('click', async () => {
                const code = button.getAttribute('data-code');
                if (!code) {
                    return;
                }

                await navigator.clipboard.writeText(code);
                const icon = button.querySelector('.material-symbols-outlined');
                if (!icon) {
                    return;
                }

                const oldValue = icon.textContent;
                icon.textContent = 'check';
                setTimeout(() => {
                    icon.textContent = oldValue;
                }, 1200);
            });
        });
    </script>
}
