<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Smart Exam Creator - No Sidebar Edition</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "primary": "#0056d2",
                        "background": "#f7f9fb",
                        "on-surface": "#191c1e",
                        "on-surface-variant": "#424654",
                        "surface-container-low": "#f2f4f6",
                        "surface-container-lowest": "#ffffff",
                        "surface-bright": "#f7f9fb",
                    },
                    fontFamily: {
                        sans: ["Manrope", "sans-serif"],
                    },
                    borderRadius: {
                        "xl": "1.5rem", /* Theo quy tắc soft corners trong DESIGN.md */
                    }
                }
            }
        }
    </script>
    <style>
        body { background-color: #f7f9fb; color: #191c1e; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24; }
        /* Tùy chỉnh dòng kẻ số thứ tự cho editor */
        .line-number::before {
            content: attr(data-line);
            position: absolute;
            left: -2rem;
            width: 1.5rem;
            text-align: right;
            color: #c3c6d6;
            font-size: 0.75rem;
            font-family: monospace;
        }
    </style>
</head>
<body class="antialiased h-screen flex flex-col overflow-hidden">

    <!-- Tiêu đề trang (breadcrumb removed) -->
    <div class="px-6 pt-5 pb-3 bg-white shrink-0 z-30 border-b border-slate-50">
        <h1 class="text-[32px] font-['Manrope',_sans-serif] font-bold text-[#0369A1] leading-none tracking-tight">Tạo đề thi thủ công</h1>
    </div>

    <!-- Thanh công cụ nhập tên, lưu, xuất bản -->
    <div class="h-16 bg-white/80 flex items-center px-6 z-30 border-b border-slate-100 justify-between gap-4 shrink-0 shadow-sm">
        <a href="/Teacher/Exams" title="Quay lại" class="text-slate-500 hover:text-primary transition-colors flex items-center justify-center w-9 h-9 rounded-full hover:bg-slate-100 shrink-0">
            <span class="material-symbols-outlined text-xl">arrow_back_ios_new</span>
        </a>
        
        <div class="flex-1 max-w-3xl flex items-center gap-3">
            <!-- Nhập Tên Đề Thi -->
            <div class="flex-1 flex items-center bg-slate-50/80 hover:bg-slate-100 transition-all rounded-xl px-4 py-1.5 border border-slate-200 focus-within:bg-white focus-within:border-primary/50 focus-within:ring-4 focus-within:ring-primary/10 shadow-sm">
                <input id="examTitleInput" class="w-full bg-transparent border-none p-0 text-[15px] font-normal text-on-surface focus:ring-0 outline-none placeholder-slate-400"
                       type="text" placeholder="Nhập tên đề thi..." value="" />
                <span class="text-red-500 text-lg font-black ml-2 mt-1 select-none" title="Bắt buộc">*</span>
            </div>
            
            <!-- Nhập Tên Môn Học -->
            <div class="w-64 flex items-center bg-slate-50/80 hover:bg-slate-100 transition-all rounded-xl px-4 py-1.5 border border-slate-200 focus-within:bg-white focus-within:border-primary/50 focus-within:ring-4 focus-within:ring-primary/10 shadow-sm">
                <span class="material-symbols-outlined text-slate-400 text-[18px] mr-2 select-none">book</span>
                <input id="examSubjectInput" class="w-full bg-transparent border-none p-0 text-[13px] font-normal text-slate-600 focus:ring-0 outline-none placeholder-slate-400"
                       type="text" placeholder="Nhập tên môn học..." value="" />
                <span class="text-red-500 text-lg font-black ml-2 mt-1 select-none" title="Bắt buộc">*</span>
            </div>

            <!-- Nhập Thời Gian Thi (Phút) -->
            <div class="w-48 flex items-center bg-slate-50/80 hover:bg-slate-100 transition-all rounded-xl px-4 py-1.5 border border-slate-200 focus-within:bg-white focus-within:border-primary/50 focus-within:ring-4 focus-within:ring-primary/10 shadow-sm">
                <span class="material-symbols-outlined text-slate-400 text-[18px] mr-2 select-none">schedule</span>
                <input id="examDurationInput" class="w-full bg-transparent border-none p-0 text-[13px] font-normal text-slate-600 focus:ring-0 outline-none placeholder-slate-400"
                       type="number" min="1" placeholder="Thời gian (phút)..." value="" />
            </div>
        </div>
        
        <div class="flex items-center gap-3 ml-auto">
            <button id="btnSaveDraft" class="bg-surface-container-low text-on-surface px-5 py-2 rounded-full font-bold text-[13px] hover:bg-slate-200 transition-all flex items-center gap-1.5">
                <span class="material-symbols-outlined text-base">save</span>
                Lưu bản nháp
            </button>
            <button id="btnPublish" class="bg-primary text-white px-6 py-2 rounded-full font-bold text-[13px] hover:opacity-90 transition-all shadow-lg shadow-blue-200 flex items-center gap-1.5">
                <span class="material-symbols-outlined text-base">publish</span>
                Xuất bản
            </button>
        </div>
    </div>

    <main class="flex flex-1 overflow-hidden">

        <div class="w-1/2 bg-white flex flex-col border-r border-slate-50">
            <div class="flex-1 overflow-hidden relative flex flex-col bg-white">
                <textarea id="nlEditor" class="w-full h-full resize-none border-none focus:ring-0 text-sm font-mono leading-[2] p-8 bg-transparent text-on-surface outline-none" placeholder="Nhập câu hỏi tại đây...&#10;Quy tắc:&#10;Câu [Số]: Nội dung câu hỏi&#10;A. Đáp án 1&#10;B. Đáp án 2&#10;Thêm dấu * trước đáp án đúng (*A. Đáp án 1)"></textarea>
            </div>
        </div>

        <div class="w-1/2 bg-surface-container-low flex flex-col shadow-[inset_10px_0_20px_-15px_rgba(0,0,0,0.05)]">
            <div id="previewContainer" class="flex-1 p-6 overflow-y-auto space-y-6">
            </div>
        </div>
    </main>

    <div class="bg-white/80 backdrop-blur-md border-t border-slate-100 p-3 flex items-center justify-between px-8 relative z-30">
        <div class="flex items-center gap-6">
            <div>
                <p class="text-[10px] font-black text-on-surface-variant uppercase tracking-widest mb-0.5">Tổng số câu</p>
                <div class="flex items-baseline gap-1">
                    <span class="text-lg font-black text-primary" id="totalQuestionsCount">0</span>
                    <span class="text-[11px] font-bold text-slate-400">câu hỏi</span>
                </div>
            </div>
        </div>
        <div class="flex items-center gap-4">
            <p class="text-xs font-bold text-slate-500">Mỗi câu: <span id="pointsPerQuestion" class="text-primary font-black">0.00</span> điểm / Tổng 10.0</p>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const titleInput = document.getElementById('examTitleInput');
            const subjectInput = document.getElementById('examSubjectInput');
            const btnSaveDraft = document.getElementById('btnSaveDraft');
            const btnPublish = document.getElementById('btnPublish');
            const nlEditor = document.getElementById('nlEditor');
            const previewContainer = document.getElementById('previewContainer');

            // 1. Validate Exam Title & Subject
            function validateActions() {
                const isValid = titleInput.value.trim() !== '' && subjectInput.value.trim() !== '';
                if (isValid) {
                    btnSaveDraft.classList.remove('opacity-50', 'cursor-not-allowed');
                    btnPublish.classList.remove('opacity-50', 'cursor-not-allowed');
                } else {
                    btnSaveDraft.classList.add('opacity-50', 'cursor-not-allowed');
                    btnPublish.classList.add('opacity-50', 'cursor-not-allowed');
                }
            }
            titleInput.addEventListener('input', validateActions);
            subjectInput.addEventListener('input', validateActions);

            function handleSavePrevent(e) {
                if (titleInput.value.trim() === '' || subjectInput.value.trim() === '') {
                    if (window.appToast) window.appToast.error("Vui lòng điền đầy đủ Tên đề thi và Tên môn học (phần có dấu sao đỏ) trước khi tiếp tục!");
                    else alert("Vui lòng điền đầy đủ Tên đề thi và Tên môn học (phần có dấu sao đỏ) trước khi tiếp tục!");
                    e.preventDefault();
                    return;
                }
                
                // Cấm lưu/xuất bản nếu không có nội dung câu hỏi nào
                const questions = parseQuestions(nlEditor.value);
                if (questions.length === 0) {
                    if (window.appToast) window.appToast.error("Đề thi chưa có nội dung câu hỏi nào. Vui lòng soạn ít nhất 1 câu hỏi vào khung soạn thảo!");
                    else alert("Đề thi chưa có nội dung câu hỏi nào. Vui lòng soạn ít nhất 1 câu hỏi vào khung soạn thảo!");
                    e.preventDefault();
                    return;
                }

                // Kiểm tra xem các câu hỏi đã có đáp án hợp lệ hay chưa
                for (let i = 0; i < questions.length; i++) {
                    const q = questions[i];
                    if (q.options.length < 2) {
                        if (window.appToast) window.appToast.error(`Câu [${q.number}] chưa nhập đủ các đáp án. Vui lòng nhập tối thiểu 2 đáp án (A, B...)!`);
                        else alert(`Câu [${q.number}] chưa nhập đủ các đáp án. Vui lòng nhập tối thiểu 2 đáp án (A, B...)!`);
                        e.preventDefault();
                        return;
                    }
                    if (!q.options.some(o => o.isCorrect)) {
                        if (window.appToast) window.appToast.error(`Câu [${q.number}] chưa đánh dấu đáp án đúng. Vui lòng thêm dấu * trước đáp án ĐÚNG!`);
                        else alert(`Câu [${q.number}] chưa đánh dấu đáp án đúng. Vui lòng thêm dấu * trước đáp án ĐÚNG!`);
                        e.preventDefault();
                        return;
                    }
                }

                // Gửi dữ liệu lên API Backend
                const btn = e.currentTarget;
                const originalText = btn.innerHTML;
                btn.innerHTML = `<span class="material-symbols-outlined text-base animate-spin">sync</span> Đang lưu...`;
                btn.classList.add('pointer-events-none', 'opacity-50');

                const payload = {
                    Title: titleInput.value.trim(),
                    Subject: subjectInput.value.trim() || "",
                    Duration: document.getElementById('examDurationInput').value ? parseInt(document.getElementById('examDurationInput').value) : null,
                    Status: btn.id === 'btnPublish' ? 'Xuất bản' : 'Bản nháp',
                    Questions: questions
                };

                fetch('/Teacher/SaveExam', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        if (window.appToast) {
                            window.appToast.redirect(btn.id === 'btnPublish' ? 'Xuất bản đề thi thành công!' : 'Lưu bản nháp thành công!', data.redirectUrl || '/Teacher/Exams');
                        } else {
                            window.location.href = data.redirectUrl || '/Teacher/Exams';
                        }
                    } else {
                        if (window.appToast) window.appToast.error('Lỗi khi lưu đề thi: ' + data.message);
                        else alert('Lỗi khi lưu đề thi: ' + data.message);
                        btn.innerHTML = originalText;
                        btn.classList.remove('pointer-events-none', 'opacity-50');
                    }
                })
                .catch(err => {
                    if (window.appToast) window.appToast.error('Lỗi hệ thống: ' + err);
                    else alert('Lỗi hệ thống: ' + err);
                    btn.innerHTML = originalText;
                    btn.classList.remove('pointer-events-none', 'opacity-50');
                });
            }
            btnSaveDraft.addEventListener('click', handleSavePrevent);
            btnPublish.addEventListener('click', handleSavePrevent);
            validateActions();

            // 2. Parse Natural Language to Object
            function parseQuestions(text) {
                const lines = text.split('\n');
                const questions = [];
                let currentQ = null;

                for (let i = 0; i < lines.length; i++) {
                    const line = lines[i].trim();
                    if (line === '') continue;

                    // Match question start: "Câu X:" or "Câu X."
                    const qMatch = line.match(/^Câu\s*(\d+)[:.]\s*(.*)$/i);
                    if (qMatch) {
                        if (currentQ) questions.push(currentQ);
                        currentQ = {
                            number: qMatch[1],
                            text: qMatch[2],
                            options: [],
                            lineIndex: i // Save line index for two-way sync
                        };
                        continue;
                    }

                    // Match option: "*A. text" or "B. text"
                    if (currentQ) {
                        const optMatch = line.match(/^(\*?)([A-Z])[.\)]\s*(.*)$/i);
                        if (optMatch) {
                            currentQ.options.push({
                                isCorrect: optMatch[1] === '*',
                                label: optMatch[2].toUpperCase(),
                                text: optMatch[3],
                                lineIndex: i
                            });
                        } else {
                            if (currentQ.options.length === 0) {
                                currentQ.text += '\n' + line;
                            }
                        }
                    }
                }
                if (currentQ) questions.push(currentQ);
                return questions;
            }

            // 3. Render Preview UI
            function renderPreview() {
                const text = nlEditor.value;
                const questions = parseQuestions(text);
                
                // Calculate points per question based on total 10.0 points
                const totalQ = questions.length;
                let pointsStr = '0.00';
                if (totalQ > 0) {
                    pointsStr = (10.0 / totalQ).toFixed(2);
                    // Remove trailing zero if it's a solid decimal like 2.00 -> 2.0
                    if(pointsStr.endsWith('0')) pointsStr = parseFloat(pointsStr).toString(); 
                }

                // Update bottom footer stats
                document.getElementById('totalQuestionsCount').innerText = totalQ;
                document.getElementById('pointsPerQuestion').innerText = pointsStr;

                let html = '';

                if (questions.length === 0) {
                    html = '<div class="text-center text-gray-400 py-10 text-sm">Chưa có câu hỏi nào. Hãy nhập khung bên trái theo ví dụ.</div>';
                }

                questions.forEach((q, qhIndex) => {
                    let optionsHtml = '';
                    
                    q.options.forEach((opt) => {
                        const isCorrectClassNames = opt.isCorrect 
                            ? 'p-4 rounded-2xl bg-blue-50 border border-blue-100 cursor-pointer opt-click' 
                            : 'p-4 rounded-2xl bg-white border border-transparent hover:border-slate-200 transition-all cursor-pointer opt-click';
                        
                        const labelClass = opt.isCorrect
                            ? 'bg-primary text-white'
                            : 'bg-surface-container-low text-on-surface';

                        const textClass = opt.isCorrect ? 'font-bold text-primary' : 'font-medium';

                        optionsHtml += `
                            <div class="flex items-center gap-4 ${isCorrectClassNames}" data-line="${opt.lineIndex}" data-qindex="${qhIndex}">
                                <span class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-black ${labelClass}">${opt.label}</span>
                                <span class="text-sm ${textClass} whitespace-pre-line">${opt.text}</span>
                            </div>
                        `;
                    });

                    html += `
                        <div class="bg-surface-container-lowest rounded-xl p-6 shadow-[0_12px_32px_rgba(25,28,30,0.04)] border border-transparent hover:border-blue-100 transition-all duration-500 mb-6">
                            <div class="flex items-center justify-between mb-4">
                                <div class="flex items-center gap-4">
                                    <span class="text-base font-extrabold text-primary">Câu ${q.number}</span>
                                    <div class="bg-surface-container-low rounded-full px-3 py-1 flex items-center gap-1.5">
                                        <span class="text-xs font-black text-center text-on-surface">${pointsStr}</span>
                                        <span class="text-[9px] text-on-surface-variant font-bold uppercase tracking-tighter">Điểm</span>
                                    </div>
                                </div>
                            </div>
                            <div class="space-y-6">
                                <h3 class="text-base font-bold text-on-surface whitespace-pre-line">${q.text}</h3>
                                <div class="grid grid-cols-2 gap-3">
                                    ${optionsHtml}
                                </div>
                            </div>
                        </div>
                    `;
                });

                previewContainer.innerHTML = html;

                // 4. Two-way sync: click right updates left
                const optDivs = previewContainer.querySelectorAll('.opt-click');
                optDivs.forEach(div => {
                    div.addEventListener('click', () => {
                        const lineIndex = parseInt(div.getAttribute('data-line'));
                        const qIndex = parseInt(div.getAttribute('data-qindex'));
                        toggleCorrectAnswer(qIndex, lineIndex);
                    });
                });
            }

            function toggleCorrectAnswer(targetQIndex, optionsLineIndex) {
                const text = nlEditor.value;
                let lines = text.split('\n');
                const questions = parseQuestions(text);
                const q = questions[targetQIndex];

                if(!q) return;

                // Remove '*' from all options in this question
                q.options.forEach(opt => {
                    let lineStr = lines[opt.lineIndex];
                    if (lineStr.trimStart().startsWith('*')) {
                        lines[opt.lineIndex] = lineStr.replace('*', '');
                    }
                });

                // Add '*' to the clicked option
                let selectedLineStr = lines[optionsLineIndex];
                const match = selectedLineStr.match(/^(\s*)([A-Z])[.\)]/i);
                if (match) {
                    lines[optionsLineIndex] = selectedLineStr.replace(match[2], '*' + match[2]);
                }

                nlEditor.value = lines.join('\n');
                renderPreview();
            }

            // Bind Editor to Parser
            nlEditor.addEventListener('input', renderPreview);
            
            // Execute first time
            renderPreview();
        });
    </script>
</body>
</html>