@model IEnumerable<OnlineExam.Models.ExamPaper>
@{
    ViewData["Title"] = "Quản lý đề thi";
}

@section Styles {
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 20;
        }
    </style>
}

<div class="max-w-7xl mx-auto space-y-8">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h1 class="text-[32px] font-['Manrope',_sans-serif] font-bold text-[#0369A1] leading-none tracking-tight">Quản lý đề thi</h1>
            <p class="text-sm text-slate-500 mt-2">Lưu trữ và quản lý hệ thống đề thi tập trung.</p>
        </div>

        <div class="flex md:items-center gap-3 max-md:flex-col max-md:items-start">
            <a href="/Teacher/CreateExam" class="flex items-center justify-center w-full py-2 h-11 bg-[#0369A1] text-white px-5 rounded-xl font-bold text-[14px] inline-flex items-center gap-2 shadow-[0_8px_20px_-6px_rgba(3,105,161,0.4)] hover:shadow-[0_12px_24px_-6px_rgba(3,105,161,0.5)] active:scale-[0.98] transition-all duration-300">
                <span class="material-symbols-outlined text-[18px]">add_circle</span>
                Tạo đề thi mới
            </a>
            <a href="/Teacher/OcrScanner" class="whitespace-nowrap flex items-center justify-center w-full py-2 h-11 bg-white border border-slate-200 text-slate-700 px-5 rounded-xl font-bold text-[14px] inline-flex items-center gap-2 shadow-sm hover:bg-slate-50 transition-all">
                <span class="material-symbols-outlined text-[18px] text-[#0369A1]">auto_awesome</span>
                Tải lên bằng AI
            </a>
        </div>
    </div>

    @if (ViewBag.ShowMeiliSearchWarning == true)
    {
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                if (window.appToast) window.appToast.warning("Không kết nối được với Meilisearch. Hệ thống đã tự động chuyển sang tìm kiếm thường.");
            });
        </script>
    }
        

        <div class="bg-white rounded-2xl p-4 md:p-5 border border-slate-100 shadow-sm flex flex-col gap-4">
            <div class="flex flex-wrap items-center justify-between gap-3">
                <div class="flex items-center gap-2">
                    <span class="text-sm font-bold text-slate-700">Công cụ:</span>
                </div>

                <div class="flex items-center border border-slate-200 rounded-lg bg-white h-9 relative">
                    <button id="exportMainBtn" class="flex items-center gap-2 px-3 py-1.5 text-slate-600 hover:bg-slate-50 transition-colors text-[12px] font-semibold border-r border-slate-200 focus:outline-none">
                        <span class="material-symbols-outlined !text-sm">download</span>
                        Export File
                    </button>
                    
                    <div id="exportMenu" class="hidden absolute left-0 top-full mt-2 bg-white shadow-2xl border border-gray-100 rounded-xl w-[200px] z-[9999] py-2">
                        <p class="px-4 py-1 text-[9px] font-black text-gray-400 uppercase tracking-widest">Định dạng</p>
                        <button type="button" onclick="exportSelectedExam('word')" class="flex items-center w-full text-left gap-2 px-4 py-2 hover:bg-blue-50 text-[#0369A1] text-[11px] font-bold">
                            <span class="material-symbols-outlined !text-sm">description</span> Xuất File Word (.doc)
                        </button>
                        <button type="button" onclick="exportSelectedExam('pdf')" class="flex items-center w-full text-left gap-2 px-4 py-2 hover:bg-red-50 text-red-600 text-[11px] font-bold">
                            <span class="material-symbols-outlined !text-sm">picture_as_pdf</span> Xuất File PDF (.pdf)
                        </button>
                    </div>

                    <div class="relative h-full">
                        <button id="gearBtn" class="px-2 h-full text-slate-600 hover:bg-slate-50 flex items-center focus:outline-none">
                            <span class="material-symbols-outlined">settings</span>
                        </button>

                        <div id="gearMenu" class="hidden absolute right-0 top-full mt-2 bg-white shadow-2xl border border-gray-100 rounded-xl w-52 z-[9999] py-2">
                            <p class="px-4 py-1 text-[9px] font-black text-gray-400 uppercase tracking-widest">Thao tác</p>
                            <button type="button" onclick="deleteSelectedExams()" class="flex items-center w-full text-left gap-2 px-4 py-2 hover:bg-red-50 text-red-600 text-[11px] font-bold">
                                <span class="material-symbols-outlined !text-sm">delete_sweep</span> Xóa mục đã chọn
                            </button>
                            <button type="button" onclick="copySelectedExams()" class="flex items-center w-full text-left gap-2 px-4 py-2 hover:bg-blue-50 text-[#0369A1] text-[11px] font-bold">
                                <span class="material-symbols-outlined !text-sm">content_copy</span> Sao chép nhanh
                            </button>
                            <hr class="my-1 border-gray-50">
                            <p class="px-4 py-1 text-[9px] font-black text-gray-400 uppercase tracking-widest">Hiển thị cột</p>
                            <label class="flex items-center gap-2 px-4 py-2 text-[11px] cursor-pointer hover:bg-gray-50">
                                <input type="checkbox" checked class="col-toggle rounded text-[#0369A1] w-3 h-3" data-col="2"> <span>Mã đề</span>
                            </label>
                            <label class="flex items-center gap-2 px-4 py-2 text-[11px] cursor-pointer hover:bg-gray-50">
                                <input type="checkbox" checked class="col-toggle rounded text-[#0369A1] w-3 h-3" data-col="3"> <span>Tên đề thi</span>
                            </label>
                            <label class="flex items-center gap-2 px-4 py-2 text-[11px] cursor-pointer hover:bg-gray-50">
                                <input type="checkbox" checked class="col-toggle rounded text-[#0369A1] w-3 h-3" data-col="4"> <span>Môn</span>
                            </label>
                            <label class="flex items-center gap-2 px-4 py-2 text-[11px] cursor-pointer hover:bg-gray-50">
                                <input type="checkbox" checked class="col-toggle rounded text-[#0369A1] w-3 h-3" data-col="5"> <span>Cập nhật</span>
                            </label>
                            <label class="flex items-center gap-2 px-4 py-2 text-[11px] cursor-pointer hover:bg-gray-50">
                                <input type="checkbox" checked class="col-toggle rounded text-[#0369A1] w-3 h-3" data-col="6"> <span>Trạng thái</span>
                            </label>
                            <label class="flex items-center gap-2 px-4 py-2 text-[11px] cursor-pointer hover:bg-gray-50">
                                <input type="checkbox" checked class="col-toggle rounded text-[#0369A1] w-3 h-3" data-col="7"> <span>Hành động</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <form method="get" action="/Teacher/Exams" class="grid grid-cols-1 md:grid-cols-12 gap-3 items-end" id="filterForm">
                <div class="md:col-span-5">
                    <label class="text-xs font-semibold text-slate-500 uppercase tracking-widest block mb-2">Tìm kiếm đề thi</label>
                    <div class="relative">
                        <span class="material-symbols-outlined text-slate-400 absolute left-3 top-1/2 -translate-y-1/2">search</span>
                        <input id="searchInput" name="search" value="@ViewBag.CurrentSearch" onchange="document.getElementById('filterForm').submit();" class="w-full h-11 rounded-xl border border-slate-200 pl-10 pr-14 focus:ring-2 focus:ring-[#0369A1]/20 focus:border-[#0369A1]" placeholder="Nhập tên đề thi..." type="text" />
                        <button type="submit" class="absolute right-1.5 top-1/2 -translate-y-1/2 h-8.5 w-8.5 rounded-lg bg-[#0369A1] text-white inline-flex items-center justify-center hover:bg-[#0369A1] transition-colors" title="Tìm kiếm">
                            <span class="material-symbols-outlined text-[18px] p-2">search</span>
                        </button>
                    </div>
                </div>

                <div class="md:col-span-3">
                    <label class="text-xs font-semibold text-slate-500 uppercase tracking-widest block mb-2">Lọc theo môn</label>
                    <div class="relative">
                        <select id="subjectFilter" name="subject" onchange="document.getElementById('filterForm').submit();" class="w-full h-11 appearance-none rounded-xl border border-slate-200 pl-3 pr-11 focus:ring-2 focus:ring-[#0369A1]/20 focus:border-[#0369A1]">
                            <option value="">Tất cả các môn</option>
                            @if (ViewBag.AllSubjects != null)
                            {
                                foreach (string subName in ViewBag.AllSubjects)
                                {
                                    if (subName == ViewBag.CurrentSubject)
                                    {
                                        <option value="@subName" selected>@subName</option>
                                    }
                                    else
                                    {
                                        <option value="@subName">@subName</option>
                                    }
                                }
                            }
                        </select>
                        <span class="material-symbols-outlined text-slate-400 absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none">expand_more</span>
                    </div>
                </div>

                <div class="md:col-span-3">
                    <label class="text-xs font-semibold text-slate-500 uppercase tracking-widest block mb-2">Lọc trạng thái</label>
                    <div class="relative">
                        <select id="statusFilter" name="status" onchange="document.getElementById('filterForm').submit();" class="w-full h-11 appearance-none rounded-xl border border-slate-200 pl-3 pr-11 focus:ring-2 focus:ring-[#0369A1]/20 focus:border-[#0369A1]">
                            <option value="">Tất cả</option>
                            <option value="Xuất bản" selected="@(ViewBag.CurrentStatus == "Xuất bản" ? "selected" : null)">Xuất bản</option>
                            <option value="Bản nháp" selected="@(ViewBag.CurrentStatus == "Bản nháp" ? "selected" : null)">Bản nháp</option>
                        </select>
                        <span class="material-symbols-outlined text-slate-400 absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none">expand_more</span>
                    </div>
                </div>

                <div class="md:col-span-1">
                    <label class="text-xs font-semibold text-transparent uppercase tracking-widest block mb-2 select-none">Bỏ lọc</label>
                    <a href="/Teacher/Exams" class="h-11 w-full rounded-xl bg-slate-100 text-slate-600 font-semibold inline-flex items-center justify-center hover:bg-slate-200 transition-colors" title="Xóa toàn bộ tìm kiếm và lọc" aria-label="Xóa toàn bộ bộ lọc">
                        <span class="material-symbols-outlined text-[20px]">filter_alt_off</span>
                    </a>
                </div>
            </form>
        </div>

        <div class="bg-white rounded-xl shadow-sm overflow-hidden mb-4 border border-gray-100 p-3 md:p-4">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse text-[13px] md:text-sm">
                    <thead class="bg-gray-50/80 text-[11px] md:text-[12px] font-black text-gray-500 uppercase tracking-wider">
                        <tr>
                            <th class="p-2 w-8"><input type="checkbox" id="selectAll" class="rounded text-primary w-3 h-3" /></th>
                            <th class="p-2 col-2">Mã đề</th>
                            <th class="p-2 col-3">Tên đề thi</th>
                            <th class="p-2 col-4">Môn</th>
                            <th class="p-2 col-5">Cập nhật</th>
                            <th class="p-2 col-6 whitespace-nowrap w-24">Trạng thái</th>
                            <th class="p-2 text-right col-7">Hành động</th>
                        </tr>
                    </thead>
                    <tbody class="text-[12px] divide-y divide-gray-50">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-blue-50/30 transition-colors group">
                                <td class="p-2 text-center">
                                    <input type="checkbox" class="row-checkbox rounded w-3 h-3" value="@item.Id" />
                                </td>
                                <td class="p-2 font-mono font-bold text-primary text-[12px] md:text-[13px] col-2">MAT-@item.Id</td>
                                <td class="p-2 col-3">
                                    <p class="font-bold text-on-surface leading-tight text-[14px] md:text-[15px]">@item.Title</p>
                                    <p class="text-[11px] md:text-[12px] text-gray-400 mt-0.5 uppercase">Thời gian thi: @(item.Duration.HasValue ? $"{item.Duration} phút" : "--")</p>
                                </td>
                                <td class="p-2 text-gray-500 col-4 text-[13px] md:text-[14px]">
                                    @if (!string.IsNullOrEmpty(item.Subject))
                                    {
                                        <span>@item.Subject</span>
                                    }
                                    else
                                    {
                                        <span class="text-gray-300 italic">Chưa nhập môn</span>
                                    }
                                </td>
                                <td class="p-2 text-gray-400 text-[12px] md:text-[13px] col-5">@(item.CreatedAt?.ToString("dd/MM/yyyy, HH:mm"))</td>
                                <td class="p-2 col-6 whitespace-nowrap">
                                    @if (item.Status == "Xuất bản")
                                    {
                                        <span class="px-2 py-0.5 rounded-full bg-emerald-50 text-emerald-600 text-[10px] md:text-[11px] font-black uppercase">Xuất bản</span>
                                    }
                                    else
                                    {
                                        <span class="px-2 py-0.5 rounded-full bg-gray-100 text-gray-500 text-[10px] md:text-[11px] font-black uppercase">Bản nháp</span>
                                    }
                                </td>
                                <td class="p-2 col-7">
                                    <div class="flex justify-end gap-0.5">
                                        <a href="/Teacher/ExamDetails/@item.Id" class="p-1 hover:bg-white text-gray-400 hover:text-primary rounded transition-colors" title="Xem chi tiết"><span class="material-symbols-outlined !text-[18px]">visibility</span></a>
                                        <a href="/Teacher/EditExam/@item.Id" class="p-1 hover:bg-white text-gray-400 hover:text-primary rounded transition-colors" title="Sửa"><span class="material-symbols-outlined !text-[18px]">edit</span></a>
                                        <button type="button" onclick="copyExam(@item.Id)" class="p-1 hover:bg-white text-gray-400 hover:text-primary rounded transition-colors" title="Sao chép"><span class="material-symbols-outlined !text-[18px]">content_copy</span></button>
                                        <button type="button" onclick="deleteExam(@item.Id)" class="p-1 hover:bg-white text-gray-400 hover:text-red-500 rounded transition-colors" title="Xóa"><span class="material-symbols-outlined !text-[18px]">delete</span></button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="p-2 border-t border-gray-50 flex items-center justify-end bg-white text-[10px] font-bold text-gray-400">
                <div class="flex gap-1">
                    @{
                        int totalExams = ViewBag.TotalExams ?? 0;
                        int totalPages = ViewBag.TotalPages ?? 1;
                        int currentPage = ViewBag.CurrentPage ?? 1;
                        if (totalPages < 1) totalPages = 1;

                        string PagerLink(int pageNum)
                        {
                            var q = new List<string>();
                            if (pageNum > 1) q.Add("page=" + pageNum);
                            if (!string.IsNullOrEmpty(ViewBag.CurrentSearch)) q.Add("search=" + Uri.EscapeDataString(ViewBag.CurrentSearch));
                            if (!string.IsNullOrEmpty(ViewBag.CurrentSubject)) q.Add("subject=" + Uri.EscapeDataString(ViewBag.CurrentSubject));
                            if (!string.IsNullOrEmpty(ViewBag.CurrentTitle)) q.Add("title=" + Uri.EscapeDataString(ViewBag.CurrentTitle));
                            if (!string.IsNullOrEmpty(ViewBag.CurrentStatus)) q.Add("status=" + Uri.EscapeDataString(ViewBag.CurrentStatus));
                            
                            return "/Teacher/Exams" + (q.Count > 0 ? "?" + string.Join("&", q) : "");
                        }
                    }

                    @if (totalPages > 1)
                    {
                        var startPage = Math.Max(1, currentPage - 2);
                        var endPage = Math.Min(totalPages, startPage + 4);
                        startPage = Math.Max(1, endPage - 4);

                        if (currentPage > 1)
                        {
                            <a href="@PagerLink(currentPage - 1)" class="w-6 h-6 rounded border border-gray-100 flex items-center justify-center hover:bg-gray-50 text-lg">«</a>
                        }
                        else
                        {
                            <span class="w-6 h-6 rounded border border-gray-100 flex items-center justify-center text-lg opacity-50 cursor-default">«</span>
                        }

                        @for (int p = startPage; p <= endPage; p++)
                        {
                            if (p == currentPage)
                            {
                                <span class="w-6 h-6 rounded bg-[#0369A1] text-white flex items-center justify-center font-bold">@p</span>
                            }
                            else
                            {
                                <a href="@PagerLink(p)" class="w-6 h-6 rounded border border-gray-100 flex items-center justify-center hover:bg-gray-50 font-bold">@p</a>
                            }
                        }

                        if (currentPage < totalPages)
                        {
                            <a href="@PagerLink(currentPage + 1)" class="w-6 h-6 rounded border border-gray-100 flex items-center justify-center hover:bg-gray-50 text-lg">»</a>
                        }
                        else
                        {
                            <span class="w-6 h-6 rounded border border-gray-100 flex items-center justify-center text-lg opacity-50 cursor-default">»</span>
                        }
                    }
                    else
                    {
                        <span class="w-6 h-6 rounded border border-gray-100 flex items-center justify-center text-lg opacity-50 cursor-default">«</span>
                        <span class="w-6 h-6 rounded bg-[#0369A1] text-white flex items-center justify-center font-bold">1</span>
                        <span class="w-6 h-6 rounded border border-gray-100 flex items-center justify-center text-lg opacity-50 cursor-default">»</span>
                    }
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-6">
            <div class="bg-white px-4 py-3 rounded-xl border border-gray-100 shadow-sm flex flex-col justify-center relative overflow-hidden group">
                <p class="text-on-surface-variant text-xs font-bold uppercase tracking-wider mb-1">Tổng đề thi</p>
                <h3 class="text-lg font-extrabold text-on-surface leading-none">@ViewBag.TotalExams</h3>
                <span class="material-symbols-outlined absolute -right-2 -bottom-2 text-5xl text-gray-100 transition-transform group-hover:scale-110">library_books</span>
            </div>

            <div class="bg-white px-4 py-3 rounded-xl border border-gray-100 shadow-sm flex flex-col justify-center">
                <p class="text-on-surface-variant text-xs font-bold uppercase tracking-wider mb-1">Phổ biến nhất</p>
                <h3 class="text-sm font-extrabold text-on-surface line-clamp-2 leading-tight" title="@ViewBag.PopularSubject">@ViewBag.PopularSubject</h3>
            </div>

            <div class="bg-white px-4 py-3 rounded-xl border border-gray-100 shadow-sm flex flex-col justify-center">
                <p class="text-on-surface-variant text-xs font-bold uppercase tracking-wider mb-1.5">Tổng câu hỏi</p>
                <div class="w-full h-1 bg-gray-100 rounded-full mb-1.5">
                    @{
                        int totalQ = ViewBag.TotalQuestions ?? 0;
                        int percentage = totalQ > 0 ? (totalQ * 100 / 1000) : 0; // Giả sử mục tiêu hệ thống là 1000
                        if (percentage > 100) percentage = 100;
                    }
                    <div class="h-full bg-primary rounded-full" style="width: @(percentage)%"></div>
                </div>
                <p class="text-sm font-extrabold text-on-surface leading-none">@totalQ <span class="text-[10px] text-on-surface-variant font-normal">/ 1,000</span></p>
            </div>
        </div>

        <footer class="pt-4 border-t border-gray-100 flex items-center justify-between text-[11px] md:text-[12px] text-on-surface-variant">
            <div class="flex gap-4">
                <div class="flex items-center gap-1.5">
                    <kbd class="px-1.5 py-0.5 bg-white border border-gray-200 rounded shadow-sm font-mono font-bold text-primary">Alt+N</kbd>
                    <span class="font-medium">Tạo mới</span>
                </div>
                <div class="flex items-center gap-1.5">
                    <kbd class="px-1.5 py-0.5 bg-white border border-gray-200 rounded shadow-sm font-mono font-bold text-primary">Alt+F</kbd>
                    <span class="font-medium">Tìm nhanh</span>
                </div>
                <div class="flex items-center gap-1.5">
                    <kbd class="px-1.5 py-0.5 bg-white border border-gray-200 rounded shadow-sm font-mono font-bold text-primary">Alt+C</kbd>
                    <span class="font-medium">Chép nhiều</span>
                </div>
                <div class="flex items-center gap-1.5">
                    <kbd class="px-1.5 py-0.5 bg-white border border-gray-200 rounded shadow-sm font-mono font-bold text-primary">Alt+X</kbd>
                    <span class="font-medium">Xóa nhiều</span>
                </div>
            </div>
            <div class="opacity-60 flex items-center gap-1 font-bold uppercase tracking-tighter">
                <span class="material-symbols-outlined !text-[12px]">verified_user</span>
                Secure System
            </div>
        </footer>
    </main>
    <script>

        // 1. Khai báo các thành phần
        const gearBtn = document.getElementById('gearBtn');
        const gearMenu = document.getElementById('gearMenu');
        const exportMainBtn = document.getElementById('exportMainBtn');
        const exportMenu = document.getElementById('exportMenu');

        // 2. Hàm xử lý hiển thị menu (Toggle)
        function toggleMenu(menuToOpen, menuToClose) {
            menuToOpen.classList.toggle('hidden');
            menuToClose.classList.add('hidden'); // Luôn đóng menu còn lại
        }

        // 3. Sự kiện Click cho nút Bánh răng
        gearBtn.addEventListener('click', function(e) {
            e.stopPropagation(); // Ngăn sự kiện lan ra ngoài
            toggleMenu(gearMenu, exportMenu);
        });

        // 4. Sự kiện Click cho nút Export
        exportMainBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            toggleMenu(exportMenu, gearMenu);
        });

        // 5. Ngăn menu bị đóng khi click vào bên trong chính nó
        gearMenu.addEventListener('click', e => e.stopPropagation());
        exportMenu.addEventListener('click', e => e.stopPropagation());

        // 6. Click ra bất kỳ đâu bên ngoài để đóng hết các menu
        document.addEventListener('click', function() {
            gearMenu.classList.add('hidden');
            exportMenu.classList.add('hidden');
        });

        // --- Các hàm chức năng khác giữ nguyên ---

        function exportSelectedExam(format) {
            const checkboxes = document.querySelectorAll('.row-checkbox:checked');
            if (checkboxes.length === 0) {
                if (window.appToast) window.appToast.show("Vui lòng tick chọn ít nhất 1 đề thi để xuất file!", "error");
                return;
            }
            if (checkboxes.length > 1) {
                if (window.appToast) window.appToast.show("Bạn chỉ được chọn đúng 1 đề thi duy nhất để xuất mỗi lần!", "error");
                return;
            }
            const activeId = checkboxes[0].value;
            if(format === "word") {
                window.location.href = `/Teacher/ExportExam?id=${activeId}&format=word`;
            } else if(format === "pdf") {
                window.open(`/Teacher/ExportExam?id=${activeId}&format=pdf`, '_blank');
            }
        }

        // Toggle hiển thị cột (Giữ nguyên logic của Nhi)
        const colToggles = document.querySelectorAll('.col-toggle');
        colToggles.forEach(toggle => {
            const colId = toggle.getAttribute('data-col');
            const colClass = '.col-' + colId;
            const elements = document.querySelectorAll(colClass);
            const savedState = localStorage.getItem('hide_col_' + colId);
            if (savedState === 'true') {
                toggle.checked = false;
                elements.forEach(el => el.style.display = 'none');
            }
            toggle.addEventListener('change', function() {
                const isChecked = this.checked;
                if (!isChecked) {
                    localStorage.setItem('hide_col_' + colId, 'true');
                } else {
                    localStorage.removeItem('hide_col_' + colId);
                }
                elements.forEach(el => el.style.display = isChecked ? '' : 'none');
            });
        });

        // Chọn tất cả
        const selectAllCheckbox = document.getElementById('selectAll');
        const rowCheckboxes = document.querySelectorAll('.row-checkbox');
        if (selectAllCheckbox) {
            selectAllCheckbox.addEventListener('change', function() {
                rowCheckboxes.forEach(cb => cb.checked = this.checked);
            });
        }

        // Các hàm Xóa/Copy (Giữ nguyên logic của Nhi)
        async function execDelete(ids) { 
            try {
                const response = await fetch('/Teacher/DeleteExams', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(ids)
                });
                if (response.ok) {
                    window.location.reload();
                } else {
                    if (window.appToast) window.appToast.show('Lỗi khi xóa!', 'error');
                }
            } catch (error) {
                console.error(error);
                if (window.appToast) window.appToast.show('Có lỗi xảy ra!', 'error');
            }
        }
        function deleteExam(id) { window.appConfirm.show('Xác nhận xóa', 'Bạn có chắc chắn muốn xóa đề thi này?', () => execDelete([id])); }
        function deleteSelectedExams() { 
            const checkboxes = document.querySelectorAll('.row-checkbox:checked');
            if (checkboxes.length === 0) {
                if (window.appToast) window.appToast.show("Vui lòng tick chọn ít nhất 1 đề thi để xóa!", "error");
                return;
            }
            window.appConfirm.show('Xác nhận xóa', `Bạn có chắc chắn muốn xóa ${checkboxes.length} đề thi đã chọn?`, () => {
                const ids = Array.from(checkboxes).map(cb => parseInt(cb.value));
                execDelete(ids);
            });
        }
        
        async function execCopy(ids) { 
            try {
                const response = await fetch('/Teacher/CopyExams', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(ids)
                });
                if (response.ok) {
                    window.location.reload(); // Load lại trang để hiển thị bài mới
                } else {
                    if (window.appToast) window.appToast.show('Lỗi khi sao chép!', 'error');
                }
            } catch (error) {
                console.error(error);
                if (window.appToast) window.appToast.show('Có lỗi xảy ra!', 'error');
            }
        }
        function copyExam(id) { window.appConfirm.show('Xác nhận sao chép', 'Bạn có muốn sao chép đề thi này?', () => execCopy([id])); }
        function copySelectedExams() { 
            const checkboxes = document.querySelectorAll('.row-checkbox:checked');
            if (checkboxes.length === 0) {
                if (window.appToast) window.appToast.show("Vui lòng tick chọn ít nhất 1 đề thi để sao chép!", "error");
                return;
            }
            window.appConfirm.show('Xác nhận sao chép', `Bạn có muốn sao chép ${checkboxes.length} đề thi đã chọn?`, () => {
                const ids = Array.from(checkboxes).map(cb => parseInt(cb.value));
                execCopy(ids);
            });
        }

        // Bắt sự kiện phím tắt
        document.addEventListener('keydown', function (e) {
            // Alt + N (Tạo đề thi mới)
            if (e.altKey && (e.key === 'n' || e.key === 'N')) {
                e.preventDefault();
                window.location.href = '/Teacher/CreateExam';
            }
            // Alt + C (Sao chép nhiều)
            if (e.altKey && (e.key === 'c' || e.key === 'C')) {
                e.preventDefault();
                copySelectedExams();
            }
            // Alt + X (Xóa nhiều)
            if (e.altKey && (e.key === 'x' || e.key === 'X')) {
                e.preventDefault();
                deleteSelectedExams();
            }
        });
    </script>
