@model OnlineExam.ViewModels.TeacherDashboardVM
@{
    ViewData["Title"] = "Tổng quan";
    var today = DateTime.Now.ToString("dddd, dd 'Tháng' MM", new System.Globalization.CultureInfo("vi-VN"));
    today = char.ToUpper(today[0]) + today.Substring(1);
    var hour = DateTime.Now.Hour;
    var greeting = hour < 12 ? "Chào buổi sáng" : hour < 18 ? "Chào buổi chiều" : "Chào buổi tối";
}

<div class="animate-fade-in">
    <section class="bg-[#e7f1ff] rounded-[32px] p-8 lg:p-12 mb-8 flex flex-col md:flex-row items-center justify-between overflow-visible relative">
        <div class="z-10 text-center md:text-left mb-8 md:mb-0">
            <h1 class="text-2xl lg:text-5xl font-extrabold text-[#004493] tracking-tight mb-4">
                @greeting, @Model.TeacherName!
            </h1>
            <p class="text-[#1a73e8] text-lg max-w-md font-medium leading-relaxed">
                Hãy cùng kiến tạo những trải nghiệm học tập tuyệt vời cho học sinh của bạn ngày hôm nay.
            </p>
            <div class="mt-8 flex gap-6 justify-center md:justify-start">
                <div class="flex items-center gap-2 text-[#004493] font-semibold">
                    <span class="material-symbols-outlined text-xl">calendar_today</span>
                    <span>@today</span>
                </div>
                <div class="flex items-center gap-2 text-[#004493] font-semibold">
                    <span class="material-symbols-outlined text-xl">event</span>
                    <span>Ca thi hôm nay: @Model.SessionsToday</span>
                </div>
            </div>
        </div>
        <div class="hidden md:block w-72 lg:w-80">
            <img alt="Academic Illustration" class="w-full drop-shadow-2xl rounded-2xl" src="https://images.unsplash.com/photo-1501504905252-473c47e087f8?q=80&w=600&auto=format&fit=crop" style="opacity: 0.9;" />
        </div>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12 px-2 lg:px-4">
        <div class="bg-white p-6 rounded-[28px] shadow-lg border border-slate-50 flex flex-col items-center text-center group hover:-translate-y-1 transition-transform duration-300">
            <div class="w-14 h-14 bg-brand-blue/10 text-brand-blue rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <span class="material-symbols-outlined text-3xl">groups</span>
            </div>
            <h4 class="text-lg font-bold mb-2">Quản lý lớp học</h4>
            <p class="text-slate-500 text-xs mb-4 line-clamp-2">Theo dõi tiến độ, quản lý danh sách và phê duyệt học sinh tham gia.</p>
            <a href="/Teacher/Classes" class="w-full py-2.5 bg-brand-blue text-white text-xs font-bold rounded-xl hover:bg-brand-blue-container transition-colors block text-center">
                Xem chi tiết
            </a>
        </div>

        <div class="bg-brand-blue p-6 rounded-[28px] shadow-xl shadow-brand-blue/20 flex flex-col items-center text-center group hover:-translate-y-1 transition-transform duration-300">
            <div class="w-14 h-14 bg-white/20 text-white rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <span class="material-symbols-outlined text-3xl">description</span>
            </div>
            <h4 class="text-lg font-bold text-white mb-2">Quản lý đề thi</h4>
            <p class="text-white/80 text-xs mb-4 line-clamp-2">Tạo đề thi chuyên nghiệp bằng AI OCR từ ảnh hoặc file PDF.</p>
            <a href="/Teacher/Exams" class="mt-auto w-full py-2.5 bg-white text-brand-blue text-xs font-bold rounded-xl hover:bg-slate-50 transition-colors block text-center">
                Tạo đề ngay
            </a>
        </div>

        <div class="bg-white p-6 rounded-[28px] shadow-lg border border-slate-50 flex flex-col items-center text-center group hover:-translate-y-1 transition-transform duration-300">
            <div class="w-14 h-14 bg-brand-orange/10 text-brand-orange rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <span class="material-symbols-outlined text-3xl">event_available</span>
            </div>
            <h4 class="text-lg font-bold mb-2">Tổ chức ca thi</h4>
            <p class="text-slate-500 text-xs mb-4 line-clamp-2">Lên lịch, thiết lập mật khẩu và giám sát quá trình làm bài.</p>
            <a href="/Teacher/Sessions" class="mt-auto w-full py-2.5 border-2 border-brand-orange text-brand-orange text-xs font-bold rounded-xl hover:bg-brand-orange hover:text-white transition-all block text-center">
                Lên lịch
            </a>
        </div>
    </section>

    <div class="grid grid-cols-12 gap-8">
        <div class="col-span-12 lg:col-span-8 space-y-8">

            <div class="bg-white p-8 rounded-[32px] shadow-sm border border-slate-100">
                <div class="flex items-center justify-between mb-8">
                    <h3 class="text-xl font-extrabold text-slate-800">Tính năng nổi bật</h3>
                    <span class="text-brand-blue font-bold text-sm flex items-center gap-1">Khám phá tất cả <span class="material-symbols-outlined text-sm ml-1">chevron_right</span></span>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <div class="flex items-start gap-4 p-5 bg-slate-50 rounded-2xl hover:bg-brand-blue/5 transition-colors group">
                        <div class="w-12 h-12 shrink-0 bg-blue-100 text-brand-blue-container rounded-xl flex items-center justify-center">
                            <span class="material-symbols-outlined text-xl">auto_awesome</span>
                        </div>
                        <div>
                            <h5 class="font-bold text-sm mb-1 group-hover:text-brand-blue transition-colors text-slate-800">Tạo đề bằng AI (OCR)</h5>
                            <p class="text-[11px] text-slate-500 leading-relaxed">Chuyển đổi ảnh chụp đề thi thành văn bản số hóa tức thì.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4 p-5 bg-slate-50 rounded-2xl hover:bg-brand-blue/5 transition-colors group">
                        <div class="w-12 h-12 shrink-0 bg-red-100 text-red-500 rounded-xl flex items-center justify-center">
                            <span class="material-symbols-outlined text-xl">security</span>
                        </div>
                        <div>
                            <h5 class="font-bold text-sm mb-1 group-hover:text-brand-blue transition-colors text-slate-800">Giám sát chống gian lận</h5>
                            <p class="text-[11px] text-slate-500 leading-relaxed">Đảo câu hỏi, đảo đáp án và cảnh báo khi chuyển tab.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4 p-5 bg-slate-50 rounded-2xl hover:bg-brand-blue/5 transition-colors group">
                        <div class="w-12 h-12 shrink-0 bg-emerald-100 text-brand-teal rounded-xl flex items-center justify-center">
                            <span class="material-symbols-outlined text-xl">analytics</span>
                        </div>
                        <div>
                            <h5 class="font-bold text-sm mb-1 group-hover:text-brand-blue transition-colors text-slate-800">Báo cáo thông minh</h5>
                            <p class="text-[11px] text-slate-500 leading-relaxed">Tự động tổng hợp kết quả và phân tích học lực ngay sau ca thi.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4 p-5 bg-slate-50 rounded-2xl hover:bg-brand-blue/5 transition-colors group">
                        <div class="w-12 h-12 shrink-0 bg-amber-100 text-brand-yellow rounded-xl flex items-center justify-center">
                            <span class="material-symbols-outlined text-xl">search</span>
                        </div>
                        <div>
                            <h5 class="font-bold text-sm mb-1 group-hover:text-brand-blue transition-colors text-slate-800">Tìm kiếm siêu tốc</h5>
                            <p class="text-[11px] text-slate-500 leading-relaxed">Truy xuất dữ liệu đề thi, học sinh, ca thi ngay lập tức.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white p-8 rounded-[32px] shadow-sm border border-slate-100">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-xl font-extrabold text-slate-800">Ca thi gần đây</h3>
                    <a href="/Teacher/Sessions" class="text-brand-blue text-sm font-bold hover:underline">Xem tất cả</a>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="border-b-2 border-slate-100">
                                <th class="pb-3 text-[10px] font-bold text-slate-400 uppercase tracking-widest">Tên ca thi</th>
                                <th class="pb-3 text-[10px] font-bold text-slate-400 uppercase tracking-widest">Lớp học</th>
                                <th class="pb-3 text-[10px] font-bold text-slate-400 uppercase tracking-widest">Thời gian</th>
                                <th class="pb-3 text-[10px] font-bold text-slate-400 uppercase tracking-widest text-right">Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50">
                            @if (Model.RecentSessions != null && Model.RecentSessions.Any())
                            {
                                foreach (var session in Model.RecentSessions)
                                {
                                    <tr class="hover:bg-slate-50/50 transition-colors">
                                        <td class="py-4">
                                            <p class="font-bold text-sm text-slate-800">@session.SessionName</p>
                                        </td>
                                        <td class="py-4">
                                            <span class="px-3 py-1 bg-slate-100 text-slate-600 rounded-lg text-xs font-semibold">@session.ClassName</span>
                                        </td>
                                        <td class="py-4 text-xs font-medium text-slate-500">
                                            @session.StartTime.ToString("HH:mm") - @session.EndTime.ToString("HH:mm")
                                        </td>
                                        <td class="py-4 text-right">
                                            @if (session.Status == "Đang diễn ra")
                                            {
                                                <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wide bg-brand-orange/10 text-brand-orange">
                                                    <span class="w-1.5 h-1.5 rounded-full bg-brand-orange mr-1.5 animate-pulse"></span> @session.Status
                                                </span>
                                            }
                                            else if (session.Status == "Sắp diễn ra")
                                            {
                                                <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wide bg-brand-blue-container/10 text-brand-blue-container">
                                                    @session.Status
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wide bg-slate-100 text-slate-500">
                                                    @session.Status
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="py-8 text-center text-slate-400 text-sm font-medium">
                                        Chưa có ca thi nào được tạo.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-span-12 lg:col-span-4 space-y-6">
            <h3 class="text-xl font-extrabold mb-4 text-slate-800">Thống kê nhanh</h3>
            <div class="grid grid-cols-2 gap-4">

                <div class="bg-brand-blue p-5 rounded-[28px] text-white shadow-lg shadow-brand-blue/10">
                    <div class="flex justify-between items-start mb-4">
                        <span class="material-symbols-outlined text-2xl">school</span>
                        <div class="w-8 h-4 bg-white/30 rounded-full flex items-center px-1">
                            <div class="w-2.5 h-2.5 bg-white rounded-full ml-auto"></div>
                        </div>
                    </div>
                    <p class="text-[10px] font-bold opacity-80 uppercase tracking-widest">Tổng số lớp học</p>
                    <h3 class="text-2xl font-black mt-1">@Model.TotalClasses.ToString("D2")</h3>
                </div>

                <div class="bg-brand-yellow p-5 rounded-[28px] text-slate-800 shadow-lg shadow-brand-yellow/10">
                    <div class="flex justify-between items-start mb-4">
                        <span class="material-symbols-outlined text-2xl">description</span>
                        <div class="w-8 h-4 bg-black/10 rounded-full flex items-center px-1">
                            <div class="w-2.5 h-2.5 bg-white rounded-full ml-auto"></div>
                        </div>
                    </div>
                    <p class="text-[10px] font-bold opacity-70 uppercase tracking-widest">Đề thi đã tạo</p>
                    <h3 class="text-2xl font-black mt-1">@Model.TotalExams.ToString("D2")</h3>
                </div>

                <div class="bg-brand-orange p-5 rounded-[28px] text-white shadow-lg shadow-brand-orange/10">
                    <div class="flex justify-between items-start mb-4">
                        <span class="material-symbols-outlined text-2xl">sensors</span>
                        <div class="w-8 h-4 bg-white/30 rounded-full flex items-center px-1">
                            <div class="w-2.5 h-2.5 bg-white rounded-full ml-auto"></div>
                        </div>
                    </div>
                    <p class="text-[10px] font-bold opacity-80 uppercase tracking-widest">Đang diễn ra</p>
                    <h3 class="text-2xl font-black mt-1">@Model.OngoingSessions.ToString("D2")</h3>
                </div>

                <div class="bg-brand-blue-container p-5 rounded-[28px] text-white shadow-lg shadow-brand-blue/10">
                    <div class="flex justify-between items-start mb-4">
                        <span class="material-symbols-outlined text-2xl">event</span>
                        <div class="w-8 h-4 bg-white/30 rounded-full flex items-center px-1">
                            <div class="w-2.5 h-2.5 bg-white rounded-full ml-auto"></div>
                        </div>
                    </div>
                    <p class="text-[10px] font-bold opacity-80 uppercase tracking-widest">Ca thi sắp tới</p>
                    <h3 class="text-2xl font-black mt-1">@Model.UpcomingSessions.ToString("D2")</h3>
                </div>
            </div>

            <div class="bg-white border border-slate-100 p-6 rounded-[32px] shadow-sm mt-8">
                <h4 class="font-extrabold text-sm mb-2 flex items-center text-slate-800"><span class="material-symbols-outlined text-brand-yellow mr-2 text-lg">lightbulb</span> Mẹo sử dụng</h4>
                <ul class="space-y-3 mt-4 text-xs font-medium text-slate-500">
                    <li class="flex gap-2 items-start"><span class="text-brand-blue">•</span> Tạo lớp học để lấy mã mời gửi cho sinh viên.</li>
                    <li class="flex gap-2 items-start"><span class="text-brand-blue">•</span> Upload file Word/PDF để AI tự động bóc tách câu hỏi và đáp án.</li>
                    <li class="flex gap-2 items-start"><span class="text-brand-blue">•</span> Bật tính năng đảo câu hỏi khi tạo ca thi để chống gian lận.</li>
                </ul>
            </div>
        </div>
    </div>
</div>