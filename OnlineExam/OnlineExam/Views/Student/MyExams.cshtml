@model OnlineExam.ViewModels.StudentDashboardVM
@{
    var currentKeyword = (string?)ViewBag.SearchKeyword ?? string.Empty;
    var currentStatus = (string?)ViewBag.StatusFilter ?? "all";
    var currentPage = (int?)ViewBag.CurrentPage ?? 1;
    var totalPages = (int?)ViewBag.TotalPages ?? 1;
    var totalItems = (int?)ViewBag.TotalItems ?? (Model.Exams?.Count ?? 0);
}

<div class="max-w-7xl mx-auto space-y-8">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <div class="flex items-center gap-3">
            <h1 class=" flex items-center text-[32px] font-['Manrope',_sans-serif] font-bold text-[#0369A1] leading-none tracking-tight">Ca thi của tôi</h1> <div class="font-bold text-slate-700 w-[20px] h-[20px] bg-slate-300 rounded-full flex items-center justify-center">@totalItems</div>
            </div>
            <p class="text-sm text-slate-500 mt-2">Danh sách tất cả các bài kiểm tra được giao.</p>
        </div>
    </div>

    @if (ViewBag.ShowMeiliSearchWarning == true)
    {
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                if (window.appToast) window.appToast.warning("Không kết nối được với Meilisearch. Hệ thống đã tự động chuyển sang tìm kiếm thường.");
            });
        </script>
    }

    <form method="get" class="bg-white rounded-2xl border border-slate-100 shadow-sm p-4 md:p-5 grid grid-cols-1 md:grid-cols-12 gap-3 items-end">
        <div class="md:col-span-8">
            <label class="text-xs font-semibold text-slate-500 uppercase tracking-widest block mb-2">Tìm kiếm ca thi</label>
            <div class="relative">
                <span class="material-symbols-outlined text-slate-400 absolute left-3 top-1/2 -translate-y-1/2">search</span>
                <input id="examSearchInput" name="searchKeyword" value="@currentKeyword" type="text" class="w-full h-11 rounded-xl border border-slate-200 pl-10 pr-4 focus:ring-2 focus:ring-[#0369A1]/20 focus:border-[#0369A1]" placeholder="Nhập tên ca thi, lớp học hoặc giáo viên..." />
            </div>
        </div>

        <div class="md:col-span-4">
            <label class="text-xs font-semibold text-transparent uppercase tracking-widest block mb-2 select-none">.</label>
            <select id="classFilterSelect" name="statusFilter" class="w-full h-11 rounded-xl border border-slate-200 px-4 focus:ring-2 focus:ring-[#0369A1]/20 focus:border-[#0369A1] bg-white">
                <option value="all" selected="@(currentStatus == "all")">Tất cả trạng thái</option>
                <option value="Chưa làm" selected="@(currentStatus == "Chưa làm")">Chưa làm</option>
                <option value="Sắp hết hạn" selected="@(currentStatus == "Sắp hết hạn")">Sắp hết hạn</option>
                <option value="Đã nộp" selected="@(currentStatus == "Đã nộp")">Đã nộp</option>
            </select>
        </div>
        <input type="hidden" name="page" value="1" />
    </form>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 w-full pb-12" id="exam-list">
        @if (Model.Exams != null && Model.Exams.Any())
        {
            foreach (var exam in Model.Exams)
            {
                var statusText = exam.Status;
                var isSubmitted = exam.Status == "Đã nộp";
                var isOpen = exam.Status == "Chưa làm" || exam.Status == "Sắp hết hạn";
                var isUpcoming = exam.Status == "Chưa mở"; // not started yet
                var toneClass = isSubmitted ? "border-[#dbeafe]" : (isOpen ? "border-[#dbeafe]" : "border-slate-100");
                var headToneClass = isSubmitted ? "bg-[#f2f3fd] text-[#0369A1]" : (isOpen ? "bg-[#f2f3fd] text-[#0369A1]" : "bg-slate-50 text-slate-400");
                var badgeToneClass = isSubmitted ? "bg-[#e8f1ff] text-[#0369A1]" : (isOpen ? "bg-[#e8f1ff] text-[#0369A1]" : "bg-slate-100 text-slate-500");
                var disabledClass = "bg-slate-100 text-slate-400 cursor-not-allowed pointer-events-none";
                var buttonClass = isSubmitted ? "bg-[#0369A1] hover:bg-[#025b88] text-white" : (isOpen ? "bg-[#0369A1] hover:bg-[#025b88] text-white" : disabledClass);
                var buttonHref = isSubmitted ? $"/Student/ExamResult/{exam.ExamSessionId}" : (isOpen ? $"/Student/TakeExam/{exam.ExamSessionId}" : "#");
                var buttonText = isSubmitted ? "Xem kết quả" : (isOpen ? "Vào thi" : (isUpcoming ? "Sắp diễn ra" : "Đã kết thúc"));

                <a href="@buttonHref"
                   class="exam-card block bg-white rounded-2xl overflow-hidden shadow-[0px_12px_28px_rgba(25,28,35,0.06)] border @toneClass @(isOpen || isSubmitted ? "hover:-translate-y-1 transition-transform duration-300" : "pointer-events-none") flex flex-col"
                         >
                    <div class="h-32 flex items-center justify-center relative @headToneClass">
                        <span class="material-symbols-outlined text-[72px]" style="font-variation-settings: 'FILL' 1;">assignment</span>
                        <div class="absolute top-3 right-3 px-3 py-1 rounded-full @badgeToneClass text-xs font-bold backdrop-blur-sm">
                            @statusText
                        </div>
                    </div>

                    <div class="p-5 flex flex-col gap-4 flex-1">
                        <div>
                            <h3 class="font-bold text-[18px] text-slate-800 leading-tight line-clamp-2">@exam.Title</h3>
                            <p class="text-sm text-slate-500 mt-1 line-clamp-1">@exam.ClassName</p>
                        </div>

                        <div class="space-y-2 text-sm text-slate-600">
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-[18px] text-[#0369A1]">person</span>
                                <span class="font-medium truncate">GV. @exam.TeacherName</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-[18px] text-[#0369A1]">schedule</span>
                                <span class="font-medium">@exam.Duration phút</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-[18px] text-[#0369A1]">event</span>
                                <span class="font-semibold text-[#0369A1]">@(isSubmitted ? $"Nộp lúc: {exam.EndTime:dd/MM HH:mm}" : $"Hạn: {exam.EndTime:dd/MM HH:mm}")</span>
                            </div>
                        </div>

                        <div class="mt-auto pt-2">
                            <div class="w-full py-3 rounded-xl text-sm font-bold text-center @buttonClass">
                                @buttonText
                            </div>
                        </div>
                    </div>
                </a>
            }
        }
        else
        {
            <div class="col-span-full py-20 text-center flex flex-col items-center bg-white rounded-2xl border border-dashed border-slate-200 shadow-sm">
                <span class="material-symbols-outlined text-6xl text-on-surface/20 mb-4">folder_open</span>
                <h4 class="text-xl font-bold text-on-surface/50 mb-2">Không có ca thi nào</h4>
                <p class="text-on-surface/40">Bạn hiện chưa tham gia lớp học nào có bài thi.</p>
            </div>
        }
    </div>

    @if (totalPages > 1)
    {
        var startPage = Math.Max(1, currentPage - 2);
        var endPage = Math.Min(totalPages, startPage + 4);
        startPage = Math.Max(1, endPage - 4);

        <div class="flex items-center justify-center gap-2 pt-2">
            <a class="h-10 w-10 rounded-xl bg-slate-100 text-[#0369A1] flex items-center justify-center transition-colors @(currentPage == 1 ? "pointer-events-none opacity-45" : "hover:bg-[#e8f1ff]")"
               href="@Url.Action("MyExams", "Student", new { searchKeyword = currentKeyword, statusFilter = currentStatus, page = currentPage - 1 })"
               aria-label="Trang trước">
                <span class="material-symbols-outlined text-[18px]">chevron_left</span>
            </a>
            @for (var pageNumber = startPage; pageNumber <= endPage; pageNumber++)
            {
                <a class="h-10 min-w-10 px-3 rounded-xl text-sm font-bold inline-flex items-center justify-center transition-colors @(pageNumber == currentPage ? "bg-[#0369A1] text-white" : "bg-slate-100 text-[#0369A1] hover:bg-[#e8f1ff]")"
                   href="@Url.Action("MyExams", "Student", new { searchKeyword = currentKeyword, statusFilter = currentStatus, page = pageNumber })">@pageNumber</a>
            }
            <a class="h-10 w-10 rounded-xl bg-slate-100 text-[#0369A1] flex items-center justify-center transition-colors @(currentPage == totalPages ? "pointer-events-none opacity-45" : "hover:bg-[#e8f1ff]")"
               href="@Url.Action("MyExams", "Student", new { searchKeyword = currentKeyword, statusFilter = currentStatus, page = currentPage + 1 })"
               aria-label="Trang sau">
                <span class="material-symbols-outlined text-[18px]">chevron_right</span>
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        const examSearchInput = document.getElementById('examSearchInput');
        const classFilterSelect = document.getElementById('classFilterSelect');
        let examSearchTimer;

        examSearchInput?.addEventListener('input', () => {
            clearTimeout(examSearchTimer);
            examSearchTimer = setTimeout(() => {
                examSearchInput.closest('form')?.submit();
            }, 350);
        });
        classFilterSelect?.addEventListener('change', () => classFilterSelect.closest('form')?.submit());
    </script>
}