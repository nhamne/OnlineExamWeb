@{
    Layout = "_Layout";
}

<div class="max-w-2xl mx-auto mt-24 p-8 bg-white rounded-2xl shadow-sm">
    <h2 class="text-2xl font-bold mb-4">Nhập mật khẩu để vào ca thi</h2>
    <p class="text-sm text-slate-600 mb-6">@ViewData["SessionName"]</p>

    @if (ViewData["Error"] != null)
    {
        <div class="mb-4 p-3 rounded-md bg-rose-50 text-rose-700">@ViewData["Error"]</div>
    }

    <form method="post" asp-action="EnterExamPassword" asp-controller="Student">
        @Html.AntiForgeryToken()
        <input type="hidden" name="sessionId" value="@ViewData["SessionId"]" />
        <div class="mb-6">
            <label class="block text-sm font-medium mb-2">Mật khẩu ca thi</label>
            <input id="examPasswordInput" name="password" type="password" autocomplete="off" placeholder="Nhập mật khẩu" class="w-full px-4 py-3 rounded-lg border focus:outline-none focus:ring-2 focus:ring-brand-blue password-with-toggle" />
        </div>

        <div class="flex items-center gap-3">
            <button type="submit" class="px-6 py-3 bg-brand-blue text-white rounded-lg">Xác nhận</button>
            <a href="/Student/Index" class="px-4 py-3 border rounded-lg">Hủy</a>
        </div>
    </form>
</div>
