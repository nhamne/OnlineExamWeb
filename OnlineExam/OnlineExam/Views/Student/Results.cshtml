@model OnlineExam.ViewModels.StudentResultsVM
@{
    var currentKeyword = (string?)ViewBag.SearchKeyword ?? string.Empty;
    var currentSortBy = (string?)ViewBag.SortBy ?? "submitted_desc";
    var currentPage = (int?)ViewBag.CurrentPage ?? 1;
    var totalPages = (int?)ViewBag.TotalPages ?? 1;
    var totalItems = (int?)ViewBag.TotalItems ?? (Model.Submissions?.Count ?? 0);
}

<div class="max-w-7xl mx-auto space-y-8">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h1 class="text-[32px] font-['Manrope',_sans-serif] font-bold text-[#0369A1] leading-none tracking-tight">Kết quả học tập</h1>
            <p class="text-sm text-slate-500 mt-2">Lịch sử và tiến độ làm bài của bạn. <span class="font-bold text-slate-700">@totalItems bài đã nộp</span></p>
        </div>
    </div>

    @if (ViewBag.ShowMeiliSearchWarning == true)
    {
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                if (window.appToast) window.appToast.warning("Không kết nối được với Meilisearch. Hệ thống đã tự động chuyển sang tìm kiếm thường.");
            });
        </script>
    }

    <form method="get" class="bg-white rounded-2xl p-4 md:p-5 border border-slate-100 shadow-sm grid grid-cols-1 md:grid-cols-12 gap-3 items-end">
        <div class="md:col-span-7">
            <label class="text-xs font-semibold text-slate-500 uppercase tracking-widest block mb-2">Tìm kiếm kết quả</label>
            <div class="relative">
                <span class="material-symbols-outlined text-slate-400 absolute left-3 top-1/2 -translate-y-1/2">search</span>
                <input id="resultSearchInput" name="searchKeyword" value="@currentKeyword" type="text" class="w-full h-11 rounded-xl border border-slate-200 pl-10 pr-4 focus:ring-2 focus:ring-[#0369A1]/20 focus:border-[#0369A1]" placeholder="Nhập tên ca thi hoặc lớp học..." />
            </div>
        </div>

        <div class="md:col-span-5">
            <label class="text-xs font-semibold text-slate-500 uppercase tracking-widest block mb-2">Sắp xếp kết quả</label>
            <div class="relative">
                <select id="resultSortSelect" name="sortBy" class="w-full h-11 appearance-none rounded-xl border border-slate-200 pl-4 pr-11 focus:ring-2 focus:ring-[#0369A1]/20 focus:border-[#0369A1] bg-white">
                    <option value="submitted_desc" selected="@(currentSortBy == "submitted_desc")">Mới nộp nhất</option>
                    <option value="submitted_asc" selected="@(currentSortBy == "submitted_asc")">Nộp lâu nhất</option>
                    <option value="score_desc" selected="@(currentSortBy == "score_desc")">Điểm cao nhất</option>
                    <option value="score_asc" selected="@(currentSortBy == "score_asc")">Điểm thấp nhất</option>
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none">expand_more</span>
            </div>
        </div>
        <input type="hidden" name="page" value="1" />
    </form>

    @if (Model.ScoreHistory != null && Model.ScoreHistory.Any())
    {
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-4 md:p-5">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-11 h-11 rounded-xl bg-[#f2f3fd] text-[#0369A1] flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined">monitoring</span>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-slate-800">Tiến độ học tập</h3>
                    <p class="text-sm text-slate-500">Biểu đồ thể hiện kết quả các bài thi gần đây.</p>
                </div>
            </div>
            <div class="w-full h-72">
                <canvas id="scoreChart"></canvas>
            </div>
        </div>
    }

    <div class="grid grid-cols-1 gap-4 w-full pb-12">
        @if (Model.Submissions != null && Model.Submissions.Any())
        {
            foreach (var sub in Model.Submissions)
            {
                <a href="/Student/ExamResult/@sub.ExamSessionId" class="group bg-white rounded-2xl border border-slate-100 shadow-[0px_12px_28px_rgba(25,28,35,0.06)] hover:-translate-y-1 transition-transform duration-300 overflow-hidden">
                    <div class="h-3 bg-[#0369A1]"></div>
                    <div class="p-6 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
                        <div class="flex items-start gap-4">
                            <div class="w-14 h-14 rounded-xl bg-[#f2f3fd] text-[#0369A1] flex items-center justify-center text-2xl shrink-0 font-headline font-black">
                                @(sub.Score ?? 0)
                            </div>
                            <div>
                                <h3 class="text-lg font-bold text-slate-800 mb-1 group-hover:text-[#0369A1] transition-colors">@sub.ExamSession.SessionName</h3>
                                <div class="flex flex-wrap items-center gap-4 text-xs text-slate-500 font-medium">
                                    <div class="flex items-center gap-1">
                                        <span class="material-symbols-outlined text-[16px] text-[#0369A1]">domain</span>
                                        <span>@sub.ExamSession.Classroom.ClassName</span>
                                    </div>
                                    <div class="flex items-center gap-1">
                                        <span class="material-symbols-outlined text-[16px] text-[#0369A1]">schedule</span>
                                        <span>@(sub.SubmittedAt?.ToString("dd/MM/yyyy HH:mm"))</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <span class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-[#f2f3fd] text-[#0369A1] font-bold text-sm group-hover:bg-[#0369A1] group-hover:text-white transition-colors shrink-0">
                            Xem chi tiết
                            <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                        </span>
                    </div>
                </a>
            }
        }
        else
        {
            <div class="bg-white p-10 rounded-2xl shadow-sm border border-dashed border-slate-200 text-center col-span-full">
                <span class="material-symbols-outlined text-6xl text-on-surface/20 mb-4">history</span>
                <h3 class="text-xl font-bold text-slate-500">Chưa có kết quả nào</h3>
                <p class="text-sm text-slate-400 mt-2">Bạn chưa hoàn thành bài kiểm tra nào.</p>
            </div>
        }
    </div>

    @if (totalPages > 1)
    {
        var startPage = Math.Max(1, currentPage - 2);
        var endPage = Math.Min(totalPages, startPage + 4);
        startPage = Math.Max(1, endPage - 4);

        <div class="flex items-center justify-center gap-2 pt-2">
            <a class="h-10 w-10 rounded-xl bg-slate-100 text-[#0369A1] flex items-center justify-center transition-colors @(currentPage == 1 ? "pointer-events-none opacity-45" : "hover:bg-[#e8f1ff]")"
               href="@Url.Action("Results", "Student", new { searchKeyword = currentKeyword, sortBy = currentSortBy, page = currentPage - 1 })"
               aria-label="Trang trước">
                <span class="material-symbols-outlined text-[18px]">chevron_left</span>
            </a>
            @for (var pageNumber = startPage; pageNumber <= endPage; pageNumber++)
            {
                <a class="h-10 min-w-10 px-3 rounded-xl text-sm font-bold inline-flex items-center justify-center transition-colors @(pageNumber == currentPage ? "bg-[#0369A1] text-white" : "bg-slate-100 text-[#0369A1] hover:bg-[#e8f1ff]")"
                   href="@Url.Action("Results", "Student", new { searchKeyword = currentKeyword, sortBy = currentSortBy, page = pageNumber })">@pageNumber</a>
            }
            <a class="h-10 w-10 rounded-xl bg-slate-100 text-[#0369A1] flex items-center justify-center transition-colors @(currentPage == totalPages ? "pointer-events-none opacity-45" : "hover:bg-[#e8f1ff]")"
               href="@Url.Action("Results", "Student", new { searchKeyword = currentKeyword, sortBy = currentSortBy, page = currentPage + 1 })"
               aria-label="Trang sau">
                <span class="material-symbols-outlined text-[18px]">chevron_right</span>
            </a>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const resultSearchInput = document.getElementById('resultSearchInput');
        const resultSortSelect = document.getElementById('resultSortSelect');
        let resultSearchTimer;

        resultSearchInput?.addEventListener('input', () => {
            clearTimeout(resultSearchTimer);
            resultSearchTimer = setTimeout(() => {
                resultSearchInput.closest('form')?.submit();
            }, 350);
        });
        resultSortSelect?.addEventListener('change', () => resultSortSelect.closest('form')?.submit());

        @if(Model.ScoreHistory != null && Model.ScoreHistory.Any())
        {
            <text>
            document.addEventListener('DOMContentLoaded', function() {
                const ctx = document.getElementById('scoreChart').getContext('2d');
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: [@Html.Raw(string.Join(",", Model.ScoreHistory.Select(s => $"'{s.ExamName.Replace("'", "\\'")}'")))],
                        datasets: [{
                            label: 'Điểm số',
                            data: [@string.Join(",", Model.ScoreHistory.Select(s => s.Score.ToString(System.Globalization.CultureInfo.InvariantCulture)))],
                            borderColor: '#1a61a4',
                            backgroundColor: 'rgba(26, 97, 164, 0.1)',
                            borderWidth: 3,
                            tension: 0.4,
                            fill: true,
                            pointBackgroundColor: '#1a61a4',
                            pointBorderColor: '#fff',
                            pointBorderWidth: 2,
                            pointRadius: 5,
                            pointHoverRadius: 8
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: '#2c3437',
                                padding: 12,
                                titleFont: { family: 'Inter', size: 13 },
                                bodyFont: { family: 'Inter', size: 15, weight: 'bold' },
                                callbacks: {
                                    label: function(context) {
                                        return context.parsed.y + ' điểm';
                                    }
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                max: 10,
                                ticks: { stepSize: 2, font: { size: 12, family: 'Inter' } },
                                grid: { color: 'rgba(0,0,0,0.05)' },
                                border: { display: false }
                            },
                            x: {
                                ticks: { font: { size: 11, family: 'Inter' } },
                                grid: { display: false }
                            }
                        },
                        interaction: {
                            intersect: false,
                            mode: 'index',
                        },
                    }
                });
            });
            </text>
        }
    </script>
}