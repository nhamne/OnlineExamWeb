@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Tham gia lớp học | The Academic Sanctuary</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'primary': '#1a61a4',
                        'primary-container': '#75aef7',
                        'surface': '#f7f9fb',
                        'surface-container-low': '#f0f4f7',
                        'on-surface': '#2c3437',
                        'outline-variant-soft': 'rgba(172, 179, 183, 0.15)',
                    },
                    fontFamily: {
                        'headline': ['Manrope', 'sans-serif'],
                        'body': ['Inter', 'sans-serif'],
                    },
                    backgroundImage: {
                        'knowledge-flow': 'linear-gradient(135deg, #1a61a4 0%, #75aef7 100%)',
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; color: #2c3437; }
        .font-headline { font-family: 'Manrope', sans-serif; }
        .transition-soft { transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }
    </style>
</head>
<body class="bg-surface min-h-screen flex flex-col items-center justify-center p-6">

    <div class="w-full max-w-md">
        <a href="/Student/Index" class="inline-flex items-center gap-2 text-on-surface/50 hover:text-primary transition-colors mb-8 font-semibold">
            <span class="material-symbols-outlined text-sm">arrow_back</span>
            Quay lại trang chủ
        </a>

        <div class="bg-white rounded-3xl shadow-2xl p-10 relative overflow-hidden border border-outline-variant-soft">
            <div class="absolute top-0 left-0 w-full h-2 bg-knowledge-flow"></div>
            
            <div class="w-16 h-16 bg-blue-50 rounded-2xl flex items-center justify-center text-primary mb-8">
                <span class="material-symbols-outlined text-[32px]">person_add</span>
            </div>

            <h1 class="text-3xl font-extrabold font-headline mb-3 text-on-surface">Tham gia lớp học</h1>
            <p class="text-on-surface/60 mb-8 text-sm leading-relaxed">Nhập mã lớp học (Join Code) do giáo viên cung cấp để thêm lớp vào danh sách của bạn.</p>
            
            <div class="space-y-6">
                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest text-on-surface/50 mb-2">Mã lớp học</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface/30">vpn_key</span>
                        <input type="text" id="joinCodeInput" placeholder="VD: WEBNC1" class="w-full pl-12 pr-4 py-4 bg-surface-container-low border border-transparent rounded-xl focus:border-primary/30 focus:bg-white focus:ring-4 focus:ring-primary/10 transition-all outline-none font-bold text-lg uppercase tracking-wide placeholder:normal-case placeholder:font-normal" />
                    </div>
                </div>

                <p id="joinClassError" class="text-red-500 text-sm font-semibold hidden flex items-center gap-2"><span class="material-symbols-outlined text-sm">error</span> <span id="errorMsg"></span></p>
                <p id="joinClassSuccess" class="text-green-600 text-sm font-semibold hidden flex items-center gap-2"><span class="material-symbols-outlined text-sm">check_circle</span> <span id="successMsg"></span></p>

                <button onclick="submitJoinClass()" id="submitBtn" class="w-full py-4 bg-knowledge-flow text-white rounded-xl font-bold shadow-lg hover:shadow-primary/30 hover:-translate-y-1 transition-all flex justify-center items-center gap-2">
                    <span class="material-symbols-outlined text-[20px]">login</span>
                    <span>Xác nhận tham gia</span>
                </button>
            </div>
        </div>
    </div>

    <script>
        async function submitJoinClass() {
            const codeInput = document.getElementById('joinCodeInput');
            const code = codeInput.value.trim();
            const errorEl = document.getElementById('joinClassError');
            const successEl = document.getElementById('joinClassSuccess');
            const errorMsg = document.getElementById('errorMsg');
            const successMsg = document.getElementById('successMsg');
            const btn = document.getElementById('submitBtn');
            
            errorEl.classList.add('hidden');
            successEl.classList.add('hidden');

            if (!code) {
                errorMsg.textContent = 'Vui lòng nhập mã lớp học.';
                errorEl.classList.remove('hidden');
                codeInput.focus();
                return;
            }

            btn.disabled = true;
            btn.classList.add('opacity-70', 'cursor-not-allowed');

            try {
                const formData = new FormData();
                formData.append('joinCode', code);

                const res = await fetch('/Student/JoinClass', {
                    method: 'POST',
                    body: formData
                });
                const data = await res.json();
                
                if (data.success) {
                    successMsg.textContent = data.message || 'Tham gia lớp thành công!';
                    successEl.classList.remove('hidden');
                    setTimeout(() => window.location.href = '/Student/Index', 1500);
                } else {
                    errorMsg.textContent = data.message || 'Mã lớp không hợp lệ.';
                    errorEl.classList.remove('hidden');
                }
            } catch (err) {
                errorMsg.textContent = 'Đã có lỗi mạng xảy ra. Vui lòng thử lại.';
                errorEl.classList.remove('hidden');
            } finally {
                btn.disabled = false;
                btn.classList.remove('opacity-70', 'cursor-not-allowed');
            }
        }

        // Allow pressing Enter to submit
        document.getElementById('joinCodeInput').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                submitJoinClass();
            }
        });
    </script>
</body>
</html>
