@model OnlineExam.ViewModels.UserProfileVM
@{
    ViewData["Title"] = "Quản lý tài khoản";
}

<div class="max-w-7xl mx-auto space-y-8">
    <div>
        <h1 class="text-[32px] font-['Manrope',_sans-serif] font-bold text-[#0369A1] leading-none tracking-tight">Quản lý tài khoản</h1>
        <p class="text-sm text-slate-500 mt-2 mb-2">Cập nhật thông tin cá nhân và cài đặt bảo mật của bạn.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-emerald-900 flex items-start gap-3">
            <span class="material-symbols-outlined text-[22px] mt-0.5">check_circle</span>
            <div>
                <p class="font-bold">Thành công</p>
                <p class="text-sm mt-1">@TempData["SuccessMessage"]</p>
            </div>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-red-900 flex items-start gap-3">
            <span class="material-symbols-outlined text-[22px] mt-0.5">error</span>
            <div>
                <p class="font-bold">Có lỗi xảy ra</p>
                <p class="text-sm mt-1">@TempData["ErrorMessage"]</p>
            </div>
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mt-2">
        
        <!-- Cập nhật thông tin -->
        <div class="bg-white rounded-2xl p-6 md:p-8 border border-slate-100 shadow-sm">
            <div class="flex items-center gap-3 mb-6">
                <span class="material-symbols-outlined text-[#0369A1] text-3xl">badge</span>
                <h2 class="text-xl font-bold text-slate-800">Thông tin cá nhân</h2>
            </div>
            
            <form action="/Profile/UpdateInfo" method="post" class="space-y-5">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Vai trò</label>
                    <div class="w-full h-12 rounded-xl border border-slate-200 px-4 bg-slate-50 flex items-center text-slate-500">
                        @(Model.Role == "Teacher" ? "Giáo viên" : "Học sinh")
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Email (Đăng nhập)</label>
                    <div class="w-full h-12 rounded-xl border border-slate-200 px-4 bg-slate-50 flex items-center text-slate-500">
                        @Model.Email
                    </div>
                    <p class="text-xs text-slate-400 mt-2">* Email không thể thay đổi vì được dùng làm tài khoản đăng nhập.</p>
                </div>

                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Họ và tên</label>
                    <input type="text" name="FullName" value="@Model.FullName" required
                           class="w-full h-12 rounded-xl border border-slate-200 px-4 focus:ring-2 focus:ring-[#0369A1]/20 focus:border-[#0369A1] transition-all" 
                           placeholder="Nhập họ và tên..." />
                </div>

                <div class="pt-4">
                    <button type="submit" class="w-full bg-[#0369A1] text-white h-12 rounded-xl font-bold flex items-center justify-center gap-2 shadow-[0_8px_20px_-6px_rgba(3,105,161,0.4)] hover:shadow-[0_12px_24px_-6px_rgba(3,105,161,0.5)] active:scale-[0.98] transition-all duration-300">
                        <span class="material-symbols-outlined text-[20px]">save</span>
                        Lưu thông tin
                    </button>
                </div>
            </form>
        </div>

        <!-- Đổi mật khẩu -->
        <div class="bg-white rounded-2xl p-6 md:p-8 border border-slate-100 shadow-sm">
            <div class="flex items-center gap-3 mb-6">
                <span class="material-symbols-outlined text-amber-500 text-3xl">lock</span>
                <h2 class="text-xl font-bold text-slate-800">Đổi mật khẩu</h2>
            </div>
            
            <form action="/Profile/ChangePassword" method="post" class="space-y-5">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Mật khẩu hiện tại</label>
                    <div class="relative">
                        <input type="password" name="CurrentPassword" required
                               class="w-full h-12 rounded-xl border border-slate-200 px-4 focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all" 
                               placeholder="Nhập mật khẩu hiện tại..." />
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Mật khẩu mới</label>
                    <div class="relative">
                        <input type="password" name="NewPassword" required minlength="6"
                               class="w-full h-12 rounded-xl border border-slate-200 px-4 focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all" 
                               placeholder="Mật khẩu mới (tối thiểu 6 ký tự)..." />
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Xác nhận mật khẩu mới</label>
                    <div class="relative">
                        <input type="password" name="ConfirmNewPassword" required minlength="6"
                               class="w-full h-12 rounded-xl border border-slate-200 px-4 focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all" 
                               placeholder="Nhập lại mật khẩu mới..." />
                    </div>
                </div>

                <div class="pt-4">
                    <button type="submit" class="w-full bg-amber-500 text-white h-12 rounded-xl font-bold flex items-center justify-center gap-2 shadow-[0_8px_20px_-6px_rgba(245,158,11,0.4)] hover:shadow-[0_12px_24px_-6px_rgba(245,158,11,0.5)] active:scale-[0.98] transition-all duration-300">
                        <span class="material-symbols-outlined text-[20px]">key</span>
                        Cập nhật mật khẩu
                    </button>
                </div>
            </form>
        </div>

    </div>
</div>
